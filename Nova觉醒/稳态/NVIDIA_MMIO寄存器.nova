NV_PMC_BOOT_0 为 0x000000。

NV_PMC_BOOT_1 为 0x000004。

NV_PMC_ENABLE 为 0x000200。

NV_PMC_INTR_0 为 0x000100。

NV_PMC_INTR_EN_0 为 0x000140。

NV_PMC_INTR_LT_0 为 0x000160。

PMC_ENABLE_PFIFO 为 1 左移 8。

PMC_ENABLE_PGRAPH 为 1 左移 12。

PMC_ENABLE_PCOPY0 为 1 左移 15。

PMC_ENABLE_PCOPY1 为 1 左移 16。

PMC_ENABLE_PDISPLAY 为 1 左移 26。

PMC_ENABLE_PWR 为 1 左移 13。

NV_PBUS_INTR_0 为 0x001100。

NV_PBUS_INTR_EN_0 为 0x001140。

NV_PBUS_BAR0_WINDOW 为 0x001700。

NV_PBUS_BAR1_BLOCK 为 0x001704。

NV_PTIMER_TIME_0 为 0x009400。

NV_PTIMER_TIME_1 为 0x009410。

NV_PTIMER_INTR_0 为 0x009100。

NV_PFIFO_INTR_0 为 0x002100。

NV_PFIFO_INTR_EN_0 为 0x002140。

NV_PFIFO_RUNLIST_BASE 为 0x002270。

NV_PFIFO_RUNLIST_SUBMIT 为 0x002274。

NV_PFIFO_CHAN_BASE 为 0x800000。

NV_PFIFO_CHAN_SIZE 为 0x1000。

NV_PGRAPH_INTR 为 0x400100。

NV_PGRAPH_NSTATUS 为 0x400104。

NV_PGRAPH_STATUS 为 0x400700。

NV_PGRAPH_GPC_NUM 为 0x409604。

NV_PGRAPH_TPC_PER_GPC 为 0x409614。

NV_PGRAPH_SM_PER_TPC 为 0x409618。

NV_PGRAPH_FECS_INTR 为 0x409C20。

NV_PDISPLAY_INTR_0 为 0x610020。

NV_PDISPLAY_INTR_EN_0 为 0x610024。

NV_PDISP_HEAD_STATE_CTRL 为 0x616300。

NV_PDISP_HEAD_STATE_SIZE 为 0x616304。

NV_PDISP_HEAD_STATE_SYNC 为 0x616308。

NV_PDISP_SOR_HDMI_CTRL 为 0x616500。

NV_PDISP_SOR_DP_CTRL 为 0x616540。

