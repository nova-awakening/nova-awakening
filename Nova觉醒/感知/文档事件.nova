EVT_CLICK 为 1; EVT_DBLCLICK = 2。
EVT_MOUSEDOWN 为 3; EVT_MOUSEUP = 4; EVT_MOUSEMOVE = 5。
EVT_MOUSEENTER 为 6; EVT_MOUSELEAVE = 7。
EVT_KEYDOWN 为 12; EVT_KEYUP = 13; EVT_KEYPRESS = 14。
EVT_INPUT 为 15; EVT_CHANGE = 16。
EVT_FOCUS 为 17; EVT_BLUR = 18。
EVT_SCROLL 为 23; EVT_LOAD = 25。
EVT_SUBMIT 为 21; EVT_WHEEL = 11。
EVT_TOUCHSTART 为 39; EVT_TOUCHMOVE = 40。
EVT_TOUCHEND 为 41; EVT_POINTERDOWN = 43。
EVT_CUSTOM 为 99。

MOD_CTRL 为 1; MOD_SHIFT = 2; MOD_ALT = 4; MOD_META = 8。

