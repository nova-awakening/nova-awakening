AX_ROLE_BUTTON 为 1。

AX_ROLE_LINK 为 2。

AX_ROLE_HEADING 为 3。

AX_ROLE_TAB 为 4。

AX_ROLE_MENUITEM 为 5。

AX_ROLE_OPTION 为 6。

AX_ROLE_TREEITEM 为 7。

AX_ROLE_LISTITEM 为 8。

AX_ROLE_TEXTBOX 为 9。

AX_ROLE_CHECKBOX 为 10。

AX_ROLE_RADIO 为 11。

AX_ROLE_SLIDER 为 12。

AX_ROLE_NAVIGATION 为 13。

AX_ROLE_MAIN 为 14。

AX_ROLE_SEARCH 为 15。

AX_ROLE_FORM 为 16。

AX_ROLE_DIALOG 为 17。

AX_ROLE_ALERT 为 18。

AX_ROLE_TABLE 为 19。

AX_ROLE_ROW 为 20。

AX_ROLE_CELL 为 21。

AX_ROLE_IMG 为 22。

AX_ROLE_GENERIC 为 23。

AX_STATE_DISABLED 为 0x0001。

AX_STATE_REQUIRED 为 0x0002。

AX_STATE_READONLY 为 0x0004。

AX_STATE_CHECKED 为 0x0008。

AX_STATE_HIDDEN 为 0x0010。

AX_STATE_EXPANDED 为 0x0020。

AX_STATE_SELECTED 为 0x0040。

AX_STATE_PRESSED 为 0x0080。

AX_STATE_BUSY 为 0x0100。

AX_STATE_INVALID 为 0x0200。

AX_STATE_FOCUSABLE 为 0x0400。

