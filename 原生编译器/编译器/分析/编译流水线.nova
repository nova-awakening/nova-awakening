}

// §8验收矩阵: 语义_报告 / 动态逃逸_报告
函数 语义_报告() {
    定义 r = 字典()
    字典设(r, "推断总数", 转字符串(_语义_推断总数))
    字典设(r, "函数类型数", 转字符串(_语义_函数类型数))
    字典设(r, "AI违规数", 转字符串(_语义_AI违规数))
    字典设(r, "动态逃逸数", 转字符串(_语义_动态逃逸数))
    字典设(r, "逃逸阈值", 转字符串(_语义_逃逸阈值))
    字典设(r, "逃逸门控通过", 转字符串(流水线_逃逸门控通过()))
    返回 r
}

函数 动态逃逸_报告() {
    定义 r = 字典()
    字典设(r, "逃逸总数", 转字符串(_语义_动态逃逸数))
    字典设(r, "逃逸详情数", 转字符串(计数(_语义_逃逸详情)))
    字典设(r, "阈值", 转字符串(_语义_逃逸阈值))
    字典设(r, "门控通过", 转字符串(流水线_逃逸门控通过()))
    // 逃逸详情(前10条)
    定义 可变 escape_i = 0
    当 (escape_i < 计数(_语义_逃逸详情) 且 escape_i < 10) {
        定义 d = _语义_逃逸详情[escape_i]
        字典设(r, 字符串拼接("逃逸_", 转字符串(escape_i)), 字符串拼接(d[0], 字符串拼接(":", d[1])))
        escape_i = escape_i + 1
    }
    返回 r
}

函数 约束冲突_报告() {
    定义 r = 字典()
    字典设(r, "约束域_函数数", 转字符串(_约束域_函数数))
    字典设(r, "约束域_安全数", 转字符串(_约束域_安全数))
    字典设(r, "约束域_警告数", 转字符串(_约束域_警告数))
    字典设(r, "AI违规数", 转字符串(_语义_AI违规数))
    字典设(r, "逃逸门控通过", 转字符串(流水线_逃逸门控通过()))
    定义 可变 冲突总 = _约束域_警告数 + _语义_AI违规数
    字典设(r, "冲突总数", 转字符串(冲突总))
    返回 r
}

