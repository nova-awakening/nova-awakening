// Nova · 编译器 · 编译流水线整合 (Compilation Pipeline Integration)
// 统一调度所有分析模块，形成完整的优化编译流水线
// 阶段: 前端 → 语义 → 分析 → 优化 → 代码生成 → 调度

导入("../../IR/优化器/优化管线.nova")
导入("../../编译器/标记常量.nova")
导入("../../系统扩展/P2-改进/生命周期.nova")
导入("../../平台/目标选择.nova")
导入("../../标准库/基础.nova")
导入("../../标准库/转换器/转换验证.nova")
导入("内存安全分析.nova")
导入("别名分析.nova")
导入("向量化分析.nova")
导入("常量传播.nova")
导入("循环不变量提升.nova")
导入("循环分析.nova")
导入("指令调度.nova")
导入("支配树.nova")
导入("数据流分析.nova")
导入("热度分析.nova")
导入("过程间优化.nova")
导入("过程间分析.nova")
导入("值域分析.nova")
导入("并发分析.nova")
导入("指针分析.nova")
导入("逃逸分析增强.nova")
导入("DWARF调试信息.nova")
导入("../智能优化/智能寄存器分配.nova")
导入("../智能优化/程序行为预测.nova")
导入("../前端入口.nova")
导入("../宏系统/宏系统.nova")
导入("../智能优化/自适应优化器.nova")
导入("../语义/类型推断.nova")
导入("类型推断.nova")  // HM 风格补充引擎 (类型宽度/二元结果/合并类型)
导入("../跨语言/外源合同/外源项目合同.nova")
导入("../跨语言/工程摄取/工程探测器.nova")
导入("../跨语言/统一语义/统一语义图.nova")
导入("../验证/形式化验证引擎.nova")
