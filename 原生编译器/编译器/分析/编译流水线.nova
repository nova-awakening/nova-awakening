// §6.5 流水线_报告 — 总流水线结构化报告
函数 流水线_报告() {
    定义 r = 字典()
    字典设(r, "profile", 目标_获取profile())
    字典设(r, "target", 目标_名称())
    // 已执行阶段
    定义 可变 已执行数 = 0
    定义 可变 跳过数 = 0
    定义 可变 总优化 = 0
    定义 可变 pi = 0
    当 (pi < 计数(_流水线_阶段)) {
        如果 (_流水线_阶段[pi][2] > 0) {
            已执行数 = 已执行数 + 1
            总优化 = 总优化 + _流水线_阶段[pi][5]
        } 否则 {
            跳过数 = 跳过数 + 1
        }
        pi = pi + 1
    }
    字典设(r, "已执行阶段数", 转字符串(已执行数))
    字典设(r, "跳过阶段数", 转字符串(跳过数))
    字典设(r, "总优化次数", 转字符串(总优化))
    字典设(r, "安全评级", 字典取(安全验证_汇总报告(), "综合评级"))
    字典设(r, "逃逸门控", 转字符串(流水线_逃逸门控通过()))
    字典设(r, "形式化_检查数", 转字符串(_形式化_检查数))
    字典设(r, "形式化_失败数", 转字符串(_形式化_失败数))
    返回 r
}

// §6.5 布局映射 — 镜像布局报告
函数 布局映射(镜像类型, 目标名, 入口符号, 基址, 代码大小, 运行时大小) {
    定义 r = 字典()
    字典设(r, "image_kind", 镜像类型)
    字典设(r, "target", 目标名)
    字典设(r, "entry_symbol", 入口符号)
    字典设(r, "base_address", 转字符串(基址))
    字典设(r, "code_size", 转字符串(代码大小))
    字典设(r, "runtime_size", 转字符串(运行时大小))
    字典设(r, "total_size", 转字符串(代码大小 + 运行时大小))
    返回 r
}

// 跨语言原生重置报告

函数 流水线_重置计划报告(源合同, 目标合同, 语义图) {
    定义 r = 字典()
    字典设(r, "报告类型", "reset_plan_report")
    如果 (源合同 != 空) {
        字典设(r, "源语言", 源语言_名称(外源合同_源语言(源合同)))
        字典设(r, "源工作区", 外源合同_工作区根(源合同))
        字典设(r, "公共API数", 转字符串(计数(外源合同_公共API(源合同))))
        字典设(r, "FFI边界数", 转字符串(计数(外源合同_FFI边界(源合同))))
        字典设(r, "高风险项数", 转字符串(计数(外源合同_高风险(源合同))))
        字典设(r, "不支持项数", 转字符串(计数(外源合同_不支持项(源合同))))
    }
    如果 (语义图 != 空) {
        字典设(r, "语义节点数", 转字符串(计数(语义图_节点(语义图))))
        字典设(r, "类型映射数", 转字符串(计数(语义图_类型映射(语义图))))
        字典设(r, "风险项数", 转字符串(计数(语义图_风险项(语义图))))
        字典设(r, "阻塞项数", 转字符串(计数(语义图_阻塞项(语义图))))
    }
    // 阻塞判定
    定义 可变 可继续 = 真
    如果 (源合同 != 空 且 计数(外源合同_不支持项(源合同)) > 0) { 可继续 = 假 }
    如果 (语义图 != 空 且 计数(语义图_阻塞项(语义图)) > 0) { 可继续 = 假 }
    字典设(r, "可继续重置", 转字符串(可继续))
    返回 r
}

