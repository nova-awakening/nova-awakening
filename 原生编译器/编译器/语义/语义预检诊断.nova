导入("../../标准库/基础.nova")
导入("../分析/错误诊断.nova")
导入("./作用域.nova")
导入("./符号表.nova")
导入("./可变性检查.nova")
导入("./未使用检查.nova")

函数 语义预检_未使用类别名(类别) {
    如果 (类别 == 类_变量) { 返回 "变量" }
    如果 (类别 == 未使用检查_类_函数) { 返回 "函数" }
    如果 (类别 == 类_参数) { 返回 "参数" }
    如果 (类别 == 类_导入) { 返回 "导入" }
    返回 "符号"
}

函数 语义预检_追加候选符号(列表, 名称) {
    如果 (名称 == 空 或 名称 == "") { 返回 0 }
    定义 可变 i = 0
    当 (i < 计数(列表)) {
        如果 (列表[i] == 名称) { 返回 0 }
        i = i + 1
    }
    追加(列表, 名称)
    返回 1
}

函数 语义预检_可用符号列表(语义结果) {
    定义 可变 结果 = []
    如果 (是列表(语义结果) == 假) { 返回 结果 }
    如果 (计数(语义结果) >= 1) {
        定义 符号表 = 语义结果[0]
        如果 (是列表(符号表) 且 计数(符号表) >= 3) {
            定义 可变 i = 0
            当 (i < 符号表_符号表_大小(符号表)) {
                语义预检_追加候选符号(结果, 符号表[0][i][0])
                i = i + 1
            }
        }
    }
    如果 (计数(语义结果) >= 2) {
        定义 作用域栈 = 语义结果[1]
        如果 (是列表(作用域栈) 且 计数(作用域栈) >= 1 且 是列表(作用域栈[0])) {
            定义 可变 si = 0
            当 (si < 计数(作用域栈[0])) {
                定义 域 = 作用域栈[0][si]
                定义 变量表 = 作用域_变量(域)
                定义 可变 vi = 0
                当 (vi < 计数(变量表)) {
                    语义预检_追加候选符号(结果, 变量_名称(变量表[vi]))
                    vi = vi + 1
                }
                si = si + 1
            }
        }
    }
    返回 结果
}

函数 语义预检_跨度(文件索引, 行号) {
    定义 可变 行 = 行号
    如果 (是整数(行) == 假 或 行 <= 0) { 行 = 1 }
    返回 跨度_创建(文件索引, 行, 1, 行, 1)
}

函数 语义预检_创建预检问题诊断(文件索引, 问题, 可用符号列) {
    定义 类型 = 问题[0]
    定义 名称 = 问题[1]
    定义 行号 = 问题[2]
    定义 参考行号 = 问题[3]
    定义 新跨度 = 语义预检_跨度(文件索引, 行号)
    如果 (类型 == 语义问题_重定义) {
        如果 (参考行号 > 0) { 返回 诊断_符号重定义(新跨度, 语义预检_跨度(文件索引, 参考行号), 名称) }
        定义 d = 诊断_创建(诊断_错误,  错误码_重定义,
            字符串拼接("符号 `", 字符串拼接(名称, "` 在同一作用域内重复定义")), 0, 0, 0)
        诊断_添加标注(d, 标注_主要(新跨度, "重复定义"))
        返回 d
    }
    如果 (类型 == 语义问题_未定义赋值) {
        定义 d = 诊断_未定义符号_带推荐(新跨度, 名称, 可用符号列)
        诊断_添加说明(d, "提示: 此处是赋值目标，请先定义该变量")
        返回 d
    }
    如果 (类型 == 语义问题_未定义引用) { 返回 诊断_未定义符号_带推荐(新跨度, 名称, 可用符号列) }
    返回 空
}

函数 语义预检_创建可变性诊断(文件索引, 错误项) {
    定义 错误码 = 错误项[0]
    定义 名称 = 错误项[1]
    定义 跨度 = 语义预检_跨度(文件索引, 错误项[2])
    如果 (错误码 == 检_赋不可变) { 返回 诊断_不可变变量(跨度, 名称) }
    定义 描述 = 可变性检_错误描述(错误码)
    定义 d = 诊断_创建(诊断_错误,  错误码_可变性,
        字符串拼接(描述, 字符串拼接(": `", 字符串拼接(名称, "`"))), 0, 0, 0)
    诊断_添加标注(d, 标注_主要(跨度, 描述))
    返回 d
}

函数 语义预检_创建未使用诊断(文件索引, 警告项) {
    定义 名称 = 警告项[1]
    定义 类别 = 警告项[2]
    定义 跨度 = 语义预检_跨度(文件索引, 警告项[3])
    如果 (类别 == 类_变量) { 返回 诊断_未使用变量(跨度, 名称) }
    定义 类别名 = 语义预检_未使用类别名(类别)
    定义 d = 诊断_创建(诊断_警告,  3100,
        字符串拼接(类别名, 字符串拼接(" `", 字符串拼接(名称, "` 未使用"))), 0, 0, 0)
    定义 标注说明 = 字符串拼接("此", 字符串拼接(类别名, "被声明但从未使用"))
    诊断_添加标注(d, 标注_主要(跨度, 标注说明))
    返回 d
}

函数 语义预检_生成诊断收集器(文件路径, 语义结果) {
    定义 收集器 = 诊断收集器_创建()
    定义 文件索引 = 诊断收集器_注册文件(收集器, 文件路径)
    定义 可用符号列 = 语义预检_可用符号列表(语义结果)
    定义 可变 问题列表 = []
    如果 (是列表(语义结果) 且 计数(语义结果) >= 7 且 是列表(语义结果[6])) { 问题列表 = 语义结果[6] }
    定义 可变 i = 0
    当 (i < 计数(问题列表)) {
        定义 d = 语义预检_创建预检问题诊断(文件索引, 问题列表[i], 可用符号列)
        如果 (d != 空) { 诊断收集器_添加(收集器, d) }
        i = i + 1
    }
    定义 可变 可变错误列 = []
    如果 (是列表(语义结果) 且 计数(语义结果) >= 3) { 可变错误列 = 可变性检_错误列表(语义结果[2]) }
    i = 0
    当 (i < 计数(可变错误列)) {
        诊断收集器_添加(收集器, 语义预检_创建可变性诊断(文件索引, 可变错误列[i]))
        i = i + 1
    }
    定义 可变 未用警告列 = []
    如果 (是列表(语义结果) 且 计数(语义结果) >= 4) { 未用警告列 = 未用检_警告列表(语义结果[3]) }
    i = 0
    当 (i < 计数(未用警告列)) {
        诊断收集器_添加(收集器, 语义预检_创建未使用诊断(文件索引, 未用警告列[i]))
        i = i + 1
    }
    返回 收集器
}
