导入("../../标准库/基础.nova")
导入("../../编译器/标记常量.nova")
导入("./可变性检查.nova")
导入("./未使用检查.nova")
导入("./符号表.nova")

// Nova 原生作用域管理 — 记录每个变量在哪个范围内可见和使用
// 职责：作用域进入/退出、变量声明与查找、遥蔽检测、闭包捕获分析
// 层级：第3层语义分析

// 作用域类型
定义 域_全局  = 0
定义 域_函数  = 1
定义 域_块    = 2
定义 域_循环  = 3
定义 域_匹配  = 4

// 变量条目: [名称ID, 类型, 是否可变, 已赋值, 被引用, 声明行]
函数 变量_创建(名称ID, 是可变, 行号) {
    返回 [名称ID, 0, 是可变, 0, 0, 行号]
}

函数 变量_名称(v) { 返回 v[0] }
函数 变量_可变(v) { 返回 v[2] }
函数 变量_已赋值(v) { 返回 v[3] }
函数 变量_被引用(v) { 返回 v[4] }
函数 变量_行号(v) { 返回 v[5] }

函数 变量_标记赋值(v) { v[3] = 1 }
函数 变量_标记引用(v) { v[4] = 1 }

// 作用域: [类型, 父索引, 变量列表, 深度]
函数 作用域_创建(类型, 父索引, 深度) {
    返回 [类型, 父索引, [], 深度]
}

函数 作用域_类型(s) { 返回 s[0] }
函数 作用域_父(s) { 返回 s[1] }
函数 作用域_变量(s) { 返回 s[2] }
函数 作用域_作用域_深度(s) { 返回 s[3] }
函数 作用域_变量数(s) { 返回 计数(s[2]) }

// 作用域栈: [作用域列表, 当前索引]
函数 作用域栈_创建() {
    定义 全局 = 作用域_创建(域_全局,  0 - 1, 0)
    返回 [[全局], 0]
}

函数 作用域栈_推入(栈, 类型) {
    定义 当前 = 栈[1]
    定义 深度 = 栈[0][当前][3] + 1
    定义 新作用域 = 作用域_创建(类型, 当前, 深度)
    追加(栈[0], 新作用域)
    栈[1] = 计数(栈[0]) - 1
    返回 栈[1]
}

函数 作用域栈_弹出(栈) {
    定义 当前 = 栈[0][栈[1]]
    栈[1] = 当前[1]
    返回 当前
}

函数 作用域栈_当前(栈) {
    返回 栈[0][栈[1]]
}

函数 作用域栈_深度(栈) {
    返回 栈[0][栈[1]][3]
}

// 变量声明
函数 声明变量(栈, 名称ID, 是可变, 行号) {
    定义 当前 = 栈[0][栈[1]]
    // 检查当前作用域是否重复
    定义 变量表 = 当前[2]
    定义 可变 i = 0
    当 (i < 计数(变量表)) {
        如果 (变量表[i][0] == 名称ID) { 返回 0 }
        i = i + 1
    }
    追加(当前[2], 变量_创建(名称ID, 是可变, 行号))
    返回 1
}

函数 当前作用域_查找变量(栈, 名称ID) {
    定义 当前 = 栈[0][栈[1]]
    定义 变量表 = 当前[2]
    定义 可变 i = 0
    当 (i < 计数(变量表)) {
        如果 (变量表[i][0] == 名称ID) { 返回 变量表[i] }
        i = i + 1
    }
    返回 0
}

// 变量查找 (向上搜索作用域链)
函数 查找变量(栈, 名称ID) {
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        定义 作用域 = 栈[0][索引]
        定义 变量表 = 作用域[2]
        定义 可变 i = 0
        当 (i < 计数(变量表)) {
            如果 (变量表[i][0] == 名称ID) { 返回 变量表[i] }
            i = i + 1
        }
        索引 = 作用域[1]
    }
    返回 0
}

// 是否在循环中
函数 在循环作用域(栈) {
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        如果 (栈[0][索引][0] == 域_循环) { 返回 1 }
        如果 (栈[0][索引][0] == 域_函数) { 返回 0 }
        索引 = 栈[0][索引][1]
    }
    返回 0
}

// 是否在函数中
函数 在函数作用域(栈) {
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        如果 (栈[0][索引][0] == 域_函数) { 返回 1 }
        索引 = 栈[0][索引][1]
    }
    返回 0
}

// 遮蔽检测: 内层变量是否遮蔽外层同名变量
函数 检查遮蔽(栈, 名称ID) {
    定义 可变 索引 = 栈[0][栈[1]][1]  // 从父作用域开始
    当 (索引 >= 0) {
        定义 作用域 = 栈[0][索引]
        定义 变量表 = 作用域[2]
        定义 可变 i = 0
        当 (i < 计数(变量表)) {
            如果 (变量表[i][0] == 名称ID) {
                返回 [1, 作用域[3], 变量表[i][5]]  // [是遮蔽, 被遮蔽深度, 被遮蔽行号]
            }
            i = i + 1
        }
        索引 = 作用域[1]
    }
    返回 [0,]
}

// 未使用变量检测
函数 检测未使用变量(栈, 作用域索引) {
    定义 作用域 = 栈[0][作用域索引]
    定义 变量表 = 作用域[2]
    定义 可变 未使用 = []
    定义 可变 i = 0
    当 (i < 计数(变量表)) {
        如果 (变量表[i][4] == 0 且 变量表[i][3] == 1) {
            // 已赋值但从未引用
            追加(未使用, [变量表[i][0], 变量表[i][5]])
        }
        i = i + 1
    }
    返回 未使用
}

// 未赋值就引用检测
函数 检测未初始化引用(栈, 作用域索引) {
    定义 作用域 = 栈[0][作用域索引]
    定义 变量表 = 作用域[2]
    定义 可变 问题 = []
    定义 可变 i = 0
    当 (i < 计数(变量表)) {
        如果 (变量表[i][4] == 1 且 变量表[i][3] == 0) {
            // 被引用但从未赋值
            追加(问题, [变量表[i][0], 变量表[i][5]])
        }
        i = i + 1
    }
    返回 问题
}

// 闭包捕获分析
// 检测当前函数作用域中引用的外部变量(需要闭包捕获)
函数 分析闭包捕获(栈) {
    定义 可变 捕获列表 = []
    定义 可变 函数深度 = -1

    // 找到最近的函数作用域
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        如果 (栈[0][索引][0] == 域_函数) {
            函数深度 = 栈[0][索引][3]
            索引 = -1  // 退出
        } 否则 {
            索引 = 栈[0][索引][1]
        }
    }

    如果 (函数深度 < 0) { 返回 捕获列表 }

    // 收集当前函数作用域内所有引用的变量
    索引 = 栈[1]
    当 (索引 >= 0 且 栈[0][索引][3] >= 函数深度) {
        定义 变量表 = 栈[0][索引][2]
        定义 可变 i = 0
        当 (i < 计数(变量表)) {
            如果 (变量表[i][4] == 1) {
                // 检查定义位置是否在函数外部
                定义 定义结果 = 查找变量定义深度(栈, 变量表[i][0])
                如果 (定义结果 >= 0 且 定义结果 < 函数深度) {
                    追加(捕获列表, [变量表[i][0], 定义结果, 变量表[i][2]])
                }
            }
            i = i + 1
        }
        索引 = 栈[0][索引][1]
    }
    返回 捕获列表
}

// 查找变量定义所在的作用域深度
函数 查找变量定义深度(栈, 名称ID) {
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        定义 变量表 = 栈[0][索引][2]
        定义 可变 i = 0
        当 (i < 计数(变量表)) {
            如果 (变量表[i][0] == 名称ID 且 变量表[i][3] == 1) {
                返回 栈[0][索引][3]  // 返回定义所在深度
            }
            i = i + 1
        }
        索引 = 栈[0][索引][1]
    }
    返回 -1  // 未找到
}

// 全面作用域诊断
函数 作用域_诊断(栈) {
    定义 总作用域 = 计数(栈[0])
    定义 可变 总变量 = 0
    定义 可变 总未使用 = 0
    定义 可变 总遮蔽 = 0
    定义 可变 最大深度 = 0

    定义 可变 s = 0
    当 (s < 总作用域) {
        定义 作用域 = 栈[0][s]
        总变量 = 总变量 + 计数(作用域[2])
        如果 (作用域[3] > 最大深度) { 最大深度 = 作用域[3] }

        定义 未使用 = 检测未使用变量(栈, s)
        总未使用 = 总未使用 + 计数(未使用)
        s = s + 1
    }

    返回 [
        总作用域,    // [0] 总作用域数
        总变量,      // [1] 总变量数
        总未使用,    // [2] 未使用变量数
        最大深度,    // [3] 最大嵌套深度
        总遮蔽       // [4] 遮蔽警告数
    ]
}

// 作用域内变量统计
函数 作用域_统计可变率(栈, 索引) {
    定义 变量表 = 栈[0][索引][2]
    定义 总数 = 计数(变量表)
    如果 (总数 == 0) { 返回 0 }
    定义 可变 可变数 = 0
    定义 可变 i = 0
    当 (i < 总数) {
        如果 (变量表[i][2] == 1) { 可变数 = 可变数 + 1 }
        i = i + 1
    }
    返回 可变数 * 10000 / 总数  // 万分比
}

// 是否在匹配作用域中
函数 在匹配作用域(栈) {
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        如果 (栈[0][索引][0] == 域_匹配) { 返回 1 }
        如果 (栈[0][索引][0] == 域_函数) { 返回 0 }
        索引 = 栈[0][索引][1]
    }
    返回 0
}

// 获取当前函数的局部变量数 (用于栈帧大小计算)
函数 统计函数局部变量(栈) {
    定义 可变 总数 = 0
    定义 可变 索引 = 栈[1]
    当 (索引 >= 0) {
        定义 作用域 = 栈[0][索引]
        总数 = 总数 + 计数(作用域[2])
        如果 (作用域[0] == 域_函数) {
            返回 总数  // 到达函数边界
        }
        索引 = 作用域[1]
    }
    返回 总数
}

定义 可变 _作用域_创建数 = 0
定义 可变 _作用域_最大深度 = 0

定义 语义问题_重定义 = 1
定义 语义问题_未定义赋值 = 2
定义 语义问题_未定义引用 = 3

函数 语义_预检_追加问题(问题列表, 类型, 名称ID, 行号, 参考行号) {
    定义 可变 i = 0
    当 (i < 计数(问题列表)) {
        定义 项 = 问题列表[i]
        如果 (项[0] == 类型 且 项[1] == 名称ID 且 项[2] == 行号) { 返回 0 }
        i = i + 1
    }
    追加(问题列表, [类型, 名称ID, 行号, 参考行号])
    返回 1
}

函数 语义_预检_取语句行号(语句) {
    如果 (是列表(语句) == 假) { 返回 0 }
    如果 (计数(语句) == 0) { 返回 0 }
    定义 候选 = 语句[计数(语句) - 1]
    如果 (是整数(候选)) { 返回 候选 }
    返回 0
}

函数 语义_预检_记录赋值(作用域栈, 可变检查器, 未用检查器, 问题列表, 名称ID, 行号) {
    如果 (名称ID == 空 或 名称ID == "") { 返回 0 }
    如果 (查找变量(作用域栈, 名称ID) == 0) {
        语义_预检_追加问题(问题列表, 语义问题_未定义赋值, 名称ID, 行号, 0)
    }
    可变性检_赋值(可变检查器,  名称ID,  行号)
    未用检_赋值记录(未用检查器, 名称ID)
    返回 1
}

函数 语义_预检_注册变量(作用域栈, 可变检查器, 未用检查器, 问题列表, 名称ID, 类别, 是可变, 行号) {
    如果 (名称ID == 空 或 名称ID == "") { 返回 0 }
    定义 已有 = 当前作用域_查找变量(作用域栈, 名称ID)
    如果 (已有 != 0) {
        语义_预检_追加问题(问题列表, 语义问题_重定义, 名称ID, 行号, 变量_行号(已有))
        返回 0
    }
    声明变量(作用域栈,  名称ID,  是可变,  行号)
    定义 可变 可变性 = 性_不可变
    如果 (是可变) { 可变性 = 性_可变 }
    可变性检_注册(可变检查器, 名称ID, 可变性)
    未用检_声明(未用检查器,  名称ID,  类别,  行号)
    返回 1
}

函数 语义_预检_记录引用(作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 名称ID, 行号, 检查未定义) {
    如果 (名称ID == 空 或 名称ID == "") { 返回 0 }
    未用检_引用(未用检查器, 名称ID)
    可变性检_使用(可变检查器,  名称ID,  行号)
    如果 (检查未定义) {
        如果 (查找变量(作用域栈, 名称ID) == 0 且 符号表_符号表_查找(符号表, 名称ID) == 0) {
            语义_预检_追加问题(问题列表, 语义问题_未定义引用, 名称ID, 行号, 0)
        }
    }
    返回 1
}

函数 语义_预检_变量是否可变(语句) {
    如果 (是列表(语句) == 假) { 返回 0 }
    如果 (计数(语句) < 4) { 返回 0 }
    如果 (语句[3]) { 返回 1 }
    返回 0
}

函数 语义_预检_遍历表达式(表达式, 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) {
    如果 (是列表(表达式) == 假 或 计数(表达式) == 0) { 返回 0 }
    定义 类型 = 表达式[0]
    如果 (类型 == 标记_名称) {
        语义_预检_记录引用(作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 表达式[1], 当前行, 1)
        返回 1
    }
    如果 (类型 == 节点_调用) {
        语义_预检_记录引用(作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 表达式[1], 当前行, 0)
        如果 (计数(表达式) >= 3 且 是列表(表达式[2])) {
            定义 可变 i = 0
            当 (i < 计数(表达式[2])) {
                语义_预检_遍历表达式(表达式[2][i], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行)
                i = i + 1
            }
        }
        返回 1
    }
    如果 (类型 == 节点_二元) {
        如果 (计数(表达式) >= 3) { 语义_预检_遍历表达式(表达式[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        如果 (计数(表达式) >= 4) { 语义_预检_遍历表达式(表达式[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        返回 1
    }
    如果 (类型 == 节点_赋值) {
        如果 (计数(表达式) >= 2 且 是列表(表达式[1])) {
            定义 可变 i = 0
            当 (i < 计数(表达式[1])) {
                语义_预检_遍历表达式(表达式[1][i], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行)
                i = i + 1
            }
        }
        返回 1
    }
    如果 (类型 == 节点_索引) {
        如果 (计数(表达式) >= 2) { 语义_预检_遍历表达式(表达式[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        如果 (计数(表达式) >= 3) { 语义_预检_遍历表达式(表达式[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        返回 1
    }
    如果 (类型 == 标记_抛出) {
        如果 (计数(表达式) >= 3 且 是列表(表达式[2])) {
            定义 可变 i = 0
            当 (i < 计数(表达式[2])) {
                定义 字段 = 表达式[2][i]
                如果 (是列表(字段) 且 计数(字段) >= 2) {
                    语义_预检_遍历表达式(字段[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行)
                }
                i = i + 1
            }
        }
        返回 1
    }
    如果 (类型 == 标记_连接词) {
        如果 (计数(表达式) >= 2) { 语义_预检_遍历表达式(表达式[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        返回 1
    }
    如果 (类型 == 节点_一元正 或 类型 == 节点_一元负) {
        如果 (计数(表达式) >= 2) { 语义_预检_遍历表达式(表达式[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 当前行) }
        返回 1
    }
    返回 0
}

函数 语义_预检_遍历语句列(语句列, 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表) {
    如果 (是列表(语句列) == 假) { 返回 0 }
    定义 可变 i = 0
    当 (i < 计数(语句列)) {
        语义_预检_遍历语句(语句列[i], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
        i = i + 1
    }
    返回 1
}

函数 语义_预检_遍历语句(语句, 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表) {
    如果 (是列表(语句) == 假 或 计数(语句) == 0) { 返回 0 }
    定义 类型 = 语句[0]
    定义 _行 = 语义_预检_取语句行号(语句)
    如果 (类型 == 标记_定义) {
        定义 可变 是可变 = 语义_预检_变量是否可变(语句)
        语义_预检_注册变量(作用域栈, 可变检查器, 未用检查器, 问题列表, 语句[1], 类_变量, 是可变, _行)
        如果 (计数(语句) >= 3) {
            语义_预检_遍历表达式(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行)
            语义_预检_记录赋值(作用域栈, 可变检查器, 未用检查器, 问题列表, 语句[1], _行)
        }
        返回 1
    }
    如果 (类型 == 标记_可变) {
        如果 (计数(语句) >= 3) { 语义_预检_遍历表达式(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        语义_预检_记录赋值(作用域栈, 可变检查器, 未用检查器, 问题列表, 语句[1], _行)
        返回 1
    }
    如果 (类型 == 标记_函数) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        作用域栈_推入(作用域栈, 域_块)
        如果 (计数(语句) >= 3) { 语义_预检_遍历语句列(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表) }
        作用域栈_弹出(作用域栈)
        如果 (计数(语句) >= 4 且 是列表(语句[3])) {
            作用域栈_推入(作用域栈, 域_块)
            语义_预检_遍历语句列(语句[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
            作用域栈_弹出(作用域栈)
        }
        返回 1
    }
    如果 (类型 == 标记_返回) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        作用域栈_推入(作用域栈, 域_循环)
        如果 (计数(语句) >= 3) { 语义_预检_遍历语句列(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表) }
        作用域栈_弹出(作用域栈)
        返回 1
    }
    如果 (类型 == 标记_如果) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        返回 1
    }
    如果 (类型 == 标记_否则) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        返回 1
    }
    如果 (类型 == 标记_当) {
        如果 (计数(语句) >= 2) {
            如果 (是列表(语句[1])) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
            否则 { 语义_预检_记录引用(作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, 语句[1], _行, 1) }
        }
        如果 (计数(语句) >= 3) { 语义_预检_遍历表达式(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        如果 (计数(语句) >= 4) { 语义_预检_遍历表达式(语句[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        返回 1
    }
    如果 (类型 == 标记_建) {
        如果 (计数(语句) >= 2) { 未用检_声明(未用检查器,  语句[1],  未使用检查_类_函数,  _行) }
        作用域栈_推入(作用域栈, 域_函数)
        如果 (计数(语句) >= 3 且 是列表(语句[2])) {
            定义 可变 pi = 0
            当 (pi < 计数(语句[2])) {
                语义_预检_注册变量(作用域栈,  可变检查器,  未用检查器,  问题列表,  语句[2][pi],  类_参数, 0, _行)
                语义_预检_记录赋值(作用域栈, 可变检查器, 未用检查器, 问题列表, 语句[2][pi], _行)
                pi = pi + 1
            }
        }
        如果 (计数(语句) >= 4) { 语义_预检_遍历语句列(语句[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表) }
        作用域栈_弹出(作用域栈)
        返回 1
    }
    如果 (类型 == 标记_顺序词) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        如果 (计数(语句) >= 4) { 语义_预检_遍历表达式(语句[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        返回 1
    }
    如果 (类型 == 标记_关键135) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        如果 (计数(语句) >= 3 且 是列表(语句[2])) {
            定义 可变 bi = 0
            当 (bi < 计数(语句[2])) {
                定义 分支 = 语句[2][bi]
                如果 (是列表(分支) 且 计数(分支) >= 2) {
                    语义_预检_遍历表达式(分支[0], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行)
                    作用域栈_推入(作用域栈, 域_匹配)
                    语义_预检_遍历语句列(分支[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
                    作用域栈_弹出(作用域栈)
                }
                bi = bi + 1
            }
        }
        返回 1
    }
    如果 (类型 == 节点_变量声明) {
        如果 (计数(语句) >= 2) {
            作用域栈_推入(作用域栈, 域_块)
            语义_预检_遍历语句列(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
            作用域栈_弹出(作用域栈)
        }
        如果 (计数(语句) >= 3) {
            作用域栈_推入(作用域栈, 域_块)
            语义_预检_遍历语句列(语句[2], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
            作用域栈_弹出(作用域栈)
        }
        返回 1
    }
    如果 (类型 == 节点_赋值语句) {
        如果 (计数(语句) >= 2) { 语义_预检_遍历表达式(语句[1], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表, _行) }
        返回 1
    }
    返回 0
}

函数 语义_最小预检查(函数列, 主体) {
    定义 符号表 = 符号表_创建(计数(函数列) + 64)
    定义 作用域栈 = 作用域栈_创建()
    定义 可变检查器 = 可变性检_创建()
    定义 未用检查器 = 未用检_创建()
    定义 问题列表 = []
    定义 可变 fi = 0
    当 (fi < 计数(函数列)) {
        定义 函数节点 = 函数列[fi]
        如果 (是列表(函数节点) 且 计数(函数节点) >= 2) {
            定义 函数行 = 语义_预检_取语句行号(函数节点)
            如果 (符号表_查找类型(符号表, 函数节点[1], 符号表_符号_函数) == 0) {
                符号表_追加(符号表,  函数节点[1],  符号表_符号_函数, 0 , 0)
            } 否则 {
                语义_预检_追加问题(问题列表, 语义问题_重定义, 函数节点[1], 函数行, 0)
            }
            未用检_声明(未用检查器,  函数节点[1],  未使用检查_类_函数,  函数行)
        }
        fi = fi + 1
    }
    fi = 0
    当 (fi < 计数(函数列)) {
        定义 函数节点 = 函数列[fi]
        如果 (是列表(函数节点) 且 计数(函数节点) >= 4) {
            定义 函数行 = 语义_预检_取语句行号(函数节点)
            作用域栈_推入(作用域栈, 域_函数)
            如果 (是列表(函数节点[2])) {
                定义 可变 pi = 0
                当 (pi < 计数(函数节点[2])) {
                    语义_预检_注册变量(作用域栈,  可变检查器,  未用检查器,  问题列表,  函数节点[2][pi],  类_参数, 0, 函数行)
                    语义_预检_记录赋值(作用域栈, 可变检查器, 未用检查器, 问题列表, 函数节点[2][pi], 函数行)
                    pi = pi + 1
                }
            }
            语义_预检_遍历语句列(函数节点[3], 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
            作用域栈_弹出(作用域栈)
        }
        fi = fi + 1
    }
    语义_预检_遍历语句列(主体, 作用域栈, 符号表, 可变检查器, 未用检查器, 问题列表)
    定义 未用警告数 = 未用检_执行(未用检查器)
    定义 可变错误数 = 可变性检_错误数(可变检查器) + 计数(问题列表)
    返回 [符号表, 作用域栈, 可变检查器, 未用检查器, 未用警告数, 可变错误数, 问题列表]
}
