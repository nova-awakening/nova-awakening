// §1 模块注册表

结构 模块信息 {
    名称,           // 模块名
    路径,           // 文件路径
    哈希,           // 源码哈希(用于增量编译检测)
    依赖列表,       // 依赖的其他模块名列表
    导出符号,       // 对外公开的函数/类型名列表
    编译状态,       // 0=未编译 1=编译中 2=已编译 3=编译失败
    目标码,         // 编译后的机器码(字节缓冲区)
    目标码大小,     // 机器码字节数
    上次编译时间,   // 时间戳
    版本号,         // 每次重编自增(热更新用)
    修正表数据,     // 模块内部的修正表 [[类型, 位置, 目标], ...]
    函数表数据,     // 模块的函数→偏移映射 字典(函数名→代码内偏移)
    入口偏移,       // 模块入口包装在目标码内的偏移
    // 5.1: 模块标签扩展
    profile标签,    // 所属profile列表: ["analysis-host", "linux-user", ...]
    子系统归属,     // 所属子系统名: "中枢"/"引导"/"外联"/...
    模块标签列表,   // 标签: ["启动", "内核态", "可热更", "AI原生", ...]
    允许热更,       // 是否允许热更新
    仅裸机,         // 是否仅裸机可用
    仅宿主,         // 是否仅host分析可用
    保留符号,       // 是否必须保留符号(调试用)
}

定义 可变 模块表 = []          // [模块信息]
定义 可变 模块索引 = 字典()    // 名称 → 模块表中的位置
定义 可变 编译顺序 = []        // 拓扑排序后的编译顺序
定义 可变 模块入口模块名 = ""
定义 可变 _模块_项目合同 = 空      // 项目系统合同(由Nova.nova设置)
定义 可变 _模块行号映射 = 字典() // 模块名 → 行号映射列表 (DWARF用)
定义 可变 _链接_全局函数表 = [0]
定义 可变 模块图详细模式 = [假]
定义 可变 模块图扫描读根 = ""
// 与 Nova.nova/前端入口.nova 对齐的共享编译状态，避免模块图单编时隐式全局告警
定义 可变 模块图编译器_目标ELF = 0

// §进度显示 — 现代化编译进度系统
// 可视化进度条 + 错误分类追踪 + IDE诊断文件 + 反卡死心跳

定义 可变 _进度_总数 = 0
定义 可变 _进度_当前 = 0
定义 可变 _进度_成功 = 0
定义 可变 _进度_失败 = 0
定义 可变 _进度_跳过 = 0
定义 可变 _进度_警告 = 0
定义 可变 _进度_解析错误 = 0
定义 可变 _进度_语义错误 = 0
定义 可变 _进度_能力违规 = 0
定义 可变 _进度_错误列表 = []
定义 可变 _进度_阶段 = "初始化"
定义 可变 _进度_最后模块 = ""

函数 _打印行(文本) {
    打印文本(文本)
    打印文本("\n")
}

// 预构建进度条查表 (0-20级，避免循环构建字符串)
定义 _进度条表 = [
    "....................",
    "=...................",
    "==..................",
    "===.................",
    "====................",
    "=====...............",
    "======..............",
    "=======.............",
    "========............",
    "=========...........",
    "==========..........",
    "===========.........",
    "============........",
    "=============.......",
    "==============......",
    "===============.....",
    "================....",
    "=================...",
    "==================..",
    "===================.",
    "===================="
]

函数 _进度_条(当前, 总数) {
    如果 (总数 <= 0) { 返回 _进度条表[0] }
    定义 级 = (当前 * 20) / 总数
    如果 (级 > 20) { 返回 _进度条表[20] }
    如果 (级 < 0)  { 返回 _进度条表[0] }
    返回 _进度条表[级]
}

函数 _进度_填充数字(数值, 最大值) {
    定义 可变 结果 = 转字符串(数值)
    定义 目标宽 = 字节长度(转字符串(最大值))
    当 (字节长度(结果) < 目标宽) { 结果 = 字符串拼接(" ", 结果) }
    返回 结果
}

函数 _进度_显示编译(序号, 总数, 模块名) {
    定义 条 = _进度_条(序号, 总数)
    定义 百分比 = 转字符串((序号 * 100) / 总数)
    定义 序 = _进度_填充数字(序号, 总数)
    定义 总 = 转字符串(总数)
    打印文本("  ")
    打印文本(条)
    打印文本(" ")
    打印文本(百分比)
    打印文本("% [")
    打印文本(序)
    打印文本("/")
    打印文本(总)
    打印文本("]  ")
    打印文本(模块名)
    打印文本("\n")
    _进度_最后模块 = 模块名
    如果 (序号 % 50 == 0 或 序号 == 总数) { _进度_心跳(模块名) }
}

函数 _进度_显示预注册(序号, 总数) {
    如果 (序号 == 1 或 序号 == 总数 或 序号 % 100 == 0) {
        定义 条 = _进度_条(序号, 总数)
        定义 百分比 = 转字符串((序号 * 100) / 总数)
        定义 序 = _进度_填充数字(序号, 总数)
        打印文本("  ")
        打印文本(条)
        打印文本(" ")
        打印文本(百分比)
        打印文本("% [")
        打印文本(序)
        打印文本("/")
        打印文本(转字符串(总数))
        打印文本("]  预注册")
        打印文本("\n")
    }
}

函数 _进度_记录错误(类型, 文件, 行号, 描述) {
    定义 位置串 = 字符串拼接(文件, 字符串拼接(":", 转字符串(行号)))
    定义 条目 = 字符串拼接(类型, 字符串拼接(" │ ", 字符串拼接(位置串, 字符串拼接(" │ ", 描述))))
    追加(_进度_错误列表, 条目)
    如果 (字符串相等(类型, "解析")) { _进度_解析错误 = _进度_解析错误 + 1 }
    如果 (字符串相等(类型, "语义")) { _进度_语义错误 = _进度_语义错误 + 1 }
    如果 (字符串相等(类型, "能力")) { _进度_能力违规 = _进度_能力违规 + 1 }
    _打印行(字符串拼接("    ✗ [", 字符串拼接(类型, 字符串拼接("] ", 字符串拼接(位置串, 字符串拼接("  ", 描述))))))
}

函数 _进度_心跳(模块名) {
    _进度_最后模块 = 模块名
    定义 行1 = 字符串拼接("phase=", 字符串拼接(_进度_阶段, 字符串拼接("\ncurrent=", 转字符串(_进度_当前))))
    定义 行2 = 字符串拼接("\ntotal=", 字符串拼接(转字符串(_进度_总数), 字符串拼接("\nmodule=", 模块名)))
    定义 行3 = 字符串拼接("\nsuccess=", 字符串拼接(转字符串(_进度_成功), 字符串拼接("\nfail=", 转字符串(_进度_失败))))
    定义 行4 = 字符串拼接("\nparse_err=", 字符串拼接(转字符串(_进度_解析错误), "\n"))
    写文件("/tmp/nova_compile_progress.txt", 字符串拼接(行1, 字符串拼接(行2, 字符串拼接(行3, 行4))), 0)
}

函数 _进度_写IDE诊断() {
    定义 行1 = 字符串拼接("NOVA_DIAG\nphase=", 字符串拼接(_进度_阶段, 字符串拼接("\ncurrent=", 转字符串(_进度_当前))))
    定义 行2 = 字符串拼接("\ntotal=", 字符串拼接(转字符串(_进度_总数), 字符串拼接("\nsuccess=", 转字符串(_进度_成功))))
    定义 行3 = 字符串拼接("\nfail=", 字符串拼接(转字符串(_进度_失败), 字符串拼接("\nskip=", 转字符串(_进度_跳过))))
    定义 行4 = 字符串拼接("\nparse_err=", 字符串拼接(转字符串(_进度_解析错误), 字符串拼接("\nsem_err=", 转字符串(_进度_语义错误))))
    定义 行5 = 字符串拼接("\ncap_err=", 字符串拼接(转字符串(_进度_能力违规), 字符串拼接("\nlast=", _进度_最后模块)))
    定义 行6 = 字符串拼接("\nerrors=", 字符串拼接(转字符串(计数(_进度_错误列表)), "\n"))
    写文件("/tmp/nova_compile_diag.txt", 字符串拼接(行1, 字符串拼接(行2, 字符串拼接(行3, 字符串拼接(行4, 字符串拼接(行5, 行6))))), 0)
}

函数 _进度_汇总(总数, 成功, 失败, 跳过, 警告, 解析错误) {
    _打印行("")
    _打印行("╔══════════════════════════════════════════╗")
    _打印行(字符串拼接("║  编译完成  共 ", 字符串拼接(转字符串(总数), " 个模块")))
    _打印行("╠══════════════════════════════════════════╣")
    如果 (成功 > 0) { _打印行(字符串拼接("║  ✓ 成功:     ", 转字符串(成功))) }
    如果 (失败 > 0) { _打印行(字符串拼接("║  ✗ 失败:     ", 转字符串(失败))) }
    如果 (跳过 > 0) { _打印行(字符串拼接("║  ○ 跳过:     ", 转字符串(跳过))) }
    如果 (_进度_解析错误 > 0) { _打印行(字符串拼接("║  ✗ 解析错误: ", 转字符串(_进度_解析错误))) }
    如果 (_进度_语义错误 > 0) { _打印行(字符串拼接("║  △ 语义错误: ", 转字符串(_进度_语义错误))) }
    如果 (_进度_能力违规 > 0) { _打印行(字符串拼接("║  ⊘ 能力违规: ", 转字符串(_进度_能力违规))) }
    如果 (警告 > 0) { _打印行(字符串拼接("║  △ 警告:     ", 转字符串(警告))) }
    _打印行("╚══════════════════════════════════════════╝")
    如果 (计数(_进度_错误列表) > 0) {
        _打印行(字符串拼接("\n  错误详情 (共 ", 字符串拼接(转字符串(计数(_进度_错误列表)), " 条):")))
        _打印行("  ─────────────────────────────────────")
        定义 可变 ei = 0
        当 (ei < 计数(_进度_错误列表) 且 ei < 30) {
            _打印行(字符串拼接("  ", _进度_错误列表[ei]))
            ei = ei + 1
        }
        如果 (计数(_进度_错误列表) > 30) {
            _打印行(字符串拼接("  ... 还有 ", 字符串拼接(转字符串(计数(_进度_错误列表) - 30), " 条未显示")))
        }
        _打印行("  ─────────────────────────────────────")
    }
    _打印行("")
    _进度_写IDE诊断()
}

函数 模块图_设置详细模式(启用) {
    模块图详细模式[0] = 启用
    增量缓存_设置详细模式(启用)
    并行_设置详细模式(启用)
}

函数 模块图_打印详细(文本) {
    如果 (模块图详细模式[0]) { 打印文本(文本) }
}

函数 模块图_写崩溃诊断(阶段, 模块名) {
    写文件("/临时/nova_stage2_last_module.txt", 字符串拼接(阶段, 字符串拼接("\n", 模块名)), 0)
}

函数 模块图_阶段标记(阶段, 模块名) {
    如果 (模块图详细模式[0]) {
        模块图_写崩溃诊断(阶段, 模块名)
        模块图_打印详细(字符串拼接("[阶段] ", 字符串拼接(阶段, 字符串拼接(" :: ", 模块名))))
    }
}

函数 模块图_重置运行状态() {
    如果 (模块表 != 空 且 是列表(模块表)) { 模块图_清空列表(模块表) } 否则 { 模块表 = [] }
    如果 (模块索引 != 空 且 是字典(模块索引)) { 字典_哈希表_清空(模块索引) } 否则 { 模块索引 = 字典() }
    如果 (编译顺序 != 空 且 是列表(编译顺序)) { 模块图_清空列表(编译顺序) } 否则 { 编译顺序 = [] }
    模块入口模块名 = ""
    _模块_项目合同 = 空
    如果 (_模块行号映射 != 空 且 是字典(_模块行号映射)) { 字典_哈希表_清空(_模块行号映射) } 否则 { _模块行号映射 = 字典() }
    如果 (_链接_全局函数表 != 空 且 是列表(_链接_全局函数表)) {
        如果 (计数(_链接_全局函数表) == 0) { 追加(_链接_全局函数表, 0) }
        _链接_全局函数表[0] = 0
        当 (计数(_链接_全局函数表) > 1) { 删除(_链接_全局函数表, 计数(_链接_全局函数表) - 1) }
    } 否则 {
        _链接_全局函数表 = [0]
    }
    如果 (模块图详细模式 != 空 且 是列表(模块图详细模式)) {
        如果 (计数(模块图详细模式) == 0) { 追加(模块图详细模式, 假) }
        模块图详细模式[0] = 假
        当 (计数(模块图详细模式) > 1) { 删除(模块图详细模式, 计数(模块图详细模式) - 1) }
    } 否则 {
        模块图详细模式 = [假]
    }
    模块图扫描读根 = ""
    模块图编译器_目标ELF = 0
    _进度_总数 = 0
    _进度_当前 = 0
    _进度_成功 = 0
    _进度_失败 = 0
    _进度_跳过 = 0
    _进度_警告 = 0
    _进度_解析错误 = 0
    _进度_语义错误 = 0
    _进度_能力违规 = 0
    如果 (_进度_错误列表 != 空 且 是列表(_进度_错误列表)) { 模块图_清空列表(_进度_错误列表) } 否则 { _进度_错误列表 = [] }
    _进度_阶段 = "初始化"
    _进度_最后模块 = ""
    如果 (_跳板表 != 空 且 是字典(_跳板表)) { 字典_哈希表_清空(_跳板表) } 否则 { _跳板表 = 字典() }
    如果 (_旧代码池 != 空 且 是列表(_旧代码池)) { 模块图_清空列表(_旧代码池) } 否则 { _旧代码池 = [] }
}

函数 模块图_清空列表(列表) {
    定义 可变 i = 计数(列表)
    当 (i > 0) {
        删除(列表, i - 1)
        i = i - 1
    }
}

函数 模块图_安全取字节(字节列, 偏移) {
    如果 (字节列 == 空 或 偏移 < 0 或 偏移 >= 计数(字节列)) { 返回 0 - 1 }
    返回 字节列[偏移]
}

函数 模块图_入口字节摘要(字节列, 入口偏移) {
    定义 b0 = 模块图_安全取字节(字节列, 入口偏移)
    定义 b1 = 模块图_安全取字节(字节列, 入口偏移 + 1)
    定义 b2 = 模块图_安全取字节(字节列, 入口偏移 + 2)
    定义 b3 = 模块图_安全取字节(字节列, 入口偏移 + 3)
    返回 字符串拼接("b0=", 字符串拼接(转字符串(b0), 字符串拼接(" b1=", 字符串拼接(转字符串(b1), 字符串拼接(" b2=", 字符串拼接(转字符串(b2), 字符串拼接(" b3=", 转字符串(b3))))))))
}

函数 模块图_当前目标是裸机() {
    返回 字符串相等(当前目标名称, "裸机") 或 字符串相等(当前目标名称, "kernel")
}

函数 模块图_当前目标是Linux() {
    返回 字符串相等(当前目标名称, "linux") 或 字符串相等(当前目标名称, "elf")
}

函数 模块图_当前目标格式() {
    如果 (模块图_当前目标是Linux()) { 返回 1 }
    如果 (模块图_当前目标是裸机()) { 返回 2 }
    如果 (字符串相等(当前目标名称, "windows") 或 字符串相等(当前目标名称, "pe")) { 返回 0 }
    返回 0
}

// §2 依赖图构建

函数 模块_注册(名称, 路径) {
    如果 (字典有(模块索引, 名称)) { 返回 字典取(模块索引, 名称) }
    定义 可变 信息 = 建 模块信息 {
        名称: 名称, 路径: 路径, 哈希: 0,
        依赖列表: [], 导出符号: [], 编译状态: 0,
        目标码: 空, 目标码大小: 0, 上次编译时间: 0, 版本号: 0,
        修正表数据: [], 函数表数据: 字典(), 入口偏移: 0,
        profile标签: [], 子系统归属: "", 模块标签列表: [],
        允许热更: 真, 仅裸机: 假, 仅宿主: 假, 保留符号: 假
    }
    定义 位置 = 计数(模块表)
    追加(模块表, 信息)
    字典设(模块索引, 名称, 位置)
    返回 位置
}

函数 模块_写回信息(位置, 信息) {
    模块表[位置] = 信息
}

// 5.1: 模块标签推断与profile裁剪

函数 模块_推断标签(信息) {
    // 根据模块路径推断子系统归属和标签
    定义 路径 = 信息.路径
    如果 (路径 == 空) { 返回 信息 }
    如果 (字符串包含(路径, "引导") 或 字符串包含(路径, "boot")) {
        信息.子系统归属 = "引导"
        追加(信息.模块标签列表, "启动")
        信息.允许热更 = 假
        信息.仅裸机 = 真
    }
    如果 (字符串包含(路径, "中枢") 或 字符串包含(路径, "神经")) {
        信息.子系统归属 = "中枢"
        追加(信息.模块标签列表, "AI原生")
    }
    如果 (字符串包含(路径, "外联") 或 字符串包含(路径, "网络")) {
        信息.子系统归属 = "外联"
        追加(信息.模块标签列表, "可热更")
    }
    如果 (字符串包含(路径, "推理") 或 字符串包含(路径, "注意力") 或 字符串包含(路径, "量化")) {
        追加(信息.模块标签列表, "AI原生")
    }
    如果 (字符串包含(路径, "记忆") 或 字符串包含(路径, "memory")) {
        追加(信息.模块标签列表, "记忆层")
    }
    如果 (字符串包含(路径, "学习") 或 字符串包含(路径, "赫布") 或 字符串包含(路径, "强化")) {
        追加(信息.模块标签列表, "学习层")
    }
    如果 (字符串包含(路径, "P0-裸机") 或 字符串包含(路径, "特权") 或 字符串包含(路径, "页表")) {
        信息.仅裸机 = 真
        信息.允许热更 = 假
        追加(信息.模块标签列表, "内核态")
    }
    如果 (字符串包含(路径, "调试") 或 字符串包含(路径, "DWARF") 或 字符串包含(路径, "debug")) {
        信息.保留符号 = 真
    }
    返回 信息
}

// profile裁剪: 根据当前活跃profile决定模块是否参与编译
函数 模块_profile可编译(信息, 活跃profile) {
    如果 (活跃profile == 空 或 字节长度(活跃profile) == 0) { 返回 真 }
    // 裸机profile: 跳过仅宿主模块
    如果 (字符串包含(活跃profile, "kernel")) {
        如果 (信息.仅宿主) { 返回 假 }
    }
    // 宿主profile: 跳过仅裸机模块
    如果 (字符串包含(活跃profile, "analysis") 或 字符串包含(活跃profile, "linux-user")) {
        如果 (信息.仅裸机) { 返回 假 }
    }
    // 有profile标签的模块: 检查是否包含当前profile
    如果 (计数(信息.profile标签) > 0) {
        定义 可变 _找到 = 假
        定义 可变 _pi = 0
        当 (_pi < 计数(信息.profile标签)) {
            如果 (字符串相等(信息.profile标签[_pi], 活跃profile)) { _找到 = 真 }
            _pi = _pi + 1
        }
        如果 (_找到 == 假) { 返回 假 }
    }
    返回 真
}

// 批量推断所有已注册模块的标签
函数 模块_批量推断标签() {
    定义 可变 i = 0
    当 (i < 计数(模块表)) {
        模块表[i] = 模块_推断标签(模块表[i])
        i = i + 1
    }
}

// 统计模块标签分布
函数 模块_标签统计() {
    定义 可变 AI数 = 0
    定义 可变 启动数 = 0
    定义 可变 可热更数 = 0
    定义 可变 裸机数 = 0
    定义 可变 记忆数 = 0
    定义 可变 i = 0
    当 (i < 计数(模块表)) {
        定义 _信息 = 模块表[i]
        定义 可变 j = 0
        当 (j < 计数(_信息.模块标签列表)) {
            定义 _t = _信息.模块标签列表[j]
            如果 (字符串相等(_t, "AI原生")) { AI数 = AI数 + 1 }
            如果 (字符串相等(_t, "启动")) { 启动数 = 启动数 + 1 }
            如果 (字符串相等(_t, "可热更")) { 可热更数 = 可热更数 + 1 }
            如果 (字符串相等(_t, "内核态")) { 裸机数 = 裸机数 + 1 }
            如果 (字符串相等(_t, "记忆层")) { 记忆数 = 记忆数 + 1 }
            j = j + 1
        }
        i = i + 1
    }
    返回 [AI数, 启动数, 可热更数, 裸机数, 记忆数]
}

 // 同步目标格式到全局 模块图编译器_目标ELF 变量
 函数 模块_同步目标格式() {
     模块图编译器_目标ELF = 模块图_当前目标格式()
     编译_设置目标ELF(模块图编译器_目标ELF)
     管线_设置裸机模式(模块图编译器_目标ELF == 2)
 }

 函数 模块_保存代码生成状态() {
     返回 [代码, 代码位, 修正表, 函数表, 变量表, 变量数, 字串表, 字串偏移, 全局变量表, 全局变量数, 主体模式, 当前函数名, 帧大小位, 变量类型表, 模块图编译器_目标ELF]
}

 函数 模块_重置模块代码生成状态() {
     编译_重置代码生成状态(假, 假)
     编译_设置目标ELF(模块图编译器_目标ELF)
 }

函数 模块_恢复代码生成状态(状态, 恢复全局变量) {
    代码 = 状态[0]
    代码位 = 状态[1]
    修正表 = 状态[2]
    函数表 = 状态[3]
    变量表 = 状态[4]
    变量数 = 状态[5]
    字串表 = 状态[6]
    字串偏移 = 状态[7]
    如果 (恢复全局变量) {
        全局变量表 = 状态[8]
        全局变量数 = 状态[9]
    }
    主体模式 = 状态[10]
    当前函数名 = 状态[11]
    帧大小位 = 状态[12]
    变量类型表 = 状态[13]
    模块图编译器_目标ELF = 状态[14]
    编译_设置目标ELF(模块图编译器_目标ELF)
}

函数 模块_初始化链接代码生成状态() {
    编译_重置代码生成状态(真, 假)
    编译_设置目标ELF(模块图编译器_目标ELF)
}

函数 模块图_规范路径(路径) {
    如果 (路径 == 空) { 返回 "" }
    定义 干净路径 = 替换(替换(路径, "\r", ""), "\n", "")
    如果 (计数(干净路径) == 0) { 返回 "" }
    // 反斜杠归一化 (跨平台兼容)
    定义 可变 结果 = 替换(干净路径, "\\", "/")
    // 剥离 ./ 前缀
    当 (以开头(结果, "./")) {
        结果 = 子串(结果, 2, 计数(结果) - 2)
    }
    // 消除连续斜杠
    当 (字符串包含(结果, "//")) {
        结果 = 替换(结果, "//", "/")
    }
    返回 结果
}


函数 模块图_父目录(路径) {
    定义 标准路径 = 模块图_规范路径(路径)
    定义 可变 i = 计数(标准路径) - 1
    当 (i >= 0) {
        如果 (字节取(标准路径, i) == 字符_斜杠) {
            如果 (i == 0) { 返回 "/" }
            如果 (i == 2 且 计数(标准路径) >= 3 且 字节取(标准路径, 1) == 字符_冒号) {
                返回 子串(标准路径, 0, 3)
            }
            返回 子串(标准路径, 0, i)
        }
        i = i - 1
    }
    返回 ""
}

函数 模块图_拼路径(基础, 子路径) {
    定义 可变 基 = 基础
    定义 可变 子 = 子路径
    如果 (基 == 空) { 基 = "" }
    如果 (子 == 空) { 子 = "" }
    定义 基长 = 字节长度(基)
    定义 子长 = 字节长度(子)
    定义 可变 结果 = ""
    如果 (基长 == 0) { 结果 = 子 }
    否则 如果 (子长 == 0) { 结果 = 基 }
    否则 如果 (字节取(子, 0) == 字符_斜杠 或 字节取(子, 0) == 字符_反斜杠) { 结果 = 子 }
    否则 如果 (子长 >= 2 且 字节取(子, 1) == 字符_冒号) { 结果 = 子 }
    否则 如果 (字节取(基, 基长 - 1) == 字符_斜杠 或 字节取(基, 基长 - 1) == 字符_反斜杠) { 结果 = 字符串拼接(基, 子) }
    否则 { 结果 = 字符串拼接(基, 字符串拼接("/", 子)) }
    返回 结果
}

函数 模块图_条目是目录(条目) {
    如果 (字节长度(条目) == 0) { 返回 假 }
    定义 长度 = 字节长度(条目)
    如果 (长度 <= 0) { 返回 假 }
    定义 末字 = 字节取(条目, 长度 - 1)
    如果 (末字 == 47) { 返回 真 }
    如果 (末字 == 标记_左花) { 返回 真 }
    返回 假
}

函数 模块图_条目名称(条目) {
    定义 可变 名称 = 替换(替换(条目, "\r", ""), "\n", "")
    如果 (模块图_条目是目录(名称)) {
        返回 子串(名称, 0, 计数(名称) - 1)
    }
    返回 名称
}

函数 模块图_应跳过条目(条目) {
    定义 名称 = 模块图_条目名称(条目)
    如果 (字节长度(名称) == 0 或 字符串相等(名称, ".") 或 字符串相等(名称, "..")) { 返回 真 }
    如果 (字符串相等(名称, ".nova_cache") 或 字符串相等(名称, "_bootstrap_out") 或 字符串相等(名称, ".git") 或 字符串相等(名称, ".vs")) { 返回 真 }
    如果 (以开头(名称, "_")) { 返回 真 }
    如果 (以开头(名称, ".__nova_dir_")) { 返回 真 }
    返回 假
}

函数 模块图_应跳过文件路径(路径) {
    定义 标准路径 = 模块图_规范路径(路径)
    如果 (字节长度(标准路径) == 0) { 返回 真 }
    如果 (包含(标准路径, "/.nova_cache/") 或 包含(标准路径, "/_bootstrap_out/")) { 返回 真 }
    如果 (包含(标准路径, "/.git/") 或 包含(标准路径, "/.vs/")) { 返回 真 }
    如果 (包含(标准路径, "/_")) { 返回 真 }
    如果 (包含(标准路径, "/.__nova_dir_")) { 返回 真 }
    返回 假
}

函数 模块图_递归枚举Nova文件(目录) {
    定义 标准目录 = 模块图_规范路径(目录)
    定义 可变 结果 = []
    如果 (字节长度(标准目录) == 0) { 返回 结果 }

    定义 条目列表 = 列目录(标准目录)
    定义 可变 i = 0
    当 (i < 计数(条目列表)) {
      定义 原始条目 = 条目列表[i]
      定义 条目名 = 模块图_条目名称(原始条目)
      如果 (模块图_应跳过条目(条目名)) {
          i = i + 1
          继续
      }

      定义 可变 条目路径 = 条目名
      如果 (字节长度(标准目录) != 1 或 字节取(标准目录, 0) != 字符_句点) {
          条目路径 = 字符串拼接(标准目录, 字符串拼接("/", 条目名))
      }
      如果 (模块图_条目是目录(原始条目)) {
          定义 子结果 = 模块图_递归枚举Nova文件(条目路径)
          定义 可变 si = 0
          当 (si < 计数(子结果)) {
              追加(结果, 子结果[si])
                si = si + 1
            }
        } 否则 如果 (模块图_是Nova文件路径(条目路径)) {
            如果 (!模块图_应跳过文件路径(条目路径)) {
                追加(结果, 条目路径)
            }
        }
        i = i + 1
    }
    返回 结果
}

// 项目系统接口
函数 模块图_设置项目合同(合同) {
    _模块_项目合同 = 合同
}

函数 模块_推断入口模块(项目根) {
    定义 根目录 = 模块图_项目根目录(项目根)
    // 优先级1: 项目合同中的显式入口模块
    如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 3) {
        定义 _合同入口 = _模块_项目合同[2]
        如果 (_合同入口 != 空 且 字节长度(_合同入口) > 0) {
            定义 _合同路径 = 模块图_规范路径(字符串拼接(根目录, 字符串拼接("/", _合同入口)))
            如果 (字典有(模块索引, _合同路径)) {
                定义 _入口位2 = 字典取(模块索引, _合同路径)
                模块图_打印详细(字符串拼接("[入口] 项目合同指定: ", _合同路径))
                返回 模块表[_入口位2].名称
            }
            模块图_打印详细(字符串拼接("[入口] 项目合同指定的入口未找到: ", _合同入口))
        }
    }
    // 优先级2: Nova.nova 启发式(兼容旧项目)
    定义 候选 = 模块图_规范路径(字符串拼接(根目录, "/Nova.nova"))
    如果 (字典有(模块索引, 候选)) { 定义 _入口位 = 字典取(模块索引, 候选)  返回 模块表[_入口位].名称 }
    定义 可变 mi = 0
    当 (mi < 计数(模块表)) {
        定义 名 = 模块表[mi].名称
        如果 (字符串相等(名, "Nova.nova") 或 以结尾(名, "/Nova.nova")) { 返回 名 }
        mi = mi + 1
    }
    // 优先级3 (bug-fix 2026-04-17): 无Nova.nova时用实际编译的模块作为入口
    // 支持单文件编译场景 (如 nova hello.nova --compile -o hello_out)
    如果 (计数(模块表) > 0) {
        定义 首模块 = 模块表[0].名称
        模块图_打印详细(字符串拼接("[入口] 回退到编译模块表首项: ", 首模块))
        返回 首模块
    }
    返回 候选
}

函数 模块_添加依赖(模块名, 依赖名) {
    如果 (字典有(模块索引, 模块名)) {
        定义 位置 = 字典取(模块索引, 模块名)
        定义 可变 信息 = 模块表[位置]
        如果 (!是列表(信息.依赖列表)) { 信息.依赖列表 = [] }
        定义 可变 已有 = 假
        定义 可变 i = 0
        定义 _dep数 = 计数(信息.依赖列表)
        当 (i < _dep数) {
            如果 (字符串相等(信息.依赖列表[i], 依赖名)) {
                已有 = 真
                i = _dep数
            }
            i = i + 1
        }
        如果 (!已有) {
            追加(信息.依赖列表, 依赖名)
            模块_写回信息(位置, 信息)
        }
    }
}

函数 模块_添加导出(模块名, 符号名) {
    如果 (字典有(模块索引, 模块名)) {
        定义 位置 = 字典取(模块索引, 模块名)
        定义 可变 信息 = 模块表[位置]
        追加(信息.导出符号, 符号名)
        模块_写回信息(位置, 信息)
    }
}

函数 模块_统计依赖() {
    定义 可变 总边数 = 0
    定义 可变 有依赖模块数 = 0
    定义 可变 最大依赖数 = 0
    定义 可变 最大依赖模块 = ""
    定义 可变 i = 0
    当 (i < 计数(模块表)) {
        定义 依赖列表 = 模块表[i].依赖列表
        如果 (!是列表(依赖列表)) { 依赖列表 = [] }
        定义 依赖数 = 计数(依赖列表)
        总边数 = 总边数 + 依赖数
        如果 (依赖数 > 0) {
            有依赖模块数 = 有依赖模块数 + 1
        }
        如果 (依赖数 > 最大依赖数) {
            最大依赖数 = 依赖数
            最大依赖模块 = 模块表[i].名称
        }
        i = i + 1
    }
    返回 [总边数, 有依赖模块数, 最大依赖数, 最大依赖模块]
}

// §3 拓扑排序(编译顺序计算)

函数 模块_拓扑排序(_扩1) {
    // Kahn算法 — 反向邻接表加速版, 复杂度 O(V + E)
    // 原版: 每次出队扫描全部V个模块找依赖者 → O(V²·E)
    // 优化: 反向邻接表(被依赖→依赖者列表) + 队头索引 + 批量排序追加
    定义 模块数 = 计数(模块表)
    定义 可变 入度 = 字典()
    定义 可变 被依赖者 = 字典()
    定义 可变 i = 0
    当 (i < 模块数) {
        定义 名 = 模块表[i].名称
        字典设(入度,  名, 0)
        i = i + 1
    }
    // 计算入度 + 构建反向邻接表
    i = 0
    当 (i < 模块数) {
        定义 当前名 = 模块表[i].名称
        定义 依赖列表 = 模块表[i].依赖列表
        如果 (是列表(依赖列表) == 假) { 依赖列表 = [] }
        定义 可变 j = 0
        当 (j < 计数(依赖列表)) {
            定义 依赖 = 依赖列表[j]
            如果 (字典有(入度, 依赖)) {
                字典设(入度, 当前名, 字典取(入度, 当前名) + 1)
                // 反向: 当前名 依赖 依赖 → 将当前名加入"依赖"的被依赖者列表
                定义 反列 = 字典取(被依赖者, 依赖)
                如果 (反列 == 空) { 反列 = []  字典设(被依赖者, 依赖, 反列) }
                追加(反列, 当前名)
            }
            j = j + 1
        }
        i = i + 1
    }
    // BFS: 队头索引(避免O(V)数组移位) + 批量排序追加(避免O(V²logV)整队排序)
    模块图_清空列表(编译顺序)
    定义 可变 队列 = []
    i = 0
    当 (i < 模块数) {
        如果 (字典取(入度, 模块表[i].名称) == 0) {
            追加(队列, 模块表[i].名称)
        }
        i = i + 1
    }
    排序(队列, 0)
    定义 可变 队头 = 0
    当 (队头 < 计数(队列)) {
        定义 当前 = 队列[队头]
        队头 = 队头 + 1
        追加(编译顺序, 当前)
        // 通过反向邻接表 O(出度) 直接定位依赖当前模块的所有模块
        定义 依赖者列表 = 字典取(被依赖者, 当前)
        如果 (依赖者列表 != 空 且 是列表(依赖者列表)) {
            定义 可变 新零度 = []
            定义 可变 k = 0
            当 (k < 计数(依赖者列表)) {
                定义 依赖者 = 依赖者列表[k]
                字典设(入度, 依赖者, 字典取(入度, 依赖者) - 1)
                如果 (字典取(入度, 依赖者) == 0) {
                    追加(新零度, 依赖者)
                }
                k = k + 1
            }
            // 批量排序后追加, 保持确定性编译顺序
            如果 (计数(新零度) > 0) {
                排序(新零度, 0)
                定义 可变 ni = 0
                当 (ni < 计数(新零度)) {
                    追加(队列, 新零度[ni])
                    ni = ni + 1
                }
            }
        }
    }
    // 循环依赖处理: 追加环中模块到编译顺序 (保证全覆盖)
    如果 (计数(编译顺序) < 模块数) {
        定义 可变 环数 = 模块数 - 计数(编译顺序)
        模块图_打印详细(字符串拼接("[拓扑] 检测到循环依赖, 环中模块=", 转字符串(环数)))
        定义 可变 _环模块 = []
        定义 可变 ci = 0
        当 (ci < 模块数) {
            如果 (字典取(入度, 模块表[ci].名称) > 0) {
                追加(_环模块, 模块表[ci].名称)
            }
            ci = ci + 1
        }
        排序(_环模块, 0)
        ci = 0
        当 (ci < 计数(_环模块)) {
            追加(编译顺序, _环模块[ci])
            ci = ci + 1
        }
    }
    返回 编译顺序
}

// §4 增量编译(只编变化的)

函数 模块_计算哈希(源码) {
    // FNV-1a 64位哈希 — 超大仓库低碰撞
    // FNV偏移基 = 14695981039346656037 (64位)
    // FNV质数  = 1099511628211
    // 原 编码(子串(源码,i,1)) 每字符分配新字符串→O(n²); 改用 字节取→O(n)
    定义 可变 哈希值 = 14695981039346656037
    定义 长度 = 字节长度(源码)
    定义 可变 i = 0
    当 (i < 长度) {
        哈希值 = (哈希值 ^ 字节取(源码, i))
        哈希值 = 哈希值 * 1099511628211
        哈希值 = 哈希值 & 0x7FFFFFFFFFFFFFFF
        i = i + 1
    }
    返回 哈希值
}

// 记忆化集合: 避免指数级重复检查依赖链
定义 可变 _重编状态 = [字典(), 字典()]    // [模块名 → 真/假, 检测递归环]

函数 模块_重编检查重置() {
    _重编状态[0] = 字典()
    _重编状态[1] = 字典()
}

函数 模块_依赖是否变更(依赖列表) {
    定义 可变 j = 0
    当 (j < 计数(依赖列表)) {
        如果 (模块_需要重编(依赖列表[j])) { 返回 真 }
        j = j + 1
    }
    返回 假
}

函数 模块_需要重编(模块名) {
    定义 已缓存 = 字典取(_重编状态[0], 模块名)
    如果 (已缓存 != 空) { 返回 已缓存 }
    如果 (字典取(_重编状态[1], 模块名) != 空) { 返回 假 }
    字典设(_重编状态[1], 模块名, 真)
    如果 (!字典有(模块索引, 模块名)) {
        字典设(_重编状态[0], 模块名, 真)
        返回 真
    }
    定义 位置 = 字典取(模块索引, 模块名)
    定义 信息 = 模块表[位置]
    如果 (信息.目标码 == 空 或 信息.编译状态 != 2) {
        字典设(_重编状态[0], 模块名, 真)
        返回 真
    }
    定义 源码 = 读文件(信息.路径)
    如果 (源码 == 空) {
        字典设(_重编状态[0], 模块名, 真)
        返回 真
    }
    如果 (当前哈希 != 信息.哈希 或 信息.哈希 == 0) {
        字典设(_重编状态[0], 模块名, 真)
        返回 真
    }
    定义 依赖组 = 信息.依赖列表
    如果 (依赖组 != 空 且 是列表(依赖组)) {
        如果 (模块_依赖是否变更(依赖组)) {
            字典设(_重编状态[0], 模块名, 真)
            返回 真
        }
    }
    字典设(_重编状态[0], 模块名, 假)
    返回 假
}

函数 _模块_增量编译_处理单个(名, 统计) {
    模块图_阶段标记("增量循环/模块前", 名)
    定义 需要重编 = 模块_需要重编(名)
    如果 (需要重编) {
        模块图_阶段标记("增量循环/重编前", 名)
        定义 编译成功 = 模块_编译单个(名)
        如果 (编译成功) {
            模块图_阶段标记("增量循环/重编成功", 名)
            统计[0] = 统计[0] + 1
        } 否则 {
            模块图_阶段标记("增量循环/重编失败", 名)
            统计[2] = 统计[2] + 1
            模块_回滚(名)
        }
    } 否则 {
        模块图_阶段标记("增量循环/跳过", 名)
        统计[1] = 统计[1] + 1
    }
    模块图_阶段标记("增量循环/模块后", 名)
}

函数 模块_增量编译() {
    模块_重编检查重置()
    模块_拓扑排序(0)
    定义 顺序 = 编译顺序
    定义 可变 统计 = [0, 0, 0]
    // 迭代遍历(原递归版对442+模块有栈溢出风险, Stage1无尾调用优化)
    定义 可变 i = 0
    当 (i < 计数(顺序)) {
        _模块_增量编译_处理单个(顺序[i], 统计)
        i = i + 1
    }
    模块图_打印详细(字符串拼接("增量编译: ", 字符串拼接(转字符串(统计[0]), 字符串拼接("编译 ", 字符串拼接(转字符串(统计[1]), 字符串拼接("跳过 ", 字符串拼接(转字符串(统计[2]), "failed")))))))
    返回 统计[2] == 0
}

// §5 单模块编译 (真正产出目标码)

函数 模块_处理_节_定义(预扫句) {
    定义 预扫名 = 预扫句[1]
    如果 (字典取(全局变量表, 预扫名) == 空) {
        字典设(全局变量表, 预扫名, 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
}

函数 模块_处理_2(_vm) {
    // 裸机/内核目标直接进入不可返回的停机循环。
    发射(0xFA)
    发射(0xF4)
    发射组([0xEB, 0xFC])
}

// 源码预验证 (括号匹配 + 基础结构检查)

函数 模块_检查括号匹配(源码, 文件名) {
    定义 可变 深度 = 0
    定义 可变 行号 = 1
    定义 可变 最后开括行 = 0
    定义 可变 i = 0
    定义 长度 = 字节长度(源码)
    当 (i < 长度) {
        定义 字节 = 字节取(源码, i)
        如果 (字节 == 字符_换行) { 行号 = 行号 + 1  i = i + 1  继续 }
        // 跳过行注释 //
        如果 (字节 == 字符_斜杠 且 i + 1 < 长度 且 字节取(源码, i + 1) == 字符_斜杠) {
            当 (i < 长度 且 字节取(源码, i) != 字符_换行) { i = i + 1 }
            继续
        }
        // 跳过字符串 "..." 和 '...'
        如果 (字节 == 标记_余 或 字节 == 39) {
            定义 引号 = 字节
            i = i + 1
            定义 可变 _扫串 = 真
            当 (i < 长度 且 _扫串) {
                定义 sc = 字节取(源码, i)
                如果 (sc == 字符_换行) { 行号 = 行号 + 1 }
                如果 (sc == 标记_左花) { i = i + 2  继续 }
                如果 (sc == 引号) { i = i + 1  _扫串 = 假  继续 }
                i = i + 1
            }
            继续
        }
        如果 (字节 == 标记_中断) { 深度 = 深度 + 1  最后开括行 = 行号 }
        如果 (字节 == 标记_真) { 深度 = 深度 - 1 }
        如果 (深度 < 0) {
            _进度_记录错误("解析", 文件名, 行号, "多余的 '}'")
            返回 假
        }
        i = i + 1
    }
    如果 (深度 > 0) {
        _进度_记录错误("解析", 文件名, 最后开括行, 字符串拼接("未闭合的 '{' (缺少 ", 字符串拼接(转字符串(深度), " 个 '}')")))
        返回 假
    }
    返回 真
}

函数 模块_检查主程序存在(函数列, 文件名) {
    定义 可变 i = 0
    当 (i < 计数(函数列)) {
        如果 (是列表(函数列[i]) 且 计数(函数列[i]) >= 2) {
            如果 (字符串相等(函数列[i][1], "主程序")) { 返回 真 }
        }
        i = i + 1
    }
    返回 假
}

函数 模块_编译单个(模块名) {
    定义 可变 _ei = 0
    定义 可变 _优fi = 0
    定义 可变 预函i = 0
    定义 可变 预扫i = 0
    如果 (!字典有(模块索引, 模块名)) { 返回 假 }
    如果 (模块图详细模式[0]) { 打印文本("  [单模块] " + 模块名 + "\n") }
    定义 位置 = 字典取(模块索引, 模块名)
    定义 可变 信息 = 模块表[位置]
    // 标记编译中
    信息.编译状态 = 1
    模块_写回信息(位置, 信息)
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[编译开始] ", 模块名)) }
    模块图_阶段标记("保存状态", 模块名)
    // 每个模块编译前硬重置前端状态，避免模块图长链自举时状态串扰。
    词法引擎_全局重置()
    语法引擎_全局重置()
    行号追踪_全局重置()
    // 读源码
    如果 (模块图详细模式[0]) { 打印文本(字符串拼接("  [阶段] 读源码 ", 模块名)) }
    定义 源码 = 读文件(信息.路径)
    如果 (源码 == 空) {
        打印文本(字符串拼接("读文件失败: ", 信息.路径))
        信息.编译状态 = 3
        模块_写回信息(位置, 信息)
        返回 假
    }
    // 保存旧版本(用于回滚)
    定义 旧版本号 = 信息.版本号
    模块图_阶段标记("保存状态完成", 模块名)

    // 阶段0.5: 源码预验证 (括号匹配)
    如果 (!模块_检查括号匹配(源码, 信息.路径)) {
        信息.编译状态 = 3
        模块_写回信息(位置, 信息)
        返回 假
    }

    // AST节点类型标签在模块顶部已完成初始化, 这里不再重复赋值

    // 阶段1: 词法分析
    如果 (模块图详细模式[0]) { 打印文本(字符串拼接("  [阶段] 词法 ", 模块名)) }
    位置_注册文件(信息.路径)
    模块图_清空列表(词行号)
    定义 词表 = 前端_词法分析(源码)
    如果 (词表 == 空 或 计数(词表) == 0) {
        打印文本(字符串拼接("词法失败: ", 模块名))
        信息.编译状态 = 3
        模块_写回信息(位置, 信息)
        返回 假
    }

    // 阶段2: 语法分析
    如果 (模块图详细模式[0]) { 打印文本(字符串拼接("  [阶段] 语法 ", 模块名)) }
    模块图_清空列表(匿名函数列)
    定义 程序 = 前端_解析_程序(词表)
    定义 _解析错误数 = 语法状态[5]
    如果 (是列表(程序) == 假 或 计数(程序) < 2) {
        打印文本(字符串拼接("错误: ", 字符串拼接(信息.路径, " 语法分析失败")))
        信息.编译状态 = 3
        模块_写回信息(位置, 信息)
        返回 假
    }
    定义 函数列 = 程序[0]
    定义 主体 = 程序[1]
    // 合并匿名函数
    定义 可变 li = 0
    当 (li < 计数(匿名函数列)) {
        追加(函数列, 匿名函数列[li])
        li = li + 1
    }
    如果 (_解析错误数 > 0) {
        打印文本(字符串拼接("错误: ", 字符串拼接(信息.路径, 字符串拼接(" 语法错误 (", 字符串拼接(转字符串(_解析错误数), "个)")))))
        信息.编译状态 = 3
        模块_写回信息(位置, 信息)
        返回 假
    }
    如果 (计数(函数列) == 0 且 计数(主体) == 0) {
        模块图_打印详细(字符串拼接("[跳过] ", 字符串拼接(信息.路径, " (无函数和语句)")))
        信息.编译状态 = 2
        信息.目标码 = 空
        信息.目标码大小 = 0
        模块_写回信息(位置, 信息)
        返回 真
    }

    // 阶段2.5: 语义分析 (P2恢复 + 5.2分级扩展)
    // 语义严格度按profile分级:
    //   analysis-host → 严格(所有警告视为错误)
    //   kernel-*      → 安全严格(可变/借用必须通过,AI约束宽松)
    //   linux-user    → 中等(报告警告,不阻塞)
    //   default       → 宽松(仅报告)
    定义 可变 _语义错误数 = 0
    定义 可变 _语义严格度 = 0
    定义 可变 _当前profile = ""
    如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 5) {
        _当前profile = _模块_项目合同[4]
        如果 (字符串相等(_当前profile, "analysis-host")) { _语义严格度 = 2 }
        如果 (字符串相等(_当前profile, "kernel-qemu") 或 字符串相等(_当前profile, "kernel-physical")) { _语义严格度 = 0 }
        如果 (字符串相等(_当前profile, "linux-user")) { _语义严格度 = 0 }
    }
    定义 _语义结果 = 语义_最小预检查(函数列, 主体)
    定义 _语义诊断 = 语义预检_生成诊断收集器(信息.路径, _语义结果)
    定义 _语义警告 = 诊断收集器_警告数(_语义诊断)
    _语义错误数 = 诊断收集器_错误数(_语义诊断)
    _进度_警告 = _进度_警告 + _语义警告
    _进度_语义错误 = _进度_语义错误 + _语义错误数
    如果 (_语义错误数 > 0 或 _语义警告 > 0) {
        诊断收集器_按行排序(_语义诊断)
        诊断_打印全部(_语义诊断)
    }
    // 5.1.1: 作用域诊断统计
    定义 _语义_作用域栈 = _语义结果[1]
    定义 _作用域诊断 = 作用域_诊断(_语义_作用域栈)
    如果 (模块图详细模式[0] 且 _作用域诊断 != 空) {
        打印文本(字符串拼接("  [作用域] ", 字符串拼接(模块名, 字符串拼接(" 总变量=", 字符串拼接(转字符串(_作用域诊断[1]), 字符串拼接(" 未使用=", 字符串拼接(转字符串(_作用域诊断[2]), 字符串拼接(" 最大深度=", 转字符串(_作用域诊断[3])))))))))
    }

    // 5.2: 借用/生命周期检查纳入主链
    定义 可变 _借用违规数 = 0
    定义 可变 _生命周期违规 = 0
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 借用进入\n") }
    借用_进入作用域()
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 约束检查\n") }
    约束_检查一致性()
    _生命周期违规 = _生命周期_违规数
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 借用退出\n") }
    借用_退出作用域()
    _借用违规数 = _生命周期违规

    // 5.2: AI类型约束检查(形状/精度/设备/记忆域)
    定义 可变 _AI约束违规 = 0

    // 严格度执行: analysis-host时所有警告升级为错误
    如果 (_语义严格度 == 2) {
        _语义错误数 = _语义错误数 + _语义警告 + _借用违规数 + _AI约束违规
    }
    如果 (_语义严格度 == 1) {
        _语义错误数 = _语义错误数 + _借用违规数
    }

    // 阶段2.8: 优化管线 (按profile等级调度)
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 优化准备\n") }
    // 从profile设置优化等级: analysis-host→O3(激进), kernel→O2(完全), linux-user→O2, default→O2
    如果 (字符串相等(_当前profile, "analysis-host")) { 设置优化等级(3) }
    否则 如果 (字符串相等(_当前profile, "kernel-qemu") 或 字符串相等(_当前profile, "kernel-physical")) { 设置优化等级(2) }
    否则 { 设置优化等级(2) }
    定义 _优化报告 = [0, 0, 0, 0]
    定义 可变 _尾调数 = 0
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 尾调扫描\n") }
    当 (_优fi < 计数(函数列)) {
        如果 (是列表(函数列[_优fi]) 且 计数(函数列[_优fi]) >= 4) {
            定义 _优函体 = 函数列[_优fi][3]
            如果 (是列表(_优函体) 且 计数(_优函体) > 0) {
                定义 _尾类型 = 尾调用优_分析尾部(_优函体, 函数列[_优fi][1], 空)
                如果 (_尾类型 > 0) { _尾调数 = _尾调数 + 1 }
            }
        }
        _优fi = _优fi + 1
    }
    // P3: AI算子路径感知优化——为每个函数推断AI标签并记录
    定义 可变 _ai路径函数数 = 0
    定义 可变 _裸机禁内联数 = 0
    定义 可变 _pfi = 0
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] AI路径扫描\n") }
    当 (_pfi < 计数(函数列)) {
        如果 (是列表(函数列[_pfi]) 且 计数(函数列[_pfi]) >= 4) {
            定义 _pf名 = 函数列[_pfi][1]
            定义 _算子标签 = IR标签_从函数名推断(_pf名)
            定义 _模态标签 = IR标签_从函数名推断模态(_pf名)
            IR标签表_设置(_pfi,  _算子标签,  _模态标签, 0, 0)
            如果 (_算子标签 != IR标签_普通) {
                _ai路径函数数 = _ai路径函数数 + 1
                管线_记录AI节点()
            }
            如果 (!管线_函数可内联(_pf名)) {
                _裸机禁内联数 = _裸机禁内联数 + 1
                管线_记录裸机禁内联()
            }
        }
        _pfi = _pfi + 1
    }
    管线_记录运行()

    // 阶段2.9: M7/M11 效果系统+能力系统 真实违规检测+阻塞
    // 默认profile白名单已在编译循环前一次性初始化
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 效果能力\n") }

    // 聚合模块效果签名
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 效果聚合\n") }
    定义 _模块效果 = 效果_模块聚合(模块名, 函数列)

    // 推断并授权模块能力
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 能力推断\n") }
    定义 _模块能力推断 = 能力_从模块名推断(模块名)
    定义 可变 _efi = 0
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 能力授权\n") }
    当 (_efi < 计数(_模块能力推断)) {
        能力_授权(模块名, _模块能力推断[_efi], 1, 假)
        _efi = _efi + 1
    }

    // 真实效果违规检测: 对每个有效果的函数检查profile是否允许
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 效果违规检查\n") }
    定义 可变 _效果违规总数 = 效果_批量检查违规(_当前profile, 函数列)

    // 真实能力违规检测: 检查模块效果所需能力是否被profile允许
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 能力违规检查\n") }
    定义 可变 _能力违规总数 = 能力_批量检查profile(_当前profile, 模块名, _模块效果)

    // 违规汇入语义错误(严格度>=1的profile下阻塞构建)
    如果 (_语义严格度 >= 1) {
        _语义错误数 = _语义错误数 + _效果违规总数 + _能力违规总数
    }

    // 效果+能力报告(详细模式或有违规时输出)
    如果 (计数(_模块效果) > 0 或 _效果违规总数 > 0 或 _能力违规总数 > 0) {
        如果 (模块图详细模式[0]) {
            定义 可变 _效果文本 = ""
            当 (_ei < 计数(_模块效果)) {
                如果 (_ei > 0) { _效果文本 = _效果文本 + "," }
                _效果文本 = _效果文本 + 效果名(_模块效果[_ei])
                _ei = _ei + 1
            }
            模块图_打印详细(字符串拼接("[效果] ", 字符串拼接(模块名, 字符串拼接(" 效果=[", 字符串拼接(_效果文本, 字符串拼接("] 效果违规=", 字符串拼接(转字符串(_效果违规总数), 字符串拼接(" 能力违规=", 转字符串(_能力违规总数)))))))))
        }
        // 有违规时输出详情(不受详细模式限制)
        如果 (_效果违规总数 > 0) { 效果_输出违规详情() }
        如果 (_能力违规总数 > 0) { 能力_输出违规详情() }
    }
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 效果能力收尾\n") }

    // 阶段2.95: 流水线权威分析链 (5.3接线)
    // 将真实AST注入编译流水线, 执行完整分析: CFG/数据流/别名/污点/形式化/约束域/IR降级
    定义 可变 _管线优化级 = 2
    如果 (字符串相等(_当前profile, "analysis-host")) { _管线优化级 = 3 }
    定义 可变 _模块标签列 = 空
    如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 7) {
        // 从项目合同子系统中推断模块标签
        定义 _子列 = _模块_项目合同[6]
        如果 (是列表(_子列)) {
            定义 可变 _tsi = 0
            当 (_tsi < 计数(_子列)) {
                如果 (是列表(_子列[_tsi]) 且 计数(_子列[_tsi]) >= 2) {
                    如果 (字符串包含(模块名, _子列[_tsi][0])) {
                        _模块标签列 = ["内核态"]
                    }
                }
                _tsi = _tsi + 1
            }
        }
    }
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 流水线开始\n") }
    定义 _管线结果 = 流水线_执行_模块级(模块名, 信息.路径, _管线优化级, _当前profile, _模块标签列, 函数列, 主体)
    如果 (模块图详细模式[0]) { 打印文本("  [阶段] 流水线完成\n") }
    定义 _管线报告 = _管线结果[1]
    如果 (模块图详细模式[0]) {
        打印文本(字符串拼接("  [流水线] ", 字符串拼接(模块名, 字符串拼接(" 阶段数=", 转字符串(计数(_管线报告))))))
    }

    // M7: 逃逸门控 — 流水线执行后检查逃逸阈值
    如果 (!流水线_逃逸门控通过()) {
        _语义错误数 = _语义错误数 + 1
        打印文本(字符串拼接("  [逃逸阻塞] ", 字符串拼接(模块名, 字符串拼接(" 逃逸数=", 字符串拼接(转字符串(_语义_动态逃逸数), 字符串拼接(" 阈值=", 转字符串(_语义_逃逸阈值)))))))
    }

    // 安全门控: 严格profile下违规阻塞代码生成
    如果 (_语义错误数 > 0 且 _语义严格度 >= 1) {
        打印文本(字符串拼接("  [阻塞] ", 字符串拼接(模块名, 字符串拼接(" profile=", 字符串拼接(_当前profile, 字符串拼接(" 语义错误=", 字符串拼接(转字符串(_语义错误数), " → 跳过代码生成")))))))
        信息.目标码 = 空
        信息.目标码大小 = 0
        模块_写回信息(位置, 信息)
        返回 真
    }

    如果 (模块图详细模式[0]) { 打印文本(字符串拼接("  [阶段] 代码生成 ", 模块名)) }
    // 阶段3: 代码生成 (真正产出机器码)
    模块图_阶段标记("代码生成前", 模块名)
    // 保存全局代码生成状态
    定义 保存_代码生成状态 = 模块_保存代码生成状态()
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[代码生成前] ", 模块名)) }

    模块_同步目标格式()
    // 重置代码生成器为此模块 (清空复用, 不重建, 避免堆耗尽)
    模块图_阶段标记("重置代码生成状态", 模块名)
    模块_重置模块代码生成状态()
    模块图_阶段标记("运行时注册", 模块名)
    发射_权威运行时(函数表)
    // 丢弃 runtime 字节, 清空函数表(仅含runtime条目)以强制编译器生成call fixup
    代码 = []
    代码位 = 0
    修正表 = []
    函数表 = 字典()
    发射(0x90)
    编译_设置当前模块名(模块名)
    编译_设置源文件名(信息.路径)
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[代码生成中] ", 模块名)) }

    // 闭包检测
    模块图_阶段标记("闭包检测", 模块名)

    模块图_阶段标记("全局变量预扫", 模块名)
    当 (预扫i < 计数(主体)) {
        定义 预扫句 = 主体[预扫i]
        如果 (是列表(预扫句) == 假 或 计数(预扫句) < 2) {
            预扫i = 预扫i + 1
            继续
        }
        如果 (预扫句[0] == 节_定义) {
            模块_处理_节_定义(预扫句)
        }
        预扫i = 预扫i + 1
    }
    模块图_阶段标记("函数预注册", 模块名)
    如果 (字典取(全局变量表, "__错误_标志") == 空) {
        字典设(全局变量表, "__错误_标志", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_值") == 空) {
        字典设(全局变量表, "__错误_值", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_基指针") == 空) {
        字典设(全局变量表, "__错误_基指针", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_栈指针") == 空) {
        字典设(全局变量表, "__错误_栈指针", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_跳转") == 空) {
        字典设(全局变量表, "__错误_跳转", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[函数预注册] ", 模块名)) }
    当 (预函i < 计数(函数列)) {
        如果 (是列表(函数列[预函i]) 且 计数(函数列[预函i]) >= 2) {
            定义 预函名 = 函数列[预函i][1]
            如果 (字典取(函数表, 预函名) == 空) {
                字典设(函数表, 预函名, 0 - 1)
            }
        }
        预函i = 预函i + 1
    }
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[函数预注册完成] ", 模块名)) }

    // 闭包分析: 扫描lambda自由变量
    闭包分析_函数列(函数列)
    // 编译全部函数到代码缓冲区 (两遍: 先普通函数, 后lambda)
    // parser将lambda添加在外层函数之前, 两遍确保外层先编译
    // 这样_闭包_尝试捕获在外层函数编译时填充闭包表, lambda编译时可读取
    模块图_阶段标记("函数编译循环", 模块名)
    定义 可变 编译失败数 = 0
    定义 _编译前代码位 = 代码位
    // Pass 0: 跨函数类型预扫描 (单遍)
    //   (a) 调用点 → 函数参数类型表 (识别字面量类型, 或已被其他模块标记的变量)
    //   (b) 函数体内 返回 语句 → 函数返回类型表 (识别直接返回字面量/已标记变量)
    //   避免预标记局部变量: 那是 Pass 1 每个函数自己的 Phase 1 职责
    定义 可变 _pass0_i = 0
    当 (_pass0_i < 计数(函数列)) {
        如果 (是列表(函数列[_pass0_i]) 且 计数(函数列[_pass0_i]) >= 4) {
            定义 _fn名_p0 = 函数列[_pass0_i][1]
            定义 _fn体_p0 = 函数列[_pass0_i][3]
            _调用点扫描_填参数类型(_fn体_p0)
            _返回类型扫描_填函数返回类型(_fn名_p0, _fn体_p0)
        }
        _pass0_i = _pass0_i + 1
    }
    定义 可变 _pass0_bi = 0
    当 (_pass0_bi < 计数(主体)) {
        _调用点扫描_填参数类型(主体[_pass0_bi])
        _pass0_bi = _pass0_bi + 1
    }
    // Pass 1: 编译普通函数 (名称不以__开头)
    定义 可变 fi = 0
    当 (fi < 计数(函数列)) {
        如果 (是列表(函数列[fi]) == 假 或 计数(函数列[fi]) < 4) {
            fi = fi + 1
            继续
        }
        定义 _p1名 = 函数列[fi][1]
        如果 (字节长度(_p1名) >= 10 且 字节取(_p1名, 0) == 字符_下划线 且 字节取(_p1名, 1) == 字符_下划线) {
            fi = fi + 1
            继续
        }
        如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[编译函数] ", _p1名)) }
        定义 函数前位 = 代码位
        编译_函数(函数列[fi], 空)
        如果 (代码位 == 函数前位 且 计数(函数列[fi]) >= 4) {
            编译失败数 = 编译失败数 + 1
        }
        fi = fi + 1
    }
    // Pass 2: 编译lambda函数 (名称以__开头, 闭包表已由Pass 1填充)
    fi = 0
    当 (fi < 计数(函数列)) {
        如果 (是列表(函数列[fi]) == 假 或 计数(函数列[fi]) < 4) {
            fi = fi + 1
            继续
        }
        定义 _p2名 = 函数列[fi][1]
        如果 (字节长度(_p2名) < 10 或 字节取(_p2名, 0) != 字符_下划线 或 字节取(_p2名, 1) != 字符_下划线) {
            fi = fi + 1
            继续
        }
        如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[编译lambda] ", _p2名)) }
        定义 函数前位2 = 代码位
        定义 _fn闭包 = 字典取(闭包表, _p2名)
        编译_函数(函数列[fi], _fn闭包)
        如果 (代码位 == 函数前位2 且 计数(函数列[fi]) >= 4) {
            编译失败数 = 编译失败数 + 1
        }
        fi = fi + 1
    }

    // 编译主体语句
    模块图_阶段标记("主体编译", 模块名)
    定义 入口 = 代码位
    当前函数名 = "__主程序__"
    变量表 = 字典()
    变量数 = 0
    主体模式 = 1
    发射_序言()
    // heap_init和全局区alloc已移至__初始化全局__,此处不再重复
    如果 (计数(主体) > 0) {
        定义 可变 si = 0
        当 (si < 计数(主体)) {
            编译_语句(主体[si])
            si = si + 1
        }
    }
    如果 (模块图编译器_目标ELF == 2) {
        模块_处理_2(空)
    }
    发射_尾声()
    发射(0xCC)
    定义 对齐帧 = (变量数 + 8) * 8
    // 由于序言额外push了r15/r14/rbp共24字节, 为保持call对齐, 需让分配N满足 (24+N)%16==0
    定义 对齐帧2 = ((对齐帧 + 8 + 15) / 16) * 16 - 8
    如果 (对齐帧2 < 4096) { 对齐帧2 = 4096 }
    内存写32(代码, 帧大小位, 对齐帧2)
    信息.入口偏移 = 入口
    如果 (编译失败数 > 0) {
        打印文本(字符串拼接("代码生成警告: ", 字符串拼接(模块名, 字符串拼接(" (", 字符串拼接(转字符串(编译失败数), "个函数未产出代码)")))))
    }

    // 阶段3.5: 窥孔优化 (原始字节级, 代码生成后就地替换)
    如果 (_编译前代码位 < 代码位) {
        定义 _窥孔数 = 窥孔_后处理_字节(_编译前代码位, 代码位)
        如果 (_窥孔数 > 0) {
            模块图_打印详细(字符串拼接("[窥孔] ", 字符串拼接(模块名, 字符串拼接(" 优化=", 转字符串(_窥孔数)))))
        }
    }

    // 嵌入字符串数据到代码段尾部
    定义 可变 _嵌入字串i = 0
    当 (_嵌入字串i < 计数(字串表)) {
        追加(字串偏移, 代码位)
        定义 _嵌入字串 = 字串表[_嵌入字串i]
        定义 可变 _嵌入字节i = 0
        当 (_嵌入字节i < 字节长度(_嵌入字串)) {
            发射(字节取(_嵌入字串, _嵌入字节i))
            _嵌入字节i = _嵌入字节i + 1
        }
        发射(0)
        _嵌入字串i = _嵌入字串i + 1
    }

    // 就地解决 str 修正, 非str修正留给链接阶段
    定义 可变 _未决修正 = []
    定义 可变 _修正i = 0
    当 (_修正i < 计数(修正表)) {
        定义 _修类 = 修正表_取类型(修正表, _修正i)
        定义 _修位 = 修正表_取位置(修正表, _修正i)
        定义 _修附 = 修正表_取附加(修正表, _修正i)
        定义 _修步长 = 修正表_项步长(修正表, _修正i)
        如果 (字符串相等(_修类, "str")) {
            定义 _str索引 = _修附
            如果 (是整数(_str索引) 且 _str索引 >= 0 且 _str索引 < 计数(字串偏移)) {
                定义 _字串位 = 字串偏移[_str索引]
                内存写32(代码, _修位, _字串位 - (_修位 + 4))
            } 否则 {
                修正表_追加现成(_未决修正, 修正表, _修正i)
            }
        } 否则 {
            修正表_追加现成(_未决修正, 修正表, _修正i)
        }
        _修正i = _修正i + _修步长
    }

    // 提取产出的机器码 (含字符串数据)
    定义 本模块代码大小 = 代码位
    模块图_打印详细(字符串拼接("[模块代码容器] ", 字符串拼接(模块名, 字符串拼接(" list=", 字符串拼接(转字符串(是列表(代码)), 字符串拼接(" size=", 转字符串(本模块代码大小)))))))
    如果 (本模块代码大小 > 0) {
        // 零拷贝: 直接转移代码列表引用 (恢复状态时会重设代码变量为旧引用)
        信息.目标码 = 代码
        信息.目标码大小 = 本模块代码大小
        模块图_打印详细(字符串拼接("[模块入口] ", 字符串拼接(模块名, 字符串拼接(" entry=", 字符串拼接(转字符串(信息.入口偏移), 字符串拼接(" size=", 字符串拼接(转字符串(信息.目标码大小), 字符串拼接(" ", 模块图_入口字节摘要(代码, 信息.入口偏移)))))))))
    } 否则 {
        信息.目标码 = 空
        信息.目标码大小 = 0
    }

    // 诊断: 计数filtering后的rt_globals (仅详细模式, 避免每模块无谓遍历)
    如果 (模块图详细模式[0]) {
        定义 可变 _后处理_注册 = 0
        定义 可变 _后处理_索引 = 0
        当 (_后处理_索引 < 计数(_未决修正)) {
            定义 _后处理_步长 = 修正表_项步长(_未决修正, _后处理_索引)
            如果 (字符串相等(修正表_取类型(_未决修正, _后处理_索引), "rt_globals")) { _后处理_注册 = _后处理_注册 + 1 }
            _后处理_索引 = _后处理_索引 + _后处理_步长
        }
        模块图_打印详细(字符串拼接("[修正表] ", 字符串拼接(模块名, 字符串拼接(" 未决=", 字符串拼接(转字符串(计数(_未决修正)), 字符串拼接(" rt_globals=", 转字符串(_后处理_注册)))))))
    }
    // 保存模块修正表和函数表 (链接时跨模块修正用)
    // 只保留非str修正 (str已在模块内就地解决)
    信息.修正表数据 = _未决修正
    信息.函数表数据 = 函数表
    字典设(_模块行号映射, 模块名, 编译_行号映射表())
    编译_重置行号映射()

    // 恢复全局代码生成状态
    模块图_阶段标记("恢复状态", 模块名)
    模块_恢复代码生成状态(保存_代码生成状态, 假)
    编译_设置当前模块名("")
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[代码生成后] ", 模块名)) }

    // 收集导出符号
    模块图_阶段标记("导出符号", 模块名)
    信息.导出符号 = []
    fi = 0
    当 (fi < 计数(函数列)) {
        如果 (是列表(函数列[fi]) 且 计数(函数列[fi]) >= 2) {
            追加(信息.导出符号, 函数列[fi][1])
        }
        fi = fi + 1
    }

    // 阶段4: 增量缓存 (持久化到磁盘)
    模块图_阶段标记("缓存保存", 模块名)
    模块图_阶段标记("缓存保存/哈希前", 模块名)
    定义 新哈希 = 模块_计算哈希(源码)
    模块图_阶段标记("缓存保存/哈希后", 模块名)
    信息.哈希 = 新哈希
    // 更新模块信息
    模块图_阶段标记("缓存保存/状态前", 模块名)
    信息.编译状态 = 2
    模块图_阶段标记("缓存保存/版本前", 模块名)
    信息.版本号 = 旧版本号 + 1
    模块图_阶段标记("缓存保存/版本后", 模块名)
    信息.上次编译时间 = 时间()
    模块_写回信息(位置, 信息)
    模块图_阶段标记("缓存保存/写回后", 模块名)
    如果 (模块图详细模式[0]) { 模块图_打印详细(字符串拼接("[编译完成] ", 模块名)) }
    如果 (模块图详细模式[0]) { 打印(".") }
    模块图_阶段标记("缓存保存/返回前", 模块名)
    返回 真
}

// §6 自动回滚(编译失败不崩溃)

函数 模块_回滚(模块名) {
    如果 (字典有(模块索引, 模块名)) {
        定义 位置 = 字典取(模块索引, 模块名)
        定义 可变 信息 = 模块表[位置]
        // 恢复到上一个成功版本: 尝试从缓存加载旧版目标码
        如果 (信息.版本号 > 0) {
            定义 缓存结果 = 缓存_加载(模块名)
            如果 (缓存结果 != 空) {
                信息.目标码 = 缓存结果
                信息.目标码大小 = 计数(缓存结果)
            }
            信息.编译状态 = 2  // 标记为已编译(使用旧版本)
            模块_写回信息(位置, 信息)
            打印文本(字符串拼接("回滚模块: ", 字符串拼接(模块名, 字符串拼接(" → 版本", 转字符串(信息.版本号)))))
        } 否则 {
            模块_写回信息(位置, 信息)
            打印文本(字符串拼接("回滚失败(无历史版本): ", 模块名))
        }
    }
}

// §7 热更新(不中断运行替换模块)

// 热更新跳板表: 所有跨模块调用通过此间接表
// 跳板表[函数名] = 当前有效的代码地址
// 热更新时只需原子替换跳板表条目, 无需修正所有call site
定义 可变 _跳板表 = 字典()    // 函数名 → 当前代码地址
定义 可变 _旧代码池 = []      // [旧目标码] 延迟释放队列

函数 跳板_注册(函数名, 代码地址) {
    字典设(_跳板表, 函数名, 代码地址)
}

函数 跳板_查询(函数名) {
    如果 (字典有(_跳板表, 函数名)) { 返回 字典取(_跳板表, 函数名) }
    返回 空
}

函数 模块_热更新(模块名) {
    定义 可变 替换数 = 0
    如果 (!字典有(模块索引, 模块名)) { 返回 假 }
    定义 位置 = 字典取(模块索引, 模块名)
    定义 旧信息目标码 = 模块表[位置].目标码

    // 1. 编译新版本
    定义 编译成功 = 模块_编译单个(模块名)
    如果 (!编译成功) {
        打印文本(字符串拼接("热更新失败, 保持旧版: ", 模块名))
        模块_回滚(模块名)
        返回 假
    }

    // 2. 原子替换跳板表: 新函数地址替换旧地址
    定义 新信息 = 模块表[位置]
    定义 新函数键 = 字典键(新信息.函数表数据)
    排序(新函数键, 0)
    定义 可变 ki = 0
    当 (ki < 计数(新函数键)) {
        定义 函数名 = 新函数键[ki]
        定义 新偏移 = 字典取(新信息.函数表数据, 函数名)
        跳板_注册(函数名, 新偏移)
        替换数 = 替换数 + 1
        ki = ki + 1
    }

    // 3. 旧代码放入延迟释放队列 (等安全点后释放)
    如果 (旧信息目标码 != 空) {
        追加(_旧代码池, 旧信息目标码)
    }

    // 4. 释放超过阈值的旧代码 (简单GC: 保留最近3个版本)
    当 (计数(_旧代码池) > 3) {
        删除(_旧代码池)
    }

    打印文本(字符串拼接("热更新成功: ", 字符串拼接(模块名, 字符串拼接(" v", 字符串拼接(转字符串(新信息.版本号), 字符串拼接(" (", 字符串拼接(转字符串(替换数), "个函数替换)")))))))
    返回 真
}

// §8 模块图链接(全部.o → 可执行文件)

函数 _map字节_追加整数(n, buf) {
    如果 (n == 0) { 追加(buf, 48)  返回 0 }
    定义 可变 临时 = []
    定义 可变 v = n
    当 (v > 0) {
        追加(临时, 48 + v % 10)
        v = v / 10
    }
    定义 可变 i = 计数(临时) - 1
    当 (i >= 0) {
        追加(buf, 临时[i])
        i = i - 1
    }
    返回 0
}

函数 模块_处理_格式_PE(vm) {
    定义 pe结果 = 构建PE(入口偏移, 代码位)
    写二进制(输出路径, pe结果[0], pe结果[1])
    模块图_打印详细(字符串拼接("PE写入成功: ", 输出路径))
}

函数 模块_分块写文件(路径, 数据, 大小, 清空) {
    定义 临时路径 = 字符串拼接(路径, ".__chunk")
    如果 (清空 != 0) {
        __系统命令(字符串拼接("rm -f '", 字符串拼接(路径, 字符串拼接("' '", 字符串拼接(临时路径, "'")))))
    } 否则 {
        __系统命令(字符串拼接("rm -f '", 字符串拼接(临时路径, "'")))
    }
    定义 可变 偏移 = 0
    当 (偏移 < 大小) {
        定义 可变 块长 = 65536
        如果 (大小 <= 4096) { 块长 = 16 }
        如果 (偏移 + 块长 > 大小) { 块长 = 大小 - 偏移 }
        定义 可变 块 = []
        定义 可变 bi = 0
        当 (bi < 块长) {
            追加(块, 数据[偏移 + bi])
            bi = bi + 1
        }
        写二进制(临时路径, 块, 块长)
        __系统命令(字符串拼接("cat '", 字符串拼接(临时路径, 字符串拼接("' >> '", 字符串拼接(路径, "'")))))
        偏移 = 偏移 + 块长
    }
    __系统命令(字符串拼接("rm -f '", 字符串拼接(临时路径, "'")))
    返回 1
}

函数 模块_追加16LE(buf, 值) {
    追加(buf, 值 & 255)
    追加(buf, (值 >> 8) & 255)
}

函数 模块_追加32LE(buf, 值) {
    追加(buf, 值 & 255)
    追加(buf, (值 >> 8) & 255)
    追加(buf, (值 >> 16) & 255)
    追加(buf, (值 >> 24) & 255)
}

函数 模块_追加64LE(buf, 值) {
    追加(buf, 值 & 255)
    追加(buf, (值 >> 8) & 255)
    追加(buf, (值 >> 16) & 255)
    追加(buf, (值 >> 24) & 255)
    追加(buf, (值 >> 32) & 255)
    追加(buf, (值 >> 40) & 255)
    追加(buf, (值 >> 48) & 255)
    追加(buf, (值 >> 56) & 255)
}

函数 模块_写LinuxELF(输出路径, 入口偏移, 代码大小) {
    定义 代码段文件偏移 = 0x1000
    定义 基址 = 0x400000
    定义 代码段虚址 = 基址 + 代码段文件偏移
    定义 对齐代码大小 = ((代码大小 + 0xFFF) / 0x1000) * 0x1000
    定义 数据段文件偏移 = 代码段文件偏移 + 对齐代码大小
    定义 数据段虚址 = 基址 + 数据段文件偏移
    定义 数据段文件大小 = 0x1000
    定义 数据段内存大小 = 数据段文件大小 + 0x10000000
    定义 填充大小 = 数据段文件偏移 - 代码段文件偏移 - 代码大小
    定义 入口虚址 = 代码段虚址 + 入口偏移
    定义 代码文件大小 = 代码段文件偏移 + 代码大小
    定义 可变 首页 = []

    追加(首页, 0x7F)
    追加(首页, 0x45)
    追加(首页, 0x4C)
    追加(首页, 0x46)
    追加(首页, 2)
    追加(首页, 1)
    追加(首页, 1)
    追加(首页, 0)
    定义 可变 _hzi = 0
    当 (_hzi < 8) {
        追加(首页, 0)
        _hzi = _hzi + 1
    }

    模块_追加16LE(首页, 2)
    模块_追加16LE(首页, 62)
    模块_追加32LE(首页, 1)
    模块_追加64LE(首页, 入口虚址)
    模块_追加64LE(首页, 64)
    模块_追加64LE(首页, 0)
    模块_追加32LE(首页, 0)
    模块_追加16LE(首页, 64)
    模块_追加16LE(首页, 56)
    模块_追加16LE(首页, 2)
    模块_追加16LE(首页, 0)
    模块_追加16LE(首页, 0)
    模块_追加16LE(首页, 0)

    模块_追加32LE(首页, 1)
    模块_追加32LE(首页, 7)
    模块_追加64LE(首页, 0)
    模块_追加64LE(首页, 基址)
    模块_追加64LE(首页, 基址)
    模块_追加64LE(首页, 代码文件大小)
    模块_追加64LE(首页, 代码文件大小)
    模块_追加64LE(首页, 0x1000)

    模块_追加32LE(首页, 1)
    模块_追加32LE(首页, 6)
    模块_追加64LE(首页, 数据段文件偏移)
    模块_追加64LE(首页, 数据段虚址)
    模块_追加64LE(首页, 数据段虚址)
    模块_追加64LE(首页, 数据段文件大小)
    模块_追加64LE(首页, 数据段内存大小)
    模块_追加64LE(首页, 0x1000)

    当 (计数(首页) < 代码段文件偏移) {
        追加(首页, 0)
    }

    打印文本(字符串拼接("[ELF-CHK] b0=", 转字符串(首页[0])))
    打印文本(字符串拼接("[ELF-PH64] ", 转字符串(首页[64])))
    打印文本(字符串拼接("[ELF-PH67] ", 转字符串(首页[67])))
    打印文本(字符串拼接("[ELF-PH68] ", 转字符串(首页[68])))
    打印文本(字符串拼接("[ELF-PH71] ", 转字符串(首页[71])))

    // 2026-04-17 根治: 一次性合并所有段为单一字节列表, 用单次写二进制调用消除cat>>追加OS依赖
    定义 可变 _elf整体 = 首页
    定义 可变 _ci = 0
    当 (_ci < 代码大小) { 追加(_elf整体, 代码[_ci]) _ci = _ci + 1 }
    定义 可变 _pi = 0
    当 (_pi < 填充大小) { 追加(_elf整体, 0) _pi = _pi + 1 }
    定义 可变 _di = 0
    当 (_di < 数据段文件大小) { 追加(_elf整体, 0) _di = _di + 1 }
    写二进制(输出路径, _elf整体, 计数(_elf整体))
    __系统命令(字符串拼接("chmod +x '", 字符串拼接(输出路径, "'")))
    返回 数据段文件偏移 + 数据段文件大小
}

函数 模块图_解析依赖路径(依赖路径, 当前目录) {
    // 剥离 ./ 前缀
    定义 可变 路径 = 依赖路径
    当 (以开头(路径, "./")) {
        路径 = 子串(路径, 2, 计数(路径) - 2)
    }
    // 处理 ../ : 每个 ../ 消耗当前目录一层
    定义 可变 目录 = 当前目录
    当 (以开头(路径, "../")) {
        路径 = 子串(路径, 3, 计数(路径) - 3)
        目录 = 模块图_父目录(目录)
    }
    // 组合: 目录 + / + 路径
    如果 (字节长度(目录) > 0) {
        返回 模块图_规范路径(字符串拼接(目录, 字符串拼接("/", 路径)))
    }
    返回 模块图_规范路径(路径)
}

// 全局变量传递fixup参数(避免>4参数的栈传递bug——Nova codegen正序push未修)
定义 可变 _fixup_基址 = 0
定义 可变 _fixup_fallback偏移 = 0
定义 可变 _fixup_当前模块名 = ""

函数 模块_应用call修正(修正表数据, 修索引, 全局函数表, 合并代码) {
    定义 目标函数 = 修正表_取附加(修正表数据, 修索引)
    定义 修位 = 修正表_取位置(修正表数据, 修索引)
    定义 全局目标 = 字典取(全局函数表, 目标函数)
    如果 (全局目标 == 空) {
        打印文本(字符串拼接("[UNRESOLVED] ", 目标函数))
        定义 修正绝对位2 = _fixup_基址 + 修位
        定义 重定位32_后备 = _fixup_fallback偏移 - (修正绝对位2 + 4)
        内存写32(合并代码, 修正绝对位2, 重定位32_后备)
        返回 0
    }
    定义 修正绝对位 = _fixup_基址 + 修位
    定义 重定位32 = 全局目标 - (修正绝对位 + 4)
    如果 (重定位32 < 0) {
        如果 (重定位32 > 0 - 200) {
            如果 (模块图详细模式[0]) { 打印文本(字符串拼接("[SELF-CALL-G] fn=", 字符串拼接(目标函数, 字符串拼接(" 重定位32=", 字符串拼接(转字符串(重定位32), 字符串拼接(" abspos=", 转字符串(修正绝对位))))))) }
        }
    }
    内存写32(合并代码, 修正绝对位, 重定位32)
    返回 1
}

// 在模块自身的目标码(小列表)上做fixup, 写入位置=模块内修位, rel32用全局绝对地址计算
函数 模块_应用call修正_本地(修正表数据, 修索引, 全局函数表, 目标码) {
    定义 目标函数 = 修正表_取附加(修正表数据, 修索引)
    定义 修位 = 修正表_取位置(修正表数据, 修索引)
    定义 全局目标 = 字典取(全局函数表, 目标函数)
    如果 (全局目标 == 空) {
        打印文本(字符串拼接("[UNR] ", 字符串拼接(_fixup_当前模块名, 字符串拼接(" -> ", 目标函数))))
        定义 修正绝对位 = _fixup_基址 + 修位
        定义 重定位32_后备 = _fixup_fallback偏移 - (修正绝对位 + 4)
        内存写32(目标码, 修位, 重定位32_后备)
        返回 0
    }
    定义 修正绝对位 = _fixup_基址 + 修位
    定义 重定位32 = 全局目标 - (修正绝对位 + 4)
    如果 (重定位32 < 0) {
        如果 (重定位32 > 0 - 200) {
            如果 (模块图详细模式[0]) { 打印文本(字符串拼接("[SELF-CALL] fn=", 字符串拼接(目标函数, 字符串拼接(" 重定位32=", 字符串拼接(转字符串(重定位32), 字符串拼接(" base=", 字符串拼接(转字符串(_fixup_基址), 字符串拼接(" pos=", 转字符串(修位))))))))) }
        }
    }
    内存写32(目标码, 修位, 重定位32)
    返回 1
}

函数 模块_链接全部(输出路径) {
    定义 可变 _mi = 0
    定义 可变 _si = 0
    定义 可变 ri = 0
    模块图_阶段标记("链接/开始", "<bootstrap>")
    模块_拓扑排序(0)
    定义 顺序 = 编译顺序
    模块_同步目标格式()
    定义 总全局变量数 = 全局变量数
    模块_初始化链接代码生成状态()
    发射_权威运行时(函数表)
    // fallback stub: exit(99) —— 未解析函数调用将显式崩溃而非静默返回0
    定义 _fallback偏移 = 代码位
    发射(191)  // mov edi, 99 (BF 63 00 00 00)
    发射(99)
    发射(0)
    发射(0)
    发射(0)
    发射(184)  // mov eax, 60 (B8 3C 00 00 00) = 系统调用_退出
    发射(60)
    发射(0)
    发射(0)
    发射(0)
    发射(15)   // syscall (0F 05)
    发射(5)
    定义 运行时前缀大小 = 代码位
    定义 运行时前缀修正表 = 修正表
    定义 运行时前缀函数表 = 函数表
    模块图_打印详细(字符串拼接("[链接前缀] 运行时前缀大小: ", 转字符串(运行时前缀大小)))
    // 收集所有已编译模块的目标码 + 记录每模块在合并代码中的基地址
    定义 可变 全部目标码 = []
    定义 可变 模块基地址 = []       // 每个模块在合并代码段中的起始偏移
    定义 可变 全局函数表 = 字典()   // 函数名 → 合并代码段中的绝对偏移
    定义 可变 模块init列表 = []     // 每个模块的__初始化全局__绝对偏移
    定义 可变 _模块名列表 = []      // 诊断用: 已编译模块名列表 (第一遍聚合时构建)
    定义 可变 当前基地址 = 运行时前缀大小
    定义 可变 首入口偏移 = 0
    定义 可变 首入口已定 = 假
    定义 可变 入口偏移 = 0
    定义 可变 入口已定 = 假
    定义 可变 运行时函i = 0
    定义 运行时函数键 = 字典键(运行时前缀函数表)
    排序(运行时函数键, 0)
    当 (运行时函i < 计数(运行时函数键)) {
        定义 运行时函数名 = 运行时函数键[运行时函i]
        字典设(全局函数表, 运行时函数名, 字典取(运行时前缀函数表, 运行时函数名))
        运行时函i = 运行时函i + 1
    }
    模块图_打印详细(字符串拼接("[ENTRY-DIAG] 模块入口模块名=[", 字符串拼接(模块入口模块名, "]")))    定义 可变 i = 0
    当 (i < 计数(顺序)) {
        定义 名 = 顺序[i]
        如果 (字典有(模块索引, 名)) {
            定义 位置 = 字典取(模块索引, 名)
            定义 信息 = 模块表[位置]
            如果 (信息.编译状态 == 2 且 信息.目标码 != 空) {
                如果 (计数(全部目标码) < 3) {
                    打印文本(字符串拼接("[链接聚合样本] #", 字符串拼接(转字符串(计数(全部目标码)), 字符串拼接(" ", 名))))
                }
                __运行时_列表追加(全部目标码, 信息.目标码)
                __运行时_列表追加(模块基地址, 当前基地址)
                如果 (!首入口已定) {
                    首入口偏移 = 当前基地址 + 信息.入口偏移
                    首入口已定 = 真
                }
                如果 (字节长度(模块入口模块名) > 0 且 字符串相等(名, 模块入口模块名)) {
                    入口偏移 = 当前基地址 + 信息.入口偏移
                    入口已定 = 真
                    模块图_打印详细(字符串拼接("[ENTRY-MATCH] ", 字符串拼接(名, 字符串拼接(" base=", 字符串拼接(转字符串(当前基地址), 字符串拼接(" entry=", 转字符串(入口偏移)))))))
                }
                // 合并函数表: 模块内偏移 + 基址 = 全局偏移
                定义 模块函数键 = 字典键(信息.函数表数据)
                定义 可变 j = 0
                排序(模块函数键, 0)
                当 (j < 计数(模块函数键)) {
                    定义 函数名 = 模块函数键[j]
                    定义 模块内偏移 = 字典取(信息.函数表数据, 函数名)
                    如果 (模块内偏移 >= 0) {
                        字典设(全局函数表, 函数名, 当前基地址 + 模块内偏移)
                    }
                    j = j + 1
                }
                // 收集模块的init入口偏移(顶层代码不在函数表中,在入口偏移字段)
                __运行时_列表追加(模块init列表, 当前基地址 + 信息.入口偏移)
                __运行时_列表追加(_模块名列表, 名)
                定义 _实际大小 = 计数(信息.目标码)
                如果 (信息.目标码大小 != _实际大小) {
                    打印文本(字符串拼接("[SIZE-MISMATCH] ", 字符串拼接(名, 字符串拼接(" 声明=", 字符串拼接(转字符串(信息.目标码大小), 字符串拼接(" 实际=", 转字符串(_实际大小)))))))
                }
                // 合并行号映射: 模块内偏移 + 基址 = 最终偏移
                如果 (字典有(_模块行号映射, 名)) {
                    定义 _lm数据 = 字典取(_模块行号映射, 名)
                    如果 (_lm数据 != 空) {
                        定义 可变 _lmi = 0
                        当 (_lmi < 计数(_lm数据)) {
                            定义 _lm条目 = _lm数据[_lmi]
                            追加(编译_行号映射表(), [_lm条目[0] + 当前基地址, _lm条目[1]])
                            _lmi = _lmi + 1
                        }
                    }
                }
                当前基地址 = 当前基地址 + 信息.目标码大小
            }
        }
        i = i + 1
    }
    模块图_阶段标记("链接/聚合后", "<bootstrap>")

    // 重新应用运行时函数表——防止模块函数覆盖运行时关键函数(如 参数/退出/打印)
    定义 可变 _rt重写i = 0
    当 (_rt重写i < 计数(运行时函数键)) {
        定义 _rt重写名 = 运行时函数键[_rt重写i]
        字典设(全局函数表, _rt重写名, 字典取(运行时前缀函数表, _rt重写名))
        _rt重写i = _rt重写i + 1
    }

    如果 (!入口已定) {
        打印文本(字符串拼接("链接失败: 入口模块 [", 字符串拼接(模块入口模块名, "] 未在已编译模块中找到")))
        返回 假
    }
    打印文本(字符串拼接("[链接诊断] 顺序=", 字符串拼接(转字符串(计数(顺序)), 字符串拼接(" 前缀=", 字符串拼接(转字符串(运行时前缀大小), 字符串拼接(" 当前基址=", 字符串拼接(转字符串(当前基地址), 字符串拼接(" 入口已定=", 转字符串(入口已定)))))))))
    模块图_打印详细(字符串拼接("[ENTRY-FINAL] 入口偏移=", 字符串拼接(转字符串(入口偏移), 字符串拼接(" 入口已定=", 字符串拼接(转字符串(入口已定), 字符串拼接(" 首入口=", 转字符串(首入口偏移)))))))
    // 合并全部模块目标码到单一代码段
    定义 可变 总代码大小 = 当前基地址
    如果 (总代码大小 == 0) {
        打印文本("链接失败: 无有效目标码")
        返回 假
    }

    _链接_全局函数表[0] = 全局函数表

    // 第1步: 运行时前缀call修正 (直接在代码列表上, 此时代码列表很小=运行时大小)
    定义 可变 rtfi = 0
    当 (rtfi < 计数(运行时前缀修正表)) {
        定义 修rt类 = 修正表_取类型(运行时前缀修正表, rtfi)
        定义 修rt步长 = 修正表_项步长(运行时前缀修正表, rtfi)
        如果 (字符串相等(修rt类, "call")) {
            _fixup_基址 = 0
            _fixup_fallback偏移 = _fallback偏移
            定义 _rt修 = 模块_应用call修正(运行时前缀修正表, rtfi, 全局函数表, 代码)
            如果 (_rt修 < 0) { 返回 假 }
        }
        rtfi = rtfi + 修rt步长
    }

    // 符号去重预处理 (创新4: 减少链接期重复符号查找)
    符号驻留_重置()
    // 第2步: 对每个模块的小目标码列表做call fixup + 收集非call修正到全局修正表 (合并原第3步, 消除重复遍历)
    定义 可变 全局修正表 = []
    // 先收集运行时前缀的非call修正
    定义 可变 前缀修i = 0
    当 (前缀修i < 计数(运行时前缀修正表)) {
        定义 前修类 = 修正表_取类型(运行时前缀修正表, 前缀修i)
        定义 前修步 = 修正表_项步长(运行时前缀修正表, 前缀修i)
        如果 (!字符串相等(前修类, "call") 且 前修类 != 空) {
            定义 前修位 = 修正表_取位置(运行时前缀修正表, 前缀修i)
            定义 前修附 = 修正表_取附加(运行时前缀修正表, 前缀修i)
            修正表_追加记录(全局修正表, 前修类, 前修位, 前修附)
        }
        前缀修i = 前缀修i + 前修步
    }
    定义 可变 修正数 = 0
    定义 可变 模块序号 = 0
    定义 可变 _总call数 = 0
    定义 可变 _call成功 = 0
    定义 可变 _call回退 = 0
    定义 可变 _未解析函数名 = 字典()
    i = 0
    当 (i < 计数(顺序)) {
        定义 名 = 顺序[i]
        如果 (字典有(模块索引, 名)) {
            定义 位置 = 字典取(模块索引, 名)
            定义 信息 = 模块表[位置]
            如果 (信息.编译状态 == 2 且 信息.目标码 != 空) {
                定义 基址 = 模块基地址[模块序号]
                ri = 0
                当 (ri < 计数(信息.修正表数据)) {
                    定义 修类 = 修正表_取类型(信息.修正表数据, ri)
                    定义 修步长 = 修正表_项步长(信息.修正表数据, ri)
                    如果 (字符串相等(修类, "call")) {
                        _总call数 = _总call数 + 1
                        _fixup_基址 = 基址
                        _fixup_fallback偏移 = _fallback偏移
                        _fixup_当前模块名 = 名
                        定义 _r = 模块_应用call修正_本地(信息.修正表数据, ri, 全局函数表, 信息.目标码)
                        如果 (_r < 0) { 返回 假 }
                        如果 (_r > 0) { _call成功 = _call成功 + 1 }
                        否则 {
                            _call回退 = _call回退 + 1
                            定义 _fb函名 = 修正表_取附加(信息.修正表数据, ri)
                            如果 (_fb函名 != 空) { 字典设(_未解析函数名, _fb函名, 名) }
                        }
                        修正数 = 修正数 + _r
                    } 否则 如果 (修类 != 空) {
                        // 收集非call修正到全局修正表 (合并原第3步, 避免重复遍历)
                        定义 修位 = 修正表_取位置(信息.修正表数据, ri)
                        定义 修附 = 修正表_取附加(信息.修正表数据, ri)
                        修正表_追加记录(全局修正表, 修类, 基址 + 修位, 修附)
                    }
                    ri = ri + 修步长
                }
                模块序号 = 模块序号 + 1
            }
        }
        i = i + 1
    }
    模块图_打印详细(字符串拼接("[STEP2] total_call=", 字符串拼接(转字符串(_总call数), 字符串拼接(" ok=", 字符串拼接(转字符串(_call成功), 字符串拼接(" fb=", 转字符串(_call回退)))))))
    // 符号去重统计 (创新4)
    定义 _驻留统计 = 符号驻留_统计()
    模块图_打印详细(字符串拼接("[符号去重] 总查询=", 字符串拼接(转字符串(_驻留统计[0]), 字符串拼接(" 命中=", 字符串拼接(转字符串(_驻留统计[1]), 字符串拼接(" 唯一符号=", 转字符串(_驻留统计[2])))))))

    // 报告未解析函数（单文件模式下为错误，模块图模式为详细日志）
    // A.6工业级增强: 为每个未解析函数提供 Did-you-mean 推荐
    定义 _未解析键 = 字典键(_未解析函数名)
    如果 (计数(_未解析键) > 0 且 计数(模块表) <= 3) {
        排序(_未解析键, 0)
        打印文本(字符串拼接("\n警告: ", 字符串拼接(转字符串(计数(_未解析键)), " 个未定义的函数调用:")))
        // 构造候选函数名列表 (已定义函数的名字集合)
        定义 _已定义函数名列表 = 字典键(全局函数表)
        定义 可变 _ui = 0
        定义 _上限 = 10
        当 (_ui < 计数(_未解析键) 且 _ui < _上限) {
            定义 _uf = _未解析键[_ui]
            定义 _um = 字典取(_未解析函数名, _uf)
            打印文本(字符串拼接("  → ", 字符串拼接(_uf, 字符串拼接("()  (在 ", 字符串拼接(_um, " 中)")))))
            // Did-you-mean 推荐: 基于 Levenshtein 距离找最多3个相似函数名
            定义 _相似 = 诊断_查找相似符号(_uf, _已定义函数名列表, 3)
            定义 可变 _si = 0
            当 (_si < 计数(_相似)) {
                打印文本(字符串拼接("      您是否想用: ", 字符串拼接(_相似[_si], "?")))
                _si = _si + 1
            }
            _ui = _ui + 1
        }
        如果 (计数(_未解析键) > _上限) {
            打印文本(字符串拼接("  ... 还有 ", 字符串拼接(转字符串(计数(_未解析键) - _上限), " 个")))
        }
    }
    如果 (计数(_未解析键) > 0 且 模块图详细模式[0]) {
        打印文本(字符串拼接("[链接] 未解析函数数: ", 转字符串(计数(_未解析键))))
    }

    // 第3步: 拼接已解析fixup的模块目标码到代码段
    定义 运行时前缀代码 = 代码
    代码 = []
    代码位 = 0
    定义 可变 _前缀i = 0
    当 (_前缀i < 运行时前缀大小) {
        发射(运行时前缀代码[_前缀i])
        _前缀i = _前缀i + 1
    }
    定义 可变 k = 0
    当 (k < 计数(全部目标码)) {
        定义 片段 = 全部目标码[k]
        定义 可变 bi = 0
        当 (bi < 计数(片段)) {
            发射(片段[bi])
            bi = bi + 1
        }
        k = k + 1
    }
    代码位 = 总代码大小


    模块图_打印详细(字符串拼接("链接 ", 字符串拼接(转字符串(计数(顺序)), 字符串拼接(" 模块 (", 字符串拼接(转字符串(总代码大小), 字符串拼接("字节) → ", 输出路径))))))
    // 打印前15个模块的基址和名称(用于定位crash偏移)
    // _模块名列表 已在第一遍聚合循环中构建, 无需重复遍历
    如果 (模块图详细模式[0]) {
        定义 可变 _dbi = 0
        当 (_dbi < 计数(模块基地址)) {
            定义 _mn = ""
            如果 (_dbi < 计数(_模块名列表)) { _mn = _模块名列表[_dbi] }
            如果 (模块基地址[_dbi] >= 5850000 且 模块基地址[_dbi] <= 5870000) {
                打印文本(字符串拼接("[CRASH-MOD] #", 字符串拼接(转字符串(_dbi), 字符串拼接(" addr=", 字符串拼接(转字符串(模块基地址[_dbi]), 字符串拼接(" ", _mn))))))
            }
            如果 (_dbi < 15 或 _dbi >= 94) {
                打印文本(字符串拼接("[BASE] #", 字符串拼接(转字符串(_dbi), 字符串拼接(" addr=", 字符串拼接(转字符串(模块基地址[_dbi]), 字符串拼接(" ", _mn))))))
            }
            _dbi = _dbi + 1
        }
    }

    // 生成合并__初始化全局__函数(调用每个模块的init)
    模块图_打印详细(字符串拼接("[INIT-DIAG] 代码位=", 字符串拼接(转字符串(代码位), 字符串拼接(" 总代码大小=", 字符串拼接(转字符串(总代码大小), 字符串拼接(" diff=", 字符串拼接(转字符串(代码位 - 总代码大小), 字符串拼接(" init0=", 转字符串(模块init列表[0])))))))))
    定义 合并init偏移 = 总代码大小
    // prologue: push rbp; mov rbp,rsp; sub rsp,0x28 (shadow space)
    发射(0x55) 发射(0x48) 发射(0x89) 发射(0xE5)
    发射(0x48) 发射(0x83) 发射(0xEC) 发射(0x28)
    // 分配全局变量区(一次性,供所有模块共享)
    如果 (总全局变量数 > 0) {
        定义 全局大小 = 总全局变量数 * 8
        // mov ecx, 全局大小
        发射(0xB9)
        发射(全局大小 & 255)
        发射((全局大小 >> 8) & 255)
        发射((全局大小 >> 16) & 255)
        发射((全局大小 >> 24) & 255)
        // 调用 __运行时_分配
        定义 alloc偏移 = 字典取(全局函数表, "__运行时_分配")
        定义 alloc_call位 = 代码位
        发射(0xE8)
        定义 分配重定位 = alloc偏移 - (alloc_call位 + 5)
        发射(分配重定位 & 255)
        发射((分配重定位 >> 8) & 255)
        发射((分配重定位 >> 16) & 255)
        发射((分配重定位 >> 24) & 255)
        // mov [rip+disp], rax — 存储全局区指针(rt_globals fixup)
        发射(0x48) 发射(0x89) 发射(0x05)
        修正表_追加记录(全局修正表, "rt_globals", 代码位, 空)
        发射(0x00) 发射(0x00) 发射(0x00) 发射(0x00)
    }
    定义 可变 _initI = 0
    定义 可变 _initPos = 代码位
    当 (_initI < 计数(模块init列表)) {
        定义 _目标 = 模块init列表[_initI]
        定义 _相对偏移 = _目标 - (_initPos + 5)
        发射(0xE8)
        发射(_相对偏移 & 255)
        发射((_相对偏移 >> 8) & 255)
        发射((_相对偏移 >> 16) & 255)
        发射((_相对偏移 >> 24) & 255)
        _initPos = _initPos + 5
        _initI = _initI + 1
    }
    // leave; ret
    发射(0xC9) 发射(0xC3)
    字典设(全局函数表, "__初始化全局__", 合并init偏移)
    // 更新总代码大小
    总代码大小 = 代码位

    代码位 = 总代码大小
    修正表 = 全局修正表
    函数表 = 全局函数表
    字串表 = []
    字串偏移 = []

    // 根据目标格式调用权威构建器并写出可执行文件
    如果 (字符串相等(当前目标名称, "linux")) {
        // 内联生成 Linux _start 入口点 (纯本地变量,避免全局UNDEF)
        定义 _start偏移 = 总代码大小
        定义 可变 _start代码 = []
        定义 可变 _主程序偏移 = 字典取(全局函数表, "主程序")
        定义 可变 _有主程序 = 假
        如果 (_主程序偏移 != 空 且 _主程序偏移 > 0) { _有主程序 = 真 }
        如果 (_有主程序) {
            _start代码 = [
                0x49, 0x89, 0xE5,
                0x48, 0x81, 0xEC, 0x00, 0x00, 0x04, 0x00,
                0x4C, 0x8D, 0x7C, 0x24, 0x28,
                0xE8, 0x00, 0x00, 0x00, 0x00,
                0x49, 0x89, 0xC6,
                0xE8, 0x00, 0x00, 0x00, 0x00,
                0xE8, 0x00, 0x00, 0x00, 0x00,
                0x48, 0x89, 0xC7,
                0x48, 0xC7, 0xC0, 0x3C, 0x00, 0x00, 0x00,
                0x0F, 0x05
            ]
        } 否则 {
            _start代码 = [
                0x49, 0x89, 0xE5,
                0x48, 0x81, 0xEC, 0x00, 0x00, 0x04, 0x00,
                0x4C, 0x8D, 0x7C, 0x24, 0x28,
                0xE8, 0x00, 0x00, 0x00, 0x00,
                0x49, 0x89, 0xC6,
                0xE8, 0x00, 0x00, 0x00, 0x00,
                0x48, 0x31, 0xFF,
                0x48, 0xC7, 0xC0, 0x3C, 0x00, 0x00, 0x00,
                0x0F, 0x05
            ]
        }
        // 回填三个call 重定位32 (直接计算位移,绕过字典有的0==空歧义)
        定义 _堆初始化偏移 = 字典取(全局函数表, "__运行时_堆初始化")
        如果 (_堆初始化偏移 == 空) { _堆初始化偏移 = 0 }
        定义 _堆重定位 = _堆初始化偏移 - (_start偏移 + 20)
        _start代码[16] = _堆重定位 & 255
        _start代码[17] = (_堆重定位 >> 8) & 255
        _start代码[18] = (_堆重定位 >> 16) & 255
        _start代码[19] = (_堆重定位 >> 24) & 255
        定义 _初始化全局偏移 = 字典取(全局函数表, "__初始化全局__")
        如果 (_初始化全局偏移 == 空) { _初始化全局偏移 = 0 }
        定义 _初始化重定位 = _初始化全局偏移 - (_start偏移 + 28)
        _start代码[24] = _初始化重定位 & 255
        _start代码[25] = (_初始化重定位 >> 8) & 255
        _start代码[26] = (_初始化重定位 >> 16) & 255
        _start代码[27] = (_初始化重定位 >> 24) & 255
        // 优先调用主程序()函数(用户程序); 回退到入口模块init(自举编译器)
        如果 (_有主程序) {
            定义 _入口重定位 = _主程序偏移 - (_start偏移 + 33)
            _start代码[29] = _入口重定位 & 255
            _start代码[30] = (_入口重定位 >> 8) & 255
            _start代码[31] = (_入口重定位 >> 16) & 255
            _start代码[32] = (_入口重定位 >> 24) & 255
        }
        // 追加_start代码到代码列表
        _si = 0
        当 (_si < 计数(_start代码)) {
            发射(_start代码[_si])
            _si = _si + 1
        }
        打印文本(字符串拼接("[START-OFF] ", 转字符串(_start偏移)))
        打印文本(字符串拼接("[START-LEN] ", 转字符串(计数(_start代码))))
        打印文本(字符串拼接("[CODE-WPOS] ", 转字符串(代码位)))
        打印文本(字符串拼接("[CODE-COUNT] ", 转字符串(计数(代码))))
        打印文本(字符串拼接("[START-B0] ", 转字符串(代码[_start偏移])))
        打印文本(字符串拼接("[START-B1] ", 转字符串(代码[_start偏移 + 1])))
        打印文本(字符串拼接("[START-B2] ", 转字符串(代码[_start偏移 + 2])))
        打印文本(字符串拼接("[START-B3] ", 转字符串(代码[_start偏移 + 3])))
        总代码大小 = 代码位
        // 计算数据段布局 (与写代码为ELF一致: data_off = 0x1000 + round_up(code_len))
        定义 _数据段文件偏移 = 0x1000 + (((总代码大小 + 0xFFF) / 0x1000) * 0x1000)
        定义 _数据段虚地址 = 0x400000 + _数据段文件偏移
        // 数据段布局: +0=heap_base, +8=heap_ptr, +16=saved_rsp, +24=globals_ptr
        // 解析全局修正表中的非call修正 (rt_globals/rt_heap/rt_saved_rsp)
        // 单遍完成: 应用修正 + 验证修补结果 (原为两遍遍历, 合并后减半迭代和字符串比较)
        定义 可变 _rg计数 = 0
        定义 可变 _v未修 = 0
        定义 可变 _gfi = 0
        当 (_gfi < 计数(全局修正表)) {
            定义 _gft = 修正表_取类型(全局修正表, _gfi)
            定义 _gfp = 修正表_取位置(全局修正表, _gfi)
            定义 _gf步长 = 修正表_项步长(全局修正表, _gfi)
            定义 _下一指令指针 = 0x401000 + _gfp + 4
            如果 (字符串相等(_gft, "rt_globals")) {
                _rg计数 = _rg计数 + 1
                如果 (_gfp >= 14300 且 _gfp <= 14368 且 模块图详细模式[0]) {
                    打印文本(字符串拼接("[RGCHK] gfp=", 转字符串(_gfp)))
                }
                内存写32(代码, _gfp, (_数据段虚地址 + 24) - _下一指令指针)
                // 就地验证: 修补后检查是否仍为全零 (合并原验证遍历)
                如果 (_gfp >= 0 且 _gfp + 3 < 计数(代码)) {
                    如果 (代码[_gfp] == 0 且 代码[_gfp + 1] == 0 且 代码[_gfp + 2] == 0 且 代码[_gfp + 3] == 0) {
                        如果 (_v未修 < 10 且 模块图详细模式[0]) {
                            打印文本(字符串拼接("[FIXUP-ZERO] pos=", 转字符串(_gfp)))
                        }
                        _v未修 = _v未修 + 1
                    }
                }
            } 否则 如果 (字符串相等(_gft, "rt_heap")) {
                内存写32(代码, _gfp, _数据段虚地址 - _下一指令指针)
            } 否则 如果 (字符串相等(_gft, "rt_saved_rsp")) {
                内存写32(代码, _gfp, (_数据段虚地址 + 16) - _下一指令指针)
            }
            _gfi = _gfi + _gf步长
        }
        模块图_打印详细(字符串拼接("[RGCHK] total=", 转字符串(_rg计数)))
        模块图_打印详细(字符串拼接("[VERIFY] fixup_zero=", 转字符串(_v未修)))
        // 诊断: 扫描未修补的 E8 00 00 00 00 (仅详细模式, 避免非调试时O(n)全量扫描)
        如果 (模块图详细模式[0]) {
            定义 可变 _uc = 0
            定义 可变 _uci = 0
            当 (_uci < 计数(代码) - 4) {
                如果 (代码[_uci] == 232 且 代码[_uci+1] == 0 且 代码[_uci+2] == 0 且 代码[_uci+3] == 0 且 代码[_uci+4] == 0) {
                    打印文本(字符串拼接("[UE8] pos=", 转字符串(_uci)))
                    _uc = _uc + 1
                }
                _uci = _uci + 1
            }
            模块图_打印详细(字符串拼接("[CALL-CHK] unpatched_E8=", 转字符串(_uc)))
        }
        // 用_start偏移作为ELF入口(不是main入口)
        // M9: 编译流水线内存Profile报告
        mem_记录分配(计数(代码))     // 代码段
        mem_记录分配(总字串大小)     // 字符串表
        mem_记录分配(计数(修正表) * 16) // 修正表
        模块图_打印详细(字符串拼接("[M9] 代码段=", 字符串拼接(转字符串(计数(代码)), 字符串拼接(" 字串表=", 字符串拼接(转字符串(总字串大小), 字符串拼接(" 修正表=", 转字符串(计数(修正表) * 16)))))))
        模块图_打印详细(字符串拼接("[M9] 峰值=", 字符串拼接(转字符串(_mem_峰值字节), 字符串拼接(" 当前=", 字符串拼接(转字符串(_mem_当前字节), 字符串拼接(" 碎片率=", 字符串拼接(转字符串(mem_碎片率()), "%")))))))
        如果 (mem_是极低内存profile()) {
            模块图_打印详细("[M9] ✓ 极低内存profile合规")
        } 否则 {
            模块图_打印详细("[M9] ✗ 未达极低内存标准")
        }
        模块图_打印详细(字符串拼接("[ELF-BUILD] start=", 字符串拼接(转字符串(_start偏移), 字符串拼接(" code=", 转字符串(总代码大小)))))
        定义 elf大小 = 模块_写LinuxELF(输出路径, _start偏移, 总代码大小)
        模块图_打印详细(字符串拼接("ELF写入成功: ", 输出路径))
        // P6: DWARF调试信息 + 行号映射 (按调试合同级别)
        定义 _lm表 = 编译_行号映射表()
        定义 _lm数 = 计数(_lm表)
        定义 可变 _调试级 = "line"
        如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 5) {
            // 从构建配置读取调试合同级别 (由profile决定)
            定义 _调试配置 = _模块_项目合同[4]
            如果 (字符串相等(_调试配置, "analysis-host")) { _调试级 = "full" }
            如果 (字符串相等(_调试配置, "kernel-qemu")) { _调试级 = "symbol" }
        }
        模块图_打印详细(字符串拼接("[DWARF] 行号映射条目数: ", 字符串拼接(转字符串(_lm数), 字符串拼接(" 调试级=", _调试级))))
        // line级+: 输出行号映射文件
        如果 (_lm数 > 0) {
            定义 可变 _map字节 = []
            当 (_mi < _lm数) {
                定义 _me = _lm表[_mi]
                _map字节_追加整数(_me[0], _map字节)
                追加(_map字节, 32)
                _map字节_追加整数(_me[1], _map字节)
                追加(_map字节, 10)
                _mi = _mi + 1
            }
            写列表文件(字符串拼接(输出路径, ".map"), _map字节)
        }
        // symbol级+: 输出函数符号表
        如果 (字符串相等(_调试级, "symbol") 或 字符串相等(_调试级, "full")) {
            定义 可变 _sym字节 = []
            定义 _函数键 = 字典键(函数表)
            定义 可变 _sym_i = 0
            当 (_sym_i < 计数(_函数键)) {
                定义 _符号名 = _函数键[_sym_i]
                定义 _符号偏移 = 字典取(函数表, _符号名)
                如果 (_符号偏移 != 空) {
                    _map字节_追加整数(_符号偏移, _sym字节)
                    追加(_sym字节, 32)
                    定义 可变 _ni = 0
                    当 (_ni < 字节长度(_符号名)) {
                        追加(_sym字节, 字节取(_符号名, _ni))
                        _ni = _ni + 1
                    }
                    追加(_sym字节, 10)
                }
                _sym_i = _sym_i + 1
            }
            写列表文件(字符串拼接(输出路径, ".sym"), _sym字节)
            模块图_打印详细(字符串拼接("[DWARF] 符号表条目数: ", 转字符串(计数(_函数键))))
        }
        // full级: 输出完整诊断报告
        如果 (字符串相等(_调试级, "full")) {
            定义 可变 _rpt字节 = []
            定义 可变 _rpt行列表 = [
                "# Nova编译诊断报告",
                字符串拼接("# 模块数: ", 转字符串(计数(模块表))),
                字符串拼接("# 代码大小: ", 转字符串(代码位)),
                字符串拼接("# 函数数: ", 转字符串(计数(_函数键)))
            ]
            定义 可变 _rli = 0
            当 (_rli < 计数(_rpt行列表)) {
                定义 可变 _rpt行 = _rpt行列表[_rli]
                定义 可变 _ri = 0
                当 (_ri < 字节长度(_rpt行)) {
                    追加(_rpt字节, 字节取(_rpt行, _ri))
                    _ri = _ri + 1
                }
                追加(_rpt字节, 10)
                _rli = _rli + 1
            }
            写列表文件(字符串拼接(输出路径, ".report"), _rpt字节)
            模块图_打印详细("[DWARF] 完整诊断报告已生成")
        }
    } 否则 如果 (字符串相等(当前目标名称, "裸机") 或 字符串相等(当前目标名称, "kernel")) {
        // 裸机内核: 先写标准ELF, 再用dd叠加补丁(绕过大文件读回问题)
        写代码为ELF(输出路径, 代码, 入口偏移)
        // 本地构建280字节补丁 (仅用内存写32+直接赋值, 绕过内存写16/64 bug)
        定义 _内核物理地址 = 0x100000
        定义 _代码段对齐 = (((代码位 + 0xFFF) / 0x1000) * 0x1000)
        定义 _数据文件偏移 = 0x1000 + _代码段对齐
        定义 _MB2偏移 = 232
        // 计算内核入口: 0xFFFFFFFF80100000 + 0x1000 + 入口偏移
        // 拆为低32位和高32位 (绕过内存写64 bug)
        定义 _入口低32 = (0x80101000 + 入口偏移) & 0xFFFFFFFF
        定义 _入口高32 = 0xFFFFFFFF
        定义 _内核基低 = 0x80100000
        定义 _内核基高 = 0xFFFFFFFF
        定义 _总段大小 = 0x1000 + 代码位
        定义 可变 _p = []
        定义 可变 _pi = 0
        当 (_pi < 280) { 追加(_p, 0) _pi = _pi + 1 }
        // ELF64 头 (64 bytes) - 直接赋值
        _p[0] = 0x7F
        _p[1] = 0x45
        _p[2] = 0x4C
        _p[3] = 0x46
        _p[4] = 2
        _p[5] = 1
        _p[6] = 1
        // e_type=2(EXEC), e_machine=62(x86-64) 用内存写32覆盖4字节
        内存写32(_p, 16, 2 + 62 * 65536)
        // e_version=1
        内存写32(_p, 20, 1)
        // e_entry (64位) = 两次32位写
        内存写32(_p, 24, _入口低32)
        内存写32(_p, 28, _入口高32)
        // e_phoff=64 (64位)
        内存写32(_p, 32, 64)
        内存写32(_p,  36, 0)
        // e_shoff=0 (已全零)
        // e_ehsize=64, e_phentsize=56, e_phnum=3 用内存写32
        内存写32(_p, 52, 64 + 56 * 65536)
        内存写32(_p, 56, 3)
        // === 程序头1: 代码段 PT_LOAD @64 ===
        内存写32(_p, 64, 1)
        内存写32(_p, 68, 7)
        // p_offset=0 (已全零)
        // p_vaddr=_kbase (64位)
        内存写32(_p, 80, _内核基低)
        内存写32(_p, 84, _内核基高)
        // p_paddr=_内核物理地址 (64位)
        内存写32(_p, 88, _内核物理地址)
        内存写32(_p,  92, 0)
        // p_filesz=p_memsz=0x1000+代码位
        内存写32(_p, 96, _总段大小)
        内存写32(_p,  100, 0)
        内存写32(_p, 104, _总段大小)
        内存写32(_p,  108, 0)
        // p_align=0x1000
        内存写32(_p, 112, 0x1000)
        内存写32(_p,  116, 0)
        // === 程序头2: 数据段 PT_LOAD @120 ===
        内存写32(_p, 120, 1)
        内存写32(_p, 124, 6)
        // p_offset=_数据文件偏移
        内存写32(_p, 128, _数据文件偏移)
        内存写32(_p,  132, 0)
        // p_vaddr
        内存写32(_p, 136, (_内核基低 + _数据文件偏移) & 0xFFFFFFFF)
        内存写32(_p, 140, _内核基高)
        // p_paddr
        内存写32(_p, 144, _内核物理地址 + _数据文件偏移)
        内存写32(_p,  148, 0)
        // p_filesz=p_memsz=0x1000
        内存写32(_p, 152, 0x1000)
        内存写32(_p,  156, 0)
        内存写32(_p, 160, 0x1000)
        内存写32(_p,  164, 0)
        // p_align=0x1000
        内存写32(_p, 168, 0x1000)
        内存写32(_p,  172, 0)
        // === 程序头3: PT_NOTE @176 ===
        内存写32(_p, 176, 4)
        内存写32(_p, 180, 4)
        // p_offset=_MB2偏移
        内存写32(_p, 184, _MB2偏移)
        内存写32(_p,  188, 0)
        // p_vaddr
        内存写32(_p, 192, _内核基低 + _MB2偏移)
        内存写32(_p, 196, _内核基高)
        // p_paddr
        内存写32(_p, 200, _内核物理地址 + _MB2偏移)
        内存写32(_p,  204, 0)
        // p_filesz=p_memsz=48
        内存写32(_p, 208, 48)
        内存写32(_p,  212, 0)
        内存写32(_p, 216, 48)
        内存写32(_p,  220, 0)
        // p_align=8
        内存写32(_p, 224, 8)
        内存写32(_p,  228, 0)
        // === Multiboot2 头 @232 ===
        内存写32(_p, 232, 0xE85250D6)
        内存写32(_p,  236, 0)
        内存写32(_p, 240, 48)
        内存写32(_p, 244, 0 - (0xE85250D6 + 0 + 48))
        // 帧缓冲标签: type=5 flags=0 size=20
        内存写32(_p, 248, 5)
        内存写32(_p, 252, 20)
        内存写32(_p, 256, 80)
        内存写32(_p, 260, 25)
        内存写32(_p,  264, 0)
        // 结束标签: type=0 flags=0 size=8
        内存写32(_p,  268, 0)
        内存写32(_p, 272, 8)
        // 尾部填充 (确保280字节)
        内存写32(_p,  276, 0)
        // 2026-04-17 根治: 读回原ELF → 替换前280字节 → 一次性写回, 消除dd conv=notrunc OS依赖
        定义 _原elf = 读文件(输出路径)
        如果 (_原elf != 空) {
            定义 _原大小 = 字节长度(_原elf)
            定义 可变 _新elf = []
            定义 可变 _hi = 0
            当 (_hi < 280) { 追加(_新elf, _p[_hi]) _hi = _hi + 1 }
            定义 可变 _ri = 280
            当 (_ri < _原大小) { 追加(_新elf, 字节取(_原elf, _ri)) _ri = _ri + 1 }
            写二进制(输出路径, _新elf, 计数(_新elf))
        }
        QEMU_写出Bundle工件(输出路径)
        模块图_打印详细("裸机ELF写入成功")
        模块图_打印详细("QEMU bundle写入成功")
    } 否则 {
        模块_处理_格式_PE(0)
    }

    返回 真
}

// §9 扫描项目自动发现模块

// Shell路径转义: 将路径中的 ' 转义为 '\'' 防止命令注入
函数 模块图_转义路径(路径) {
    定义 长度 = 字节长度(路径)
    如果 (长度 == 0) { 返回 路径 }
    定义 可变 结果 = ""
    定义 可变 i = 0
    定义 可变 有引号 = 假
    当 (i < 长度) {
        如果 (字节取(路径, i) == 字符_单引号) {
            有引号 = 真
            i = 长度
        }
        i = i + 1
    }
    如果 (!有引号) { 返回 路径 }
    i = 0
    当 (i < 长度) {
        定义 b = 字节取(路径, i)
        如果 (b == 字符_单引号) {
            结果 = 字符串拼接(结果, "'\\''")
        } 否则 {
            结果 = 字符串拼接(结果, 字符(b))
        }
        i = i + 1
    }
    返回 结果
}

函数 是目录(路径) {
    定义 可变 标准路径 = 模块图_规范路径(路径)
    如果 (字节长度(标准路径) == 0) { 标准路径 = "." }
    // 2026-04-17 根治: 调用runtime blob原生__运行时_是目录(stat syscall), 消除test -d OS依赖
    返回 __运行时_是目录(标准路径)
}

函数 模块图_是Nova文件路径(路径) {
    定义 标准路径 = 模块图_规范路径(路径)
    如果 (字节长度(标准路径) == 0) { 返回 假 }
    定义 长度 = 字节长度(标准路径)
    如果 (长度 < 5) { 返回 假 }
    如果 (字节取(标准路径, 长度 - 5) == 字符_句点 且 字节取(标准路径, 长度 - 4) == 110 且 字节取(标准路径, 长度 - 3) == 111 且 字节取(标准路径, 长度 - 2) == 118 且 字节取(标准路径, 长度 - 1) == 字符_小写a) {
        返回 真
    }
    返回 假
}

函数 模块图_项目根目录(路径) {
    定义 可变 标准路径 = 路径
    如果 (标准路径 == 空) { 标准路径 = "" }
    标准路径 = 替换(替换(标准路径, "\r", ""), "\n", "")
    如果 (字节长度(标准路径) == 0) { 返回 "." }
    如果 (模块图_是Nova文件路径(标准路径)) {
        定义 父目录 = 模块图_父目录(标准路径)
        如果 (字节长度(父目录) > 0) { 返回 父目录 }
        返回 "."
    }
    返回 标准路径
}

函数 列目录(路径) {
    定义 可变 标准路径 = 模块图_规范路径(路径)
    如果 (字节长度(标准路径) == 0) { 标准路径 = "." }
    定义 可变 枚举缓存 = ".__nova_dir_tmp.txt"
    定义 可变 _目录是点 = 0
    如果 (字节长度(标准路径) == 1) {
        如果 (字节取(标准路径, 0) == 字符_句点) { _目录是点 = 1 }
    }
    如果 (_目录是点 == 0) {
        枚举缓存 = 字符串拼接(标准路径, "/.__nova_dir_tmp.txt")
    }
    定义 命令 = "ls -1pA '" + 模块图_转义路径(标准路径) + "' > '" + 模块图_转义路径(枚举缓存) + "'"
    定义 执行结果 = __系统命令(命令)
    如果 (执行结果 != 0) { 返回 [] }

    定义 文本 = 读文件(枚举缓存)
    // 清理临时文件
    __系统命令("rm -f '" + 模块图_转义路径(枚举缓存) + "'")
    定义 可变 结果 = []
    如果 (文本 != 空 且 字节长度(文本) > 0) {
        定义 行列表 = 模块图_文本分行(文本)
        定义 可变 已见 = 字典()
        定义 可变 i = 0
        定义 可变 _mfg样本 = 0
        当 (i < 计数(行列表)) {
            定义 原行 = 替换(替换(行列表[i], "\r", ""), "\n", "")
            定义 行 = 模块图_规范路径(原行)
            定义 是目录条目 = 模块图_条目是目录(原行)
            定义 _mfg是Nova = 模块图_是Nova文件路径(行)
            定义 _mfg跳过 = 模块图_应跳过文件路径(行)
            如果 (模块图详细模式[0] 且 _mfg样本 < 3) {
                模块图_打印详细(字符串拼接("[清单] 行=", 行))
                模块图_打印详细(字符串拼接("[清单] 是Nova=", 转字符串(_mfg是Nova)))
                模块图_打印详细(字符串拼接("[清单] 跳过=", 转字符串(_mfg跳过)))
                _mfg样本 = _mfg样本 + 1
            }
            如果 (字节长度(行) > 0) {
                定义 可变 结果项 = 行
                如果 (是目录条目) { 结果项 = 字符串拼接(结果项, "/") }
                // 字典去重 O(1) (原线性扫描 O(n²))
                如果 (字典取(已见, 结果项) == 空) {
                    字典设(已见, 结果项, 真)
                    追加(结果, 结果项)
                }
            }
            i = i + 1
        }
    }
    模块图_打印详细(字符串拼接("[清单] 结果数=", 转字符串(计数(结果))))
    返回 结果
}

函数 模块_扫描文件(文件路径) {
    // 扫描单个.nova文件, 用词法感知方式提取依赖
    定义 可变 标准路径 = 文件路径
    如果 (字节长度(标准路径) == 0) { 返回 空 }
    定义 可变 读路径 = 标准路径
    如果 (路径_是相对(读路径)) {
        如果 (字节长度(模块图扫描读根) > 0) {
            读路径 = 字符串拼接(模块图扫描读根, 字符串拼接("/", 读路径))
        }
    }
    定义 源码 = 读文件(读路径)
    如果 (源码 == 空) { 打印文本(字符串拼接("读文件失败: ", 读路径)) 返回 空 }
    定义 可变 模块名扫 = 标准路径
    如果 (字节长度(模块图扫描读根) > 0) {
        定义 _读根前缀 = 字符串拼接(模块图扫描读根, "/")
        如果 (以开头(模块名扫, _读根前缀)) { 模块名扫 = 子串(模块名扫, 计数(_读根前缀), 计数(模块名扫) - 计数(_读根前缀)) }
    }
    如果 (以开头(模块名扫, "./")) { 模块名扫 = 子串(模块名扫, 2, 计数(模块名扫) - 2) }
    模块_注册(模块名扫, 读路径)
    定义 当前目录 = 模块图_父目录(模块名扫)

    // 词法感知扫描: 逐行处理, 跳过注释和字符串内部
    定义 可变 行列表 = 模块图_文本分行(源码)
    定义 可变 行号 = 0
    当 (行号 < 计数(行列表)) {
        定义 可变 行 = 行列表[行号]
        // 去掉前导空白
        定义 可变 行前 = 0
        当 (行前 < 计数(行) 且 (字节取(行, 行前) == 字符_空格 或 字节取(行, 行前) == 字符_制表)) {
            行前 = 行前 + 1
        }
        定义 有效行 = 子串(行, 行前, 计数(行) - 行前)
        // 跳过注释行
        如果 (计数(有效行) >= 2 且 字节取(有效行, 0) == 字符_斜杠 且 字节取(有效行, 1) == 字符_斜杠) {
            // 注释行: 不处理导入, 直接由底部行号+1推进
        } 否则 {
            // 匹配 导入("...") 或 入("...")
            定义 可变 导入偏移 = 0
            定义 可变 括号位 = 0
            当 (括号位 < 计数(有效行) 且 字节取(有效行, 括号位) != 字符_左圆括) {
                括号位 = 括号位 + 1
            }
            如果 (括号位 < 计数(有效行)) {
                定义 可变 导入前缀 = 子串(有效行, 0, 括号位)
                当 (计数(导入前缀) > 0 且 (字节取(导入前缀, 计数(导入前缀) - 1) == 字符_空格 或 字节取(导入前缀, 计数(导入前缀) - 1) == 字符_制表)) {
                    导入前缀 = 子串(导入前缀, 0, 计数(导入前缀) - 1)
                }
                如果 (字符串相等(导入前缀, "入") 或 字符串相等(导入前缀, "导入")) {
                    导入偏移 = 括号位 + 1
                }
            }
            如果 (导入偏移 > 0) {
                // 跳过开头引号
                如果 (导入偏移 < 计数(有效行) 且 (字节取(有效行, 导入偏移) == 字符_双引号 或 字节取(有效行, 导入偏移) == 字符_单引号)) {
                    定义 引号字节 = 字节取(有效行, 导入偏移)
                    导入偏移 = 导入偏移 + 1
                    // 扫描配对引号位置, 子串一次切片 O(1) (原逐字符拼接 O(n²))
                    定义 路径起始 = 导入偏移
                    当 (导入偏移 < 计数(有效行) 且 字节取(有效行, 导入偏移) != 引号字节) {
                        导入偏移 = 导入偏移 + 1
                    }
                    如果 (导入偏移 > 路径起始) {
                        定义 依赖路径 = 子串(有效行, 路径起始, 导入偏移 - 路径起始)
                        定义 依赖名 = 模块图_解析依赖路径(依赖路径, 当前目录)
                        模块_添加依赖(模块名扫, 依赖名)
                    }
                }
            }
        }
        行号 = 行号 + 1
    }
    返回 模块名扫
}

函数 模块图_文本分行(文本) {
    返回 分行(文本)
}

函数 模块图_追加清单文件(清单路径, 原结果) {
    定义 可变 结果 = 原结果
    如果 (!是列表(结果)) { 结果 = [] }
    定义 内容 = 读文件(清单路径)
    如果 (内容) {
        如果 (字节长度(内容) > 0) {
            定义 行列表 = 模块图_文本分行(内容)
            结果 = 模块图_追加清单行递归(行列表, 0, 计数(行列表), 结果)
        }
    }
    返回 结果
}

函数 模块图_追加清单行递归(行列表, 索引, 剩余, 结果) {
    // 迭代版 (原递归版对442+行清单有栈溢出风险)
    定义 可变 i = 索引
    定义 可变 剩 = 剩余
    当 (剩 > 0) {
        定义 可变 行 = 替换(替换(行列表[i], "\r", ""), "\n", "")
        如果 (以开头(行, "./")) { 行 = 子串(行, 2, 计数(行) - 2) }
        如果 (字节长度(行) > 0) { 追加(结果, 行) }
        i = i + 1
        剩 = 剩 - 1
    }
    返回 结果
}

函数 模块图_扫描文件列表递归(文件列表, 索引, 剩余, 扫描根, 扫描根是点) {
    // 迭代版 (原递归版对442+文件有栈溢出风险)
    定义 可变 i = 索引
    定义 可变 剩 = 剩余
    当 (剩 > 0) {
        定义 可变 文件路径 = 字符串拼接(文件列表[i], "")
        如果 (路径_是相对(文件路径)) {
            如果 (!扫描根是点) {
                文件路径 = 字符串拼接(扫描根, 字符串拼接("/", 文件路径))
            }
        }
        模块_扫描文件(文件路径)
        i = i + 1
        剩 = 剩 - 1
    }
    返回 0
}

函数 _扫描_尝试清单(文件名, 扫描根) {
    定义 可变 清单内容 = 读文件(文件名)
    如果 (!清单内容) {
        如果 (字节长度(扫描根) > 0) {
            清单内容 = 读文件(字符串拼接(扫描根, 字符串拼接("/", 文件名)))
        }
    }
    如果 (清单内容) {
        如果 (字节长度(清单内容) > 0) {
            定义 行列表 = 模块图_文本分行(清单内容)
            返回 模块图_追加清单行递归(行列表, 0, 计数(行列表), [])
        }
    }
    返回 []
}

函数 模块_扫描项目(根目录) {
    定义 可变 _sfi = 0
    定义 可变 _si = 0
    模块图扫描读根 = ""
    模块图_打印详细(字符串拼接("扫描项目: ", 根目录))
    定义 可变 扫描根 = 根目录
    如果 (字节长度(扫描根) == 0) { 扫描根 = "." }
    扫描根 = 模块图_项目根目录(扫描根)
    如果 (字节长度(扫描根) == 0) { 扫描根 = "." }
    定义 可变 文件列表 = []
    定义 可变 _扫描根是点 = 0
    如果 (字节长度(扫描根) == 1 且 字节取(扫描根, 0) == 字符_句点) { _扫描根是点 = 1 }
    // 清单加载: 按优先级依次尝试
    文件列表 = _扫描_尝试清单("_manifest.txt", 扫描根)
    如果 (!计数(文件列表)) { 文件列表 = _扫描_尝试清单("nova_manifest.txt", 扫描根) }
    如果 (!计数(文件列表)) { 文件列表 = _扫描_尝试清单(".__nova_files_tmp.txt", 扫描根) }
    如果 (!计数(文件列表)) { 文件列表 = _扫描_尝试清单("nova_files_tmp.txt", 扫描根) }
    如果 (!计数(文件列表)) {
        文件列表 = 模块图_递归枚举Nova文件(扫描根)
        模块图_打印详细(字符串拼接("[扫描] 回退到递归枚举 root=", 扫描根))
    } 否则 {
        模块图_打印详细(字符串拼接("[扫描] 使用显式清单 root=", 扫描根))
    }
    // 项目系统: 子manifest聚合
    如果 (_模块_项目合同) {
        如果 (是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 7) {
        定义 _子系统列 = _模块_项目合同[6]
        如果 (是列表(_子系统列) 且 计数(_子系统列) > 0) {
            模块图_打印详细(字符串拼接("[项目系统] 聚合子系统manifest: ", 转字符串(计数(_子系统列))))
            当 (_si < 计数(_子系统列)) {
                定义 _子系统 = _子系统列[_si]
                如果 (是列表(_子系统) 且 计数(_子系统) >= 2) {
                    定义 _子名 = _子系统[0]
                    定义 _子清单 = _子系统[1]
                    定义 可变 _子路径 = _子清单
                    如果 (!_扫描根是点) {
                        _子路径 = 字符串拼接(扫描根, 字符串拼接("/", _子清单))
                    }
                    定义 _子文件 = 模块图_追加清单文件(_子路径, [])
                    如果 (计数(_子文件) > 0) {
                        模块图_打印详细(字符串拼接("  [子系统] ", 字符串拼接(_子名, 字符串拼接(" → ", 字符串拼接(转字符串(计数(_子文件)), " 个文件")))))
                        定义 _子目录 = 模块图_父目录(_子清单)
                        _sfi = 0
                        当 (_sfi < 计数(_子文件)) {
                            如果 (字节长度(_子目录) > 0) {
                                追加(文件列表, 字符串拼接(_子目录, 字符串拼接("/", _子文件[_sfi])))
                            } 否则 {
                                追加(文件列表, _子文件[_sfi])
                            }
                            _sfi = _sfi + 1
                        }
                    }
                }
                _si = _si + 1
            }
        }
        }
    }
    模块图_扫描文件列表递归(文件列表, 0, 计数(文件列表), 扫描根, _扫描根是点)
    模块图_打印详细(字符串拼接("发现 ", 字符串拼接(转字符串(计数(模块表)), " 个模块")))
    返回 计数(模块表)
}

// §10 自举入口 (接入全部子系统)

// 当前目标名称 (默认linux, 可通过命令行覆盖)

函数 _模块_手动编译_处理单个(模块名, 位置, 统计) {
    定义 当前序号 = 位置 + 1
    _进度_当前 = 当前序号
    模块图_阶段标记("手动编译/模块前", 模块名)
    // profile过滤: 检查模块是否在当前profile下可编译
    如果 (字典有(模块索引, 模块名)) {
        定义 _过滤位 = 字典取(模块索引, 模块名)
        定义 _过滤信息 = 模块表[_过滤位]
        定义 _活跃p = ""
        如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 5) { _活跃p = _模块_项目合同[4] }
        如果 (!模块_profile可编译(_过滤信息, _活跃p)) {
            _进度_跳过 = _进度_跳过 + 1
            _进度_显示编译(当前序号, _进度_总数, 字符串拼接(模块名, " (跳过)"))
            返回
        }
    }
    _进度_显示编译(当前序号, _进度_总数, 模块名)
    定义 编译成功 = 模块_编译单个(模块名)
    如果 (编译成功) {
        _进度_成功 = _进度_成功 + 1
        统计[0] = 统计[0] + 1
        模块图_阶段标记("手动编译/成功", 模块名)
    } 否则 {
        _进度_失败 = _进度_失败 + 1
        模块图_阶段标记("手动编译/失败", 模块名)
    }
}

函数 _模块_手动编译_遍历(层级, 位置, 统计) {
    定义 可变 i = 位置
    定义 层级数 = 计数(层级)
    当 (i < 层级数) {
        定义 模块名 = 层级[i]
        _模块_手动编译_处理单个(模块名, i, 统计)
        i = i + 1
    }
}

函数 模块_自举(项目根, 输出路径) {
    定义 规范项目根 = 模块图_项目根目录(项目根)

    // 阶段0: 初始化子系统
    模块图_打印详细("模块_自举: begin")
    缓存_配置项目根(规范项目根)
    模块图_打印详细("模块_自举: cache project root ok")
    模块图_打印详细("模块_自举: target parsed ok")
    模块图_打印详细(字符串拼接("[目标] ", 当前目标名称))

    // M8: 通过目标选择模块的三元组/配置真实分派
    定义 可变 _m8_三元组 = 空
    如果 (字符串相等(当前目标名称, "linux") 或 字符串相等(当前目标名称, "elf") 或 字符串相等(当前目标名称, "x86-64")) {
        _m8_三元组 = 三元组_创建(目标_X86_64, 系统_Linux, "SysV")
        设置目标架构(架构_x86_64)
    } 否则 如果 (字符串相等(当前目标名称, "裸机") 或 字符串相等(当前目标名称, "kernel")) {
        _m8_三元组 = 三元组_创建(目标_X86_64, 系统_裸机, "SysV")
        设置目标架构(架构_x86_64)
    } 否则 如果 (字符串相等(当前目标名称, "arm64")) {
        _m8_三元组 = 三元组_创建(目标_ARM64, 系统_Linux, "AAPCS64")
        设置目标架构(架构_ARM64)
    } 否则 如果 (字符串相等(当前目标名称, "riscv64")) {
        _m8_三元组 = 三元组_创建(目标_RISCV64, 系统_Linux, "LP64D")
        设置目标架构(架构_RISC_V)
    } 否则 如果 (字符串相等(当前目标名称, "wasm") 或 字符串相等(当前目标名称, "wasm32")) {
        _m8_三元组 = 三元组_创建(目标_WASM32, 系统_WASI, "WASM")
        设置目标架构(架构_WASM)
    } 否则 {
        _m8_三元组 = 三元组_创建(目标_X86_64, 系统_Linux, "SysV")
        设置目标架构(架构_x86_64)
    }
    // 设置全局目标配置
    目标_设置(_m8_三元组)
    // 同步profile到目标选择层
    如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 5) {
        目标_设置profile(_模块_项目合同[4])
    }
    定义 _M8配置 = 目标_获取()
    如果 (_M8配置 != 空) {
        模块图_打印详细(字符串拼接("[M8] 目标三元组: ", 三元组_描述(_m8_三元组)))
        模块图_打印详细(字符串拼接("[M8] 指针宽度=", 字符串拼接(转字符串(目标_指针宽度(_M8配置)), 字符串拼接(" 栈对齐=", 字符串拼接(转字符串(目标_栈对齐(_M8配置)), 字符串拼接(" 参数寄存器=", 转字符串(目标_参数寄存器数(_M8配置))))))))
        模块图_打印详细(字符串拼接("[M8] ELF机器号=", 字符串拼接(转字符串(目标_ELF机器号(三元组_架构(_m8_三元组))), 字符串拼接(" syscall=", 目标_syscall指令(三元组_架构(_m8_三元组))))))
    }
    模块图_打印详细(字符串拼接("[ABI] ", 字符串拼接(目标_名称(), 字符串拼接(" cc=", 目标_调用约定名()))))

    缓存_初始化(0)
    模块图_打印详细("模块_自举: cache init ok")
    模块图_打印详细("[增量缓存] 就绪")

    // 阶段0.5: 运行时能力配置 (P5: 热更新/JIT/GC按profile门控)
    定义 可变 _rt_jit门控 = 2      // 默认: 标准JIT
    定义 可变 _rt_热更允许 = 0     // 默认: 禁止
    定义 可变 _rt_gc策略 = "分代"  // 默认: 分代GC
    如果 (_模块_项目合同 != 空 且 是列表(_模块_项目合同) 且 计数(_模块_项目合同) >= 5) {
        定义 _运行时配置 = _模块_项目合同[4]
        如果 (字符串相等(_运行时配置, "analysis-host")) {
            _rt_jit门控 = 3       // 最大化JIT(分析模式需要快速迭代)
            _rt_热更允许 = 0      // 分析模式不热更
            _rt_gc策略 = "关闭"   // 分析模式: 短生命周期,不需GC
        }
        如果 (字符串相等(_运行时配置, "linux-user")) {
            _rt_jit门控 = 2       // 标准JIT
            _rt_热更允许 = 1      // 白名单热更
            _rt_gc策略 = "分代"   // 分代GC
        }
        如果 (字符串相等(_运行时配置, "kernel-qemu")) {
            _rt_jit门控 = 1       // 白名单JIT(内核谨慎)
            _rt_热更允许 = 1      // 白名单热更(内核模块热插拔)
            _rt_gc策略 = "手动"   // 内核: 手动内存管理
        }
        如果 (字符串相等(_运行时配置, "kernel-physical")) {
            _rt_jit门控 = 0       // 禁止JIT(物理硬件稳定性优先)
            _rt_热更允许 = 1      // 白名单热更(允许OTA)
            _rt_gc策略 = "手动"   // 内核: 手动内存管理
        }
        模块图_打印详细(字符串拼接("[运行时] JIT门控=", 字符串拼接(转字符串(_rt_jit门控), 字符串拼接(" 热更=", 字符串拼接(转字符串(_rt_热更允许), 字符串拼接(" GC=", _rt_gc策略))))))
    }

    // M9: 冷启动内存基线
    内存基准_标记冷启动()

    // 阶段1: 扫描发现所有模块
    定义 模块数 = 模块_扫描项目(规范项目根)
    模块图_打印详细(字符串拼接("[扫描] 发现 ", 字符串拼接(转字符串(模块数), " 个模块")))

    // 阶段1.1: 批量推断模块标签 (AI原生/启动/可热更/内核态/记忆层)
    模块_批量推断标签()

    // 阶段1.5: 恢复缓存到模块表 (跨会话命中闭环)
    定义 缓存命中 = 缓存_恢复模块状态(模块表, 模块索引)
    如果 (缓存命中 > 0) {
        模块图_打印详细(字符串拼接("[缓存] 命中 ", 字符串拼接(转字符串(缓存命中), " 个模块 (跳过重编)")))
    }

    // 阶段2: 自动注册接口契约
    定义 新注册 = 契约_自动发现(规范项目根)
    模块图_打印详细(字符串拼接("[契约] ", 字符串拼接(转字符串(新注册), " 个新模块注册契约")))

    // 阶段2.5: 循环依赖检测 (独立Kahn BFS)
    定义 循环结果 = 模块图_循环检测()
    如果 (循环结果[0]) {
        模块图_打印详细("[循环检测] 存在循环依赖, 拓扑排序将自动容忍")
    }
    模块图_阶段标记("自举/循环检测后", "<bootstrap>")

    // 阶段3: 拓扑排序
    模块图_阶段标记("自举/拓扑前", "<bootstrap>")
    模块_拓扑排序(0)
    定义 顺序 = 编译顺序
    模块图_阶段标记("自举/拓扑后", "<bootstrap>")
    模块图_打印详细(字符串拼接("[拓扑] 编译顺序: ", 转字符串(计数(顺序))))

    // 阶段4: 编译层级（直接使用拓扑排序顺序）
    模块图_打印详细(字符串拼接("[诊断] 拓扑排序数=", 转字符串(计数(顺序))))
    定义 层级 = 顺序

    // 阶段4.5: 全局变量预注册 (扫描全部模块顶层定义)
    模块图_阶段标记("自举/预注册前", "<bootstrap>")
    全局变量表 = 字典()
    全局变量数 = 0
    定义 可变 预注册i = 0
    定义 可变 _预注册_跳过数 = 0
    定义 可变 _预注册_读失败 = 0
    定义 可变 _预注册_词失败 = 0
    _进度_阶段 = "预注册"
    _进度_总数 = 计数(顺序)
    _进度_当前 = 0
    _打印行(字符串拼接("\n  ─── 预注册阶段 ─── 扫描 ", 字符串拼接(转字符串(计数(顺序)), " 个模块的全局变量...")))
    当 (预注册i < 计数(顺序)) {
        定义 预注册名 = 顺序[预注册i]
        模块图_阶段标记("预注册/模块前", 预注册名)
        _进度_显示预注册(预注册i + 1, 计数(顺序))
        如果 (!字典有(模块索引, 预注册名)) { _预注册_跳过数 = _预注册_跳过数 + 1  预注册i = 预注册i + 1  继续 }
        定义 预注册位置 = 字典取(模块索引, 预注册名)
        定义 预注册信息 = 模块表[预注册位置]
        模块图_阶段标记("预注册/读前", 预注册名)
        定义 预注册源码 = 读文件(预注册信息.路径)
        模块图_阶段标记("预注册/读后", 预注册名)
        如果 (预注册源码 == 空 或 计数(预注册源码) == 0) { _预注册_读失败 = _预注册_读失败 + 1  预注册i = 预注册i + 1  继续 }
        词法引擎_全局重置()
        语法引擎_全局重置()
        行号追踪_全局重置()
        位置_注册文件(预注册信息.路径)
        模块图_清空列表(词行号)
        模块图_阶段标记("预注册/词法前", 预注册名)
        定义 预注册词表 = 前端_词法分析(预注册源码)
        模块图_阶段标记("预注册/词法后", 预注册名)
        如果 (预注册词表 != 空 且 计数(预注册词表) > 0) {
            模块图_清空列表(匿名函数列)
            模块图_阶段标记("预注册/解析前", 预注册名)
            定义 预注册程序 = 前端_解析_程序(预注册词表)
            模块图_阶段标记("预注册/解析后", 预注册名)
            如果 (是列表(预注册程序) == 假 或 计数(预注册程序) < 2) {
                _预注册_词失败 = _预注册_词失败 + 1
                预注册i = 预注册i + 1
                继续
            }
            定义 预注册主体 = 预注册程序[1]
            模块图_阶段标记("预注册/变量扫描前", 预注册名)
            定义 可变 预注册si = 0
            当 (预注册si < 计数(预注册主体)) {
                如果 (是列表(预注册主体[预注册si]) 且 计数(预注册主体[预注册si]) >= 2 且 预注册主体[预注册si][0] == 节_定义) {
                    定义 预注册变量名 = 预注册主体[预注册si][1]
                    如果 (字典取(全局变量表, 预注册变量名) == 空) {
                        字典设(全局变量表, 预注册变量名, 全局变量数 + 1)
                        全局变量数 = 全局变量数 + 1
                    }
                }
                预注册si = 预注册si + 1
            }
            模块图_阶段标记("预注册/变量扫描后", 预注册名)
        }
        模块图_阶段标记("预注册/模块后", 预注册名)
        预注册i = 预注册i + 1
    }
    模块图_阶段标记("自举/预注册后", "<bootstrap>")
    模块图_打印详细(字符串拼接("[预注册] 全局变量: ", 字符串拼接(转字符串(全局变量数), 字符串拼接(" 跳过=", 字符串拼接(转字符串(_预注册_跳过数), 字符串拼接(" 读失败=", 转字符串(_预注册_读失败)))))))

    // 阶段5: 编译所有模块
    模块图_打印详细(字符串拼接("[诊断] 预注册完成 全局变量数=", 转字符串(全局变量数)))
    _进度_阶段 = "编译"
    _进度_总数 = 计数(层级)
    _进度_当前 = 0
    _进度_成功 = 0
    _进度_失败 = 0
    _进度_跳过 = 0
    _进度_警告 = 0
    _进度_解析错误 = 0
    _进度_语义错误 = 0
    _进度_能力违规 = 0
    _进度_错误列表 = []
    _打印行(字符串拼接("\n  ─── 编译阶段 ─── 开始编译 ", 字符串拼接(转字符串(_进度_总数), " 个模块...")))
    // P1: 效果/能力系统一次性初始化 (原先每模块重复调用)
    效果_初始化默认profile()
    能力_初始化默认profile()
    定义 可变 手动统计 = [0]
    模块图_阶段标记("自举/手动编译前", "<bootstrap>")
    _模块_手动编译_遍历(层级, 0, 手动统计)
    模块图_阶段标记("自举/手动编译后", "<bootstrap>")
    定义 编译结果 = 手动统计[0]
    如果 (编译结果 == 0 且 计数(模块表) > 0) {
        // 检查是否全部跳过(缓存命中)
        如果 (模块图详细模式[0]) { 打印("[编译] 全部命中缓存, 无需重编") }
    }

    // 检查是否有编译失败
    定义 可变 失败数 = 0
    定义 可变 已编译数 = 0
    定义 可变 有码段数 = 0
    定义 可变 ci = 0
    当 (ci < 计数(模块表)) {
        如果 (模块表[ci].编译状态 == 2) { 已编译数 = 已编译数 + 1 }
        如果 (模块表[ci].编译状态 == 3) { 失败数 = 失败数 + 1 }
        如果 (模块表[ci].目标码 != 空 且 模块表[ci].目标码大小 > 0) { 有码段数 = 有码段数 + 1 }
        ci = ci + 1
    }
    _进度_汇总(计数(模块表), _进度_成功, _进度_失败, _进度_跳过, _进度_警告, 失败数)
    打印文本(字符串拼接("[自举诊断] 已编译=", 字符串拼接(转字符串(已编译数), 字符串拼接(" 失败=", 字符串拼接(转字符串(失败数), 字符串拼接(" 有码段=", 转字符串(有码段数)))))))
    模块图_打印详细(字符串拼接("[诊断] 已编译模块数=", 转字符串(已编译数)))
    // 标签统计 + 依赖统计 + 优化管线报告 (详细模式输出)
    如果 (模块图详细模式[0]) {
        定义 _标签统 = 模块_标签统计()
        打印文本(字符串拼接("[标签统计] AI=", 字符串拼接(转字符串(_标签统[0]), 字符串拼接(" 启动=", 字符串拼接(转字符串(_标签统[1]), 字符串拼接(" 可热更=", 字符串拼接(转字符串(_标签统[2]), 字符串拼接(" 内核态=", 字符串拼接(转字符串(_标签统[3]), 字符串拼接(" 记忆=", 转字符串(_标签统[4])))))))))))
        定义 _依赖统 = 模块_统计依赖()
        打印文本(字符串拼接("[依赖统计] 总边=", 字符串拼接(转字符串(_依赖统[0]), 字符串拼接(" 有依赖=", 字符串拼接(转字符串(_依赖统[1]), 字符串拼接(" 最大依赖=", 字符串拼接(转字符串(_依赖统[2]), 字符串拼接(" by ", _依赖统[3]))))))))
        优化管线_打印结构化报告()
    }
    如果 (失败数 > 0) {
        打印文本(字符串拼接("\n编译失败: ", 字符串拼接(转字符串(失败数), 字符串拼接(" 个模块有错误 (共 ", 字符串拼接(转字符串(计数(模块表)), " 个模块)")))))
        定义 可变 _fi = 0
        当 (_fi < 计数(模块表)) {
            如果 (模块表[_fi].编译状态 == 3) {
                打印文本(字符串拼接("  ✗ ", 模块表[_fi].路径))
            }
            _fi = _fi + 1
        }
        返回 假
    }

    // M9: 编译后内存采集
    内存基准_自动采集()

    // 阶段6: 链接为可执行文件
    _进度_阶段 = "链接"
    _打印行(字符串拼接("\n  ─── 链接阶段 ─── 目标: ", 输出路径))
    _进度_心跳("链接中...")
    模块入口模块名 = 模块_推断入口模块(规范项目根)
    模块图_打印详细(字符串拼接("[链接] 目标: ", 输出路径))
    定义 链接成功 = 模块_链接全部(输出路径)
    如果 (!链接成功) {
        打印("自举失败: 链接错误")
        返回 假
    }

    // 阶段7: 持久化缓存 + 统计
    缓存_保存manifest()
    如果 (模块图详细模式[0]) { 缓存_统计() }

    // 阶段8: 流水线统计报告 (P2纳入权威主路径)
    流水线_记录编译()
    流水线_记录优化(已编译数)
    如果 (模块图详细模式[0]) {
        定义 _管线统计 = 流水线_总统计()
        打印文本(字符串拼接("  [流水线] 编译次数=", 字符串拼接(转字符串(_管线统计[0]), 字符串拼接(" 优化轮次=", 转字符串(_管线统计[1])))))
        内存profile_打印报告()
        效果_打印报告()
        能力_打印报告()
        定义 _ai统计 = AI后端_统计报告()
        打印文本(字符串拼接("[AI后端] SIMD=", 字符串拼接(字典取(_ai统计, "SIMD发射"), 字符串拼接(" 低比特=", 字符串拼接(字典取(_ai统计, "低比特发射"), 字符串拼接(" GQA=", 字符串拼接(字典取(_ai统计, "GQA发射"), 字符串拼接(" 裸机=", 字典取(_ai统计, "裸机目标")))))))))
    }

    模块图_打印详细("═══ 自举完成 ═══")
    返回 真
}

// §11 自举验证 (二进制对比)

函数 模块图编_自举_验证(编译器A路径, 编译器B路径) {
    // 用A编译源码→产物X, 用B编译源码→产物Y
    // 对比X和Y的字节一致性 → 一致=自举成功
    定义 数据A = 读文件(编译器A路径)
    定义 数据B = 读文件(编译器B路径)
    如果 (数据A == 空 或 数据B == 空) {
        打印文本("验证失败: 无法读取编译器文件")
        返回 假
    }
    定义 大小A = 字节长度(数据A)
    定义 大小B = 字节长度(数据B)
    如果 (大小A != 大小B) {
        打印文本(字符串拼接("验证失败: 大小不同 (", 字符串拼接(转字符串(大小A), 字符串拼接(" vs ", 转字符串(大小B)))))
        返回 假
    }
    // 逐字节对比
    定义 可变 i = 0
    当 (i < 大小A) {
        如果 (字节取(数据A, i) != 字节取(数据B, i)) {
            打印文本(字符串拼接("验证失败: 偏移 ", 字符串拼接(转字符串(i), " 处不同")))
            返回 假
        }
        i = i + 1
    }
    打印文本(字符串拼接("验证成功: ", 字符串拼接(转字符串(大小A), " 字节完全一致")))
    返回 真
}

// §11.5 子进程执行 (自举Stage间调用)

// 双引号参数转义: " → \" , \ → \\ , ` → \` , $ → \$
函数 _系统执行_转义参数(参数) {
    定义 长度 = 字节长度(参数)
    如果 (长度 == 0) { 返回 参数 }
    // 快速路径: 无需转义的参数直接返回
    定义 可变 需转义 = 假
    定义 可变 i = 0
    当 (i < 长度) {
        定义 b = 字节取(参数, i)
        如果 (b == 标记_余 或 b == 标记_左花 或 b == 标记_逗号 或 b == 36) { 需转义 = 真  i = 长度 }
        i = i + 1
    }
    如果 (!需转义) { 返回 参数 }
    定义 可变 结果 = ""
    i = 0
    当 (i < 长度) {
        定义 b = 字节取(参数, i)
        如果 (b == 标记_余 或 b == 标记_左花 或 b == 标记_逗号 或 b == 36) {
            结果 = 字符串拼接(结果, 字符串拼接("\\", 字符(b)))
        } 否则 {
            结果 = 字符串拼接(结果, 字符(b))
        }
        i = i + 1
    }
    返回 结果
}

函数 系统执行(程序, 参数列表) {
    // 构建命令行: "程序 参1 参2 ..." (参数已转义防止注入)
    定义 可变 命令行 = "\"" + _系统执行_转义参数(程序) + "\""
    定义 可变 ai = 0
    当 (ai < 计数(参数列表)) {
        命令行 = 命令行 + " " + "\"" + _系统执行_转义参数(参数列表[ai]) + "\""
        ai = ai + 1
    }
    打印("[系统执行] " + 命令行)
    // 调用运行时提供的 __系统命令(0) 内建函数
    // 返回子进程退出码 (0=成功, 非0=失败)
    // Windows: 内部调用 CreateProcessA + WaitForSingleObject + GetExitCodeProcess
    // Linux:   内部调用 fork + execvp + waitpid
    定义 退出码 = __系统命令(命令行)
    打印("[系统执行] 退出码: " + 转字符串(退出码))
    返回 退出码
}

// §12 完整自举链 (Stage-0 → 验证)

函数 完整自举(项目根, 编译器路径) {
    打印("═══ Nova 完整分离式链式自举 ═══")
    打印("[Stage-0] Rust引导编译器 → Stage-1")

    // 编译器主源文件路径 (自举目标就是编译 Nova.nova 自身)
    定义 规范项目根 = 模块图_项目根目录(项目根)
    定义 编译器源 = 模块图_拼路径(规范项目根, "Nova.nova")
    定义 可变 stage1名 = 模块图_拼路径(规范项目根, "stage1_编译器")
    定义 可变 stage2名 = 模块图_拼路径(规范项目根, "stage2_编译器")
    定义 可变 stage3名 = 模块图_拼路径(规范项目根, "stage3_编译器")
    定义 可变 stage1程序 = 编译器路径
    定义 可变 stage2程序 = stage2名
    如果 (字符串相等(当前目标名称, "windows") 或 字符串相等(当前目标名称, "pe")) {
        stage1名 = 模块图_拼路径(规范项目根, "stage1_编译器.exe")
        stage2名 = 模块图_拼路径(规范项目根, "stage2_编译器.exe")
        stage3名 = 模块图_拼路径(规范项目根, "stage3_编译器.exe")
        stage2程序 = stage2名
    }
    打印("[自举目标] " + 编译器源)
    打印("[Stage-1 输出] " + stage1名)
    打印("[Stage-2 输出] " + stage2名)
    打印("[Stage-3 输出] " + stage3名)

    // Stage-1: 编译全部模块 → stage1编译器
    定义 s1成功 = 模块_自举(项目根, stage1名)
    如果 (!s1成功) {
        打印("Stage-1 失败")
        返回 假
    }
    如果 (!文件存在(stage1名)) {
        打印("Stage-1 失败: 未生成产物 " + stage1名)
        返回 假
    }
    打印("[Stage-1] 完成 → " + stage1名)

    // Stage-2: 用stage1编译器以模块图模式编译整个项目 → stage2编译器
    打印("[Stage-2] stage1 模块图编译 " + 项目根 + " → " + stage2名)
    定义 s2退出码 = 系统执行(stage1程序, [项目根, "--compile", "--module-graph", "--target", 当前目标名称, "-o", stage2名])
    如果 (s2退出码 != 0) {
        打印("Stage-2 失败: stage1编译器执行返回 " + 转字符串(s2退出码))
        返回 假
    }
    如果 (!文件存在(stage2名)) {
        打印("Stage-2 失败: 未生成产物 " + stage2名)
        返回 假
    }
    打印("[Stage-2] 完成 → " + stage2名)

    // Stage-3: 用stage2编译器以同样模块图模式编译 → stage3编译器
    打印("[Stage-3] stage2 模块图编译 " + 项目根 + " → " + stage3名)
    定义 s3退出码 = 系统执行(stage2程序, [项目根, "--compile", "--module-graph", "--target", 当前目标名称, "-o", stage3名])
    如果 (s3退出码 != 0) {
        打印("Stage-3 失败: stage2编译器执行返回 " + 转字符串(s3退出码))
        返回 假
    }
    如果 (!文件存在(stage3名)) {
        打印("Stage-3 失败: 未生成产物 " + stage3名)
        返回 假
    }
    打印("[Stage-3] 完成 → " + stage3名)

    // 验证: 对比 stage2 和 stage3 二进制一致性
    打印("[验证] 对比 stage2 与 stage3...")
    定义 验证结果 = 模块图编_自举_验证(stage2名, stage3名)
    如果 (验证结果) {
        打印("═══ 自举验证通过: 编译器可完美复制自身 ═══")
    } 否则 {
        打印("═══ 自举验证失败: stage2 与 stage3 不一致 ═══")
    }
    返回 验证结果
}

// FB013反哺: Kosaraju 算法 — 模块依赖循环检测
// 实验验证: Rust验证引擎证实Nova当前模块依赖循环=0
// 用途: 编译前检测，发现循环依赖立即报错并输出循环路径

// 迭代式后序DFS（显式栈, 替代原递归版防止442+模块栈溢出）
函数 _K_后序DFS_迭代(邻接表, 起始id, 已访问, 后序栈) {
    // 显式栈: [节点id, 邻居索引] 对
    定义 可变 dfs栈 = []
    定义 起始键 = 转字符串(起始id)
    如果 (字典取(已访问, 起始键) != 空) { 返回 空 }
    追加(dfs栈, [起始id, 0])
    字典设(已访问, 起始键, 真)
    当 (计数(dfs栈) > 0) {
        定义 栈顶 = dfs栈[计数(dfs栈) - 1]
        定义 当前id = 栈顶[0]
        定义 可变 邻居idx = 栈顶[1]
        定义 邻居 = 字典取(邻接表, 转字符串(当前id))
        定义 可变 推进 = 假
        如果 (邻居 != 空) {
            当 (邻居idx < 计数(邻居) 且 !推进) {
                定义 下一个 = 邻居[邻居idx]
                邻居idx = 邻居idx + 1
                栈顶[1] = 邻居idx
                定义 下一键 = 转字符串(下一个)
                如果 (字典取(已访问, 下一键) == 空) {
                    字典设(已访问, 下一键, 真)
                    追加(dfs栈, [下一个, 0])
                    推进 = 真
                }
            }
        }
        如果 (!推进) {
            // 所有邻居已遍历, 后序输出
            追加(后序栈, 当前id)
            删除(dfs栈, 计数(dfs栈) - 1)
        }
    }
}

// 迭代式反向DFS收集SCC（显式栈）
函数 _K_反向DFS_迭代(反向邻接表, 起始id, 已访问, 当前SCC) {
    定义 可变 dfs栈 = [起始id]
    定义 起始键 = 转字符串(起始id)
    如果 (字典取(已访问, 起始键) != 空) { 返回 空 }
    字典设(已访问, 起始键, 真)
    追加(当前SCC, 起始id)
    当 (计数(dfs栈) > 0) {
        定义 当前 = dfs栈[计数(dfs栈) - 1]
        删除(dfs栈, 计数(dfs栈) - 1)
        定义 邻居 = 字典取(反向邻接表, 转字符串(当前))
        如果 (邻居 != 空) {
            定义 可变 k = 0
            当 (k < 计数(邻居)) {
                定义 下一个 = 邻居[k]
                定义 下一键 = 转字符串(下一个)
                如果 (字典取(已访问, 下一键) == 空) {
                    字典设(已访问, 下一键, 真)
                    追加(当前SCC, 下一个)
                    追加(dfs栈, 下一个)
                }
                k = k + 1
            }
        }
    }
}

// Kosaraju SCC 完整迭代版入口
// 返回: [所有SCC列表, id到名映射]
函数 模块图_Kosaraju_SCC() {
    定义 模块数 = 计数(模块表)
    // 1. 构建名↔id映射
    定义 可变 名到id = 字典()
    定义 可变 id到名 = []
    定义 可变 i = 0
    当 (i < 模块数) {
        字典设(名到id, 模块表[i].名称, i)
        追加(id到名, 模块表[i].名称)
        i = i + 1
    }
    // 2. 构建正向+反向邻接表
    定义 可变 邻接表 = 字典()
    定义 可变 反向邻接表 = 字典()
    i = 0
    当 (i < 模块数) {
        定义 可变 依赖组 = 模块表[i].依赖列表
        如果 (依赖组 == 空) { 依赖组 = [] }
        定义 可变 邻居ids = []
        定义 可变 j = 0
        当 (j < 计数(依赖组)) {
            定义 依赖号 = 字典取(名到id, 依赖组[j])
            如果 (依赖号 != 空) {
                追加(邻居ids, 依赖号)
                定义 反键 = 转字符串(依赖号)
                如果 (字典取(反向邻接表, 反键) == 空) {
                    字典设(反向邻接表, 反键, [])
                }
                追加(字典取(反向邻接表, 反键), i)
            }
            j = j + 1
        }
        字典设(邻接表, 转字符串(i), 邻居ids)
        i = i + 1
    }
    // 3. 第一遍DFS: 后序遍历（迭代式）
    定义 可变 已访问1 = 字典()
    定义 可变 后序栈 = []
    i = 0
    当 (i < 模块数) {
        _K_后序DFS_迭代(邻接表, i, 已访问1, 后序栈)
        i = i + 1
    }
    // 4. 第二遍DFS: 按逆后序在反向图上收集SCC（迭代式）
    定义 可变 已访问2 = 字典()
    定义 可变 所有SCC = []
    i = 计数(后序栈) - 1
    当 (i >= 0) {
        定义 v = 后序栈[i]
        如果 (字典取(已访问2, 转字符串(v)) == 空) {
            定义 可变 当前SCC = []
            _K_反向DFS_迭代(反向邻接表, v, 已访问2, 当前SCC)
            追加(所有SCC, 当前SCC)
        }
        i = i - 1
    }
    返回 [所有SCC, id到名]
}

// 主函数: 检测模块表中的循环依赖
// 返回: [有循环, 循环模块名列表]
// 注意: 独立计算入度, 不调用 模块_拓扑排序 (后者会追加环中模块导致检测失真)
函数 模块图_循环检测() {
    定义 模块数 = 计数(模块表)
    如果 (模块数 == 0) { 返回 [假, []] }

    // 独立计算入度 + 反向邻接表 (不修改全局 编译顺序)
    定义 可变 入度 = 字典()
    定义 可变 被依赖者 = 字典()
    定义 可变 i = 0
    当 (i < 模块数) {
        字典设(入度,  模块表[i].名称, 0)
        i = i + 1
    }
    i = 0
    当 (i < 模块数) {
        定义 当前名 = 模块表[i].名称
        定义 依赖列表 = 模块表[i].依赖列表
        如果 (是列表(依赖列表) == 假) { 依赖列表 = [] }
        定义 可变 j = 0
        当 (j < 计数(依赖列表)) {
            定义 依赖 = 依赖列表[j]
            如果 (字典有(入度, 依赖)) {
                字典设(入度, 当前名, 字典取(入度, 当前名) + 1)
                定义 反列 = 字典取(被依赖者, 依赖)
                如果 (反列 == 空) { 反列 = []  字典设(被依赖者, 依赖, 反列) }
                追加(反列, 当前名)
            }
            j = j + 1
        }
        i = i + 1
    }

    // Kahn BFS — 反向邻接表加速, O(V+E)
    定义 可变 队列 = []
    i = 0
    当 (i < 模块数) {
        如果 (字典取(入度, 模块表[i].名称) == 0) {
            追加(队列, 模块表[i].名称)
        }
        i = i + 1
    }
    定义 可变 已处理数 = 0
    定义 可变 qi = 0
    当 (qi < 计数(队列)) {
        定义 当前 = 队列[qi]
        已处理数 = 已处理数 + 1
        定义 依赖者列表 = 字典取(被依赖者, 当前)
        如果 (依赖者列表 != 空 且 是列表(依赖者列表)) {
            定义 可变 k = 0
            当 (k < 计数(依赖者列表)) {
                定义 名 = 依赖者列表[k]
                字典设(入度, 名, 字典取(入度, 名) - 1)
                如果 (字典取(入度, 名) == 0) {
                    追加(队列, 名)
                }
                k = k + 1
            }
        }
        qi = qi + 1
    }

    如果 (已处理数 >= 模块数) {
        模块图_打印详细("[OK] 模块依赖图无循环 (拓扑验证)")
        返回 [假, []]
    }

    // 使用 Kosaraju SCC 精确分解循环分组
    定义 scc结果 = 模块图_Kosaraju_SCC()
    定义 所有SCC = scc结果[0]
    定义 id到名 = scc结果[1]
    定义 可变 循环模块 = []
    定义 可变 循环组数 = 0
    定义 可变 si = 0
    当 (si < 计数(所有SCC)) {
        定义 当前SCC = 所有SCC[si]
        如果 (计数(当前SCC) > 1) {
            循环组数 = 循环组数 + 1
            // 输出每组循环的具体模块
            定义 可变 组摘要 = ""
            定义 可变 ki = 0
            定义 组上限 = 5
            当 (ki < 计数(当前SCC) 且 ki < 组上限) {
                如果 (ki > 0) { 组摘要 = 字符串拼接(组摘要, " → ") }
                如果 (当前SCC[ki] < 计数(id到名)) {
                    组摘要 = 字符串拼接(组摘要, id到名[当前SCC[ki]])
                }
                ki = ki + 1
            }
            如果 (计数(当前SCC) > 组上限) {
                组摘要 = 字符串拼接(组摘要, 字符串拼接(" ... 等", 字符串拼接(转字符串(计数(当前SCC) - 组上限), "个")))
            }
            模块图_打印详细(字符串拼接("[循环组", 字符串拼接(转字符串(循环组数), 字符串拼接("] ", 字符串拼接(转字符串(计数(当前SCC)), 字符串拼接("个模块: ", 组摘要))))))
            // 收集到循环模块列表
            ki = 0
            当 (ki < 计数(当前SCC)) {
                如果 (当前SCC[ki] < 计数(id到名)) {
                    追加(循环模块, id到名[当前SCC[ki]])
                }
                ki = ki + 1
            }
        }
        si = si + 1
    }

    模块图_打印详细(字符串拼接("[信息] 模块循环依赖已容忍 (", 字符串拼接(转字符串(计数(循环模块)), 字符串拼接("个模块,  ", 字符串拼接(转字符串(循环组数), "个循环组)")))))
    返回 [真, 循环模块]
}

// [Nova实验室反哺] 快排优化版
// 实验结论: O(n²)嵌套排序 → O(nlogn)快速排序，n=100时速度13×
// 已在标准库/基础.nova中实现 基础_快速排序(列表, 低, 高)
// 快排已反哺 — 可调用 基础_快速排序 替代本函数
