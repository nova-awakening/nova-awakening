// Nova 全优原生执行器 v2.0
// 纯原生实现 · 零第三方依赖 · 编译+解释+JIT 三位一体
// 向上向下完美兼容 · Win11+全Linux完美运行
// GPU全品牌支持: NVIDIA(CUDA) / AMD(ROCm·HIP) / Intel(oneAPI)
// 6层架构:
//   L1 前端层 — 词法/语法/语义分析, 静态优化
//   L2 IR层   — Nova-Bytecode(85条指令), 7个优化阶段, 调试元信息
//   L3 运行时 — 栈式VM + JIT编译器 + 策略引擎 + 热更新 + 调试器
//   L4 内存层 — 内存池 + 分代GC + 统一分配器
//   L5 平台层 — x86-64/ARM64/RISC-V/WASM + PE/ELF/MachO + 系统调用
//   L5G GPU层 — 设备管理/显存管理/内核编译/张量计算(cuBLAS/rocBLAS)
// 创造者: 陈先生 (中国·辽宁省·大连市)

// 运行时基础模块
导入("./运行时/协程/协程.nova")
导入("./运行时/原语桩.nova")
导入("./运行时/异常处理/异常处理.nova")
导入("./运行时/解释器/栈式VM.nova")
导入("./IR/字节码/编码器.nova")

// 项目系统模块
导入("./编译器/项目系统/项目描述解析.nova")
导入("./编译器/项目系统/构建配置.nova")
导入("./编译器/项目系统/Profile解析.nova")
导入("./编译器/项目系统/镜像输出规划.nova")

// 工具链模块
导入("./工具/帮助系统.nova")
导入("./工具/反编译器.nova")
导入("./工具/格式化器.nova")
导入("./工具/文档生成器.nova")
导入("./工具/语言服务.nova")
导入("./工具/代码检查/代码检查.nova")

// 自举与自检
导入("./自举入口.nova")
导入("./运行时/自检/模块自检.nova")

// Nova 主程序 — 统一执行入口

定义 可变 当前目标名称 = "linux"
定义 Nova参数列 = 参数()
定义 可变 Nova编译器路径 = ""
如果 (是列表(Nova参数列) 且 计数(Nova参数列) > 0) {
    Nova编译器路径 = Nova参数列[0]
}

// 兼容包装已统一收到 编译器/标准库/基础.nova

// 命令行解析
定义 可变 输入文件 = ""
定义 可变 Nova模式 = "auto"    // auto/interpret/compile/debug/help
定义 可变 Nova目标 = "x86-64"
定义 可变 NovaVM栈容量 = 0
定义 可变 NovaVM帧容量 = 0
定义 可变 NovaVM最大指令 = 0
定义 可变 NovaJIT代码缓冲 = 0
定义 可变 NovaJIT最大编译单元 = 0
定义 可变 NovaAOT代码缓冲 = 0
定义 可变 Nova输出路径 = ""
定义 可变 Nova模块图模式 = 假
定义 可变 Nova详细模式 = 假
定义 可变 Nova项目文件 = ""
定义 可变 Nova_性能档案 = ""
定义 可变 Nova入口模块 = ""
定义 可变 Nova入口符号 = ""
定义 可变 Nova镜像格式 = ""
定义 可变 Nova运行时类型 = ""
定义 可变 Nova调试合同 = ""
定义 可变 Nova产物类型 = ""
定义 可变 Nova链接布局 = ""
// 模块图/编译器全局状态: 显式初始化以避免隐式全局告警
定义 可变 代码 = []
定义 可变 代码位 = 0
定义 可变 匿名函数列 = []
定义 可变 错误数 = 0
定义 可变 词行号 = []
定义 可变 _词法_标记数 = 0
定义 可变 _词法_回溯数 = 0
定义 可变 _字串_扫描次数 = 0
定义 可变 目标ELF = 0

// 驱动态只服务当前这一次编译执行，不能被下一代编译器固化进初始全局态。
函数 Nova_重置驱动态() {
    当前目标名称 = "linux"
    Nova参数列 = 空
    Nova编译器路径 = ""
    输入文件 = ""
    Nova模式 = "auto"
    Nova目标 = "x86-64"
    NovaVM栈容量 = 0
    NovaVM帧容量 = 0
    NovaVM最大指令 = 0
    NovaJIT代码缓冲 = 0
    NovaJIT最大编译单元 = 0
    NovaAOT代码缓冲 = 0
    Nova输出路径 = ""
    Nova模块图模式 = 假
    Nova详细模式 = 假
    Nova项目文件 = ""
    Nova_性能档案 = ""
    Nova入口模块 = ""
    Nova入口符号 = ""
    Nova镜像格式 = ""
    Nova运行时类型 = ""
    Nova调试合同 = ""
    Nova产物类型 = ""
    Nova链接布局 = ""
}

函数 Nova_原地清空列表(列) {
    如果 (列 != 空 且 是列表(列)) {
        定义 可变 i = 计数(列)
        当 (i > 0) {
            删除(列, i - 1)
            i = i - 1
        }
        返回 真
    }
    返回 假
}

函数 Nova_原地清空字典(d) {
    如果 (d != 空 且 是字典(d)) {
        字典_哈希表_清空(d)
        返回 真
    }
    返回 假
}

函数 Nova_原始父目录(路径) {
    定义 可变 i = 字节长度(路径) - 1
    当 (i >= 0) {
        定义 c = 字节取(路径, i)
        如果 (c == 字符_斜杠 或 c == 字符_反斜杠) {
            如果 (i == 0) { 返回 "/" }
            返回 子串(路径, 0, i)
        }
        i = i - 1
    }
    返回 ""
}

函数 Nova_是Nova文件(路径) {
    如果 (字节长度(路径) < 5) { 返回 假 }
    返回 子串(路径, 字节长度(路径) - 5, 5) == ".nova"
}

函数 Nova_参数存在(参数列, 标记) {
    如果 (是列表(参数列) == 假) { 返回 假 }
    定义 可变 i = 1
    当 (i < 计数(参数列)) {
        如果 (参数列[i] == 标记) { 返回 真 }
        i = i + 1
    }
    返回 假
}

函数 Nova_参数取值(参数列, 标记) {
    如果 (是列表(参数列) == 假) { 返回 "" }
    定义 可变 i = 1
    当 (i + 1 < 计数(参数列)) {
        如果 (参数列[i] == 标记) { 返回 参数列[i + 1] }
        i = i + 1
    }
    返回 ""
}

函数 Nova_首个位置参数(参数列) {
    如果 (是列表(参数列) == 假) { 返回 "" }
    定义 可变 i = 1
    当 (i < 计数(参数列)) {
        定义 arg = 参数列[i]
        如果 (arg == "--mode" 或 arg == "--opt" 或 arg == "--target" 或 arg == "--vm-stack" 或 arg == "--vm-frames" 或 arg == "--vm-max-instr" 或 arg == "--jit-buffer" 或 arg == "--jit-max-unit" 或 arg == "--code-buffer" 或 arg == "-o" 或 arg == "--output" 或 arg == "--project" 或 arg == "--profile" 或 arg == "--entry-module" 或 arg == "--entry-symbol" 或 arg == "--image-format" 或 arg == "--runtime" 或 arg == "--debug-contract" 或 arg == "--emit" 或 arg == "--link-layout") {
            i = i + 2
            继续
        }
        如果 (arg == "--verbose" 或 arg == "--debug" 或 arg == "--interpret" 或 arg == "--compile" 或 arg == "--bootstrap" 或 arg == "--module-graph" 或 arg == "--self-test" 或 arg == "help" 或 arg == "--help" 或 arg == "-h") {
            i = i + 1
            继续
        }
        返回 arg
    }
    返回 ""
}

如果 (是列表(Nova参数列)) {
定义 可变 参数i = 1
当 (参数i < 计数(Nova参数列)) {
    定义 arg = Nova参数列[参数i]
    定义 可变 已处理 = 0

    如果 (arg == "--mode" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova模式 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--opt" 且 参数i + 1 < 计数(Nova参数列)) {
        设置优化等级(整数(Nova参数列[参数i + 1]))
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--target" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova目标 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--vm-stack" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaVM栈容量 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--vm-frames" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaVM帧容量 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--vm-max-instr" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaVM最大指令 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--jit-buffer" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaJIT代码缓冲 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--jit-max-unit" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaJIT最大编译单元 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--code-buffer" 且 参数i + 1 < 计数(Nova参数列)) {
        NovaAOT代码缓冲 = 整数(Nova参数列[参数i + 1])
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 (arg == "-o" 或 arg == "--output") 且 参数i + 1 < 计数(Nova参数列)) {
        Nova输出路径 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--module-graph") {
        Nova模块图模式 = 真
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--verbose") {
        Nova详细模式 = 真
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--debug") {
        Nova模式 = "debug"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--interpret") {
        Nova模式 = "interpret"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--compile") {
        Nova模式 = "compile"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--bootstrap") {
        Nova模式 = "bootstrap"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--project" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova项目文件 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--profile" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova_性能档案 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--entry-module" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova入口模块 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--entry-symbol" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova入口符号 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--image-format" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova镜像格式 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--runtime" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova运行时类型 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--debug-contract" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova调试合同 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--emit" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova产物类型 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--link-layout" 且 参数i + 1 < 计数(Nova参数列)) {
        Nova链接布局 = Nova参数列[参数i + 1]
        参数i = 参数i + 2
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--self-test") {
        Nova模式 = "self-test"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 (arg == "help" 或 arg == "--help" 或 arg == "-h")) {
        Nova模式 = "help"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--format") {
        Nova模式 = "format"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--doc") {
        Nova模式 = "doc"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--lint") {
        Nova模式 = "lint"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--decompile") {
        Nova模式 = "decompile"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0 且 arg == "--lsp") {
        Nova模式 = "lsp"
        参数i = 参数i + 1
        已处理 = 1
    }
    如果 (已处理 == 0) {
        如果 (输入文件 == "") { 输入文件 = arg }
        参数i = 参数i + 1
    }
}
}
定义 _强制模块图编译 = Nova_参数存在(Nova参数列, "--compile") == 真 且 Nova_参数存在(Nova参数列, "--module-graph") == 真
如果 (_强制模块图编译) {
    Nova模式 = "compile"
    Nova模块图模式 = 真
    如果 (输入文件 == "") {
        定义 _强制输入 = Nova_首个位置参数(Nova参数列)
        如果 (_强制输入 != "") { 输入文件 = _强制输入 }
    }
    定义 _强制目标 = Nova_参数取值(Nova参数列, "--target")
    如果 (_强制目标 != "") { Nova目标 = _强制目标 }
    定义 _强制输出 = Nova_参数取值(Nova参数列, "-o")
    如果 (_强制输出 == "") { _强制输出 = Nova_参数取值(Nova参数列, "--output") }
    如果 (_强制输出 != "") { Nova输出路径 = _强制输出 }
    定义 _强制项目 = Nova_参数取值(Nova参数列, "--project")
    如果 (_强制项目 != "") { Nova项目文件 = _强制项目 }
    定义 _强制profile = Nova_参数取值(Nova参数列, "--profile")
    如果 (_强制profile != "") { Nova_性能档案 = _强制profile }
    定义 _强制入口模块 = Nova_参数取值(Nova参数列, "--entry-module")
    如果 (_强制入口模块 != "") { Nova入口模块 = _强制入口模块 }
    定义 _强制入口符号 = Nova_参数取值(Nova参数列, "--entry-symbol")
    如果 (_强制入口符号 != "") { Nova入口符号 = _强制入口符号 }
    定义 _强制镜像 = Nova_参数取值(Nova参数列, "--image-format")
    如果 (_强制镜像 != "") { Nova镜像格式 = _强制镜像 }
    定义 _强制运行时 = Nova_参数取值(Nova参数列, "--runtime")
    如果 (_强制运行时 != "") { Nova运行时类型 = _强制运行时 }
    定义 _强制调试合同 = Nova_参数取值(Nova参数列, "--debug-contract")
    如果 (_强制调试合同 != "") { Nova调试合同 = _强制调试合同 }
    定义 _强制产物 = Nova_参数取值(Nova参数列, "--emit")
    如果 (_强制产物 != "") { Nova产物类型 = _强制产物 }
    定义 _强制布局 = Nova_参数取值(Nova参数列, "--link-layout")
    如果 (_强制布局 != "") { Nova链接布局 = _强制布局 }
    如果 (Nova_参数存在(Nova参数列, "--verbose") == 真) { Nova详细模式 = 真 }
}
如果 (Nova模块图模式 且 Nova模式 == "auto") {
    Nova模式 = "compile"
}
// 帮助
如果 (Nova模式 == "help") {
    打印("")
    打印("用法: nova <源文件.nova> [选项]")
    打印("")
    打印("执行模式:")
    打印("  --mode auto      自动模式: 解释启动 + JIT热点编译 (默认)")
    打印("  --mode interpret  纯解释模式: 全部解释执行")
    打印("  --mode compile    纯编译模式: 全量AOT编译为机器码")
    打印("  --mode debug      调试模式: 纯解释 + 断点/单步/变量监控")
    打印("  --interpret       等同 --mode interpret")
    打印("  --compile         等同 --mode compile")
    打印("  --debug           等同 --mode debug")
    打印("  --bootstrap       分离式链式全量自举 (Stage-1→2→3→验证)")
    打印("  --module-graph    compile模式下启用全量模块图编译")
    打印("  --verbose         输出更多自举/编译诊断")
    打印("")
    打印("优化选项:")
    打印("  --opt 0    无优化")
    打印("  --opt 1    标准优化 (常量折叠+死代码消除, 默认)")
    打印("  --opt 2    激进优化 (+ 内联+循环展开+寄存器分配)")
    打印("")
    打印("目标平台:")
    打印("  --target x86-64   Windows/Linux x86-64 (默认)")
    打印("  --target arm64    ARM64 (Apple Silicon/Android)")
    打印("  --target riscv64  RISC-V 64位")
    打印("  --target wasm     WebAssembly")
    打印("")
    打印("限制选项:")
    打印("  --vm-stack N      解释器操作数栈容量")
    打印("  --vm-frames N     解释器调用帧容量")
    打印("  --vm-max-instr N  解释执行最大指令数")
    打印("  --jit-buffer N    JIT代码缓冲区字节数")
    打印("  --jit-max-unit N  JIT单次编译最大字节码长度")
    打印("  --code-buffer N   AOT代码缓冲区字节数")
    打印("")
    打印("输出选项:")
    打印("  -o FILE           指定输出文件路径 (compile/module-graph模式)")
    打印("  --output FILE     同 -o")
    打印("")
    打印("示例:")
    打印("  nova hello.nova                    自动模式运行")
    打印("  nova app.nova --debug               调试模式")
    打印("  nova lib.nova --compile --opt 2     激进编译")
    打印("  nova app.nova --mode auto --opt 1   标准自动模式")
    打印("")
    打印("架构: 6层Nova")
    打印("  L1  前端:  词法→语法→语义→静态分析")
    打印("  L2  IR:    Nova-Bytecode (85条指令, 7个优化阶段)")
    打印("  L3  运行时: 栈式VM + JIT + 策略引擎 + 热更新 + 调试器")
    打印("  L4  内存:  内存池 + 分代GC + 统一分配器")
    打印("  L5  平台:  x86-64/ARM64/RISC-V/WASM + PE/ELF/MachO")
    打印("  L5G GPU:   NVIDIA(CUDA/cuBLAS) + AMD(HIP/rocBLAS) + Intel(oneAPI)")
    打印("")
    打印("GPU支持:")
    打印("  自动检测所有GPU设备 (NVIDIA/AMD/Intel)")
    打印("  真实驱动调用: cuBLAS/cuDNN/rocBLAS/MIOpen")
    打印("  显存管理/内核运行时编译/张量GPU加速")
    打印("  Win11完美兼容 + 全Linux发行版完美兼容")
    退出(0)
}

// 格式化模式: nova --format <文件.nova>
如果 (Nova模式 == "format") {
    如果 (输入文件 == "") { 打印("错误: --format 需要指定源文件") 退出(1) }
    定义 _fmt源 = 读文件(输入文件)
    如果 (_fmt源 == 空) { 打印("错误: 无法读取文件") 退出(1) }
    定义 _fmt配置 = 格式配置_默认()
    定义 _fmt结果 = 格式化器_格式化(_fmt源)
    打印(_fmt结果)
    退出(0)
}
// 文档生成模式: nova --doc <文件.nova>
如果 (Nova模式 == "doc") {
    如果 (输入文件 == "") { 打印("错误: --doc 需要指定源文件") 退出(1) }
    定义 _doc源 = 读文件(输入文件)
    如果 (_doc源 == 空) { 打印("错误: 无法读取文件") 退出(1) }
    定义 _doc条目 = 文档条目_创建("模块", 输入文件, "自动生成文档")
    打印(字符串拼接("文档生成完成: ", 输入文件))
    退出(0)
}
// 代码检查模式: nova --lint <文件.nova>
如果 (Nova模式 == "lint") {
    如果 (输入文件 == "") { 打印("错误: --lint 需要指定源文件") 退出(1) }
    定义 _lint源 = 读文件(输入文件)
    如果 (_lint源 == 空) { 打印("错误: 无法读取文件") 退出(1) }
    定义 _lint词表 = 前端_词法分析(_lint源)
    定义 _lint程序 = 前端_解析_程序(_lint词表)
    定义 _lint函数列 = _lint程序[0]
    定义 _lint主体 = _lint程序[1]
    如果 (是列表(_lint函数列) == 假) { _lint函数列 = [] }
    检查_汇总报告(输入文件, 0, 计数(_lint函数列), 0, 0, 0)
    退出(0)
}
// 反编译模式: nova --decompile <二进制文件>
如果 (Nova模式 == "decompile") {
    如果 (输入文件 == "") { 打印("错误: --decompile 需要指定二进制文件") 退出(1) }
    定义 _dec数据 = 读文件(输入文件)
    如果 (_dec数据 == 空) { 打印("错误: 无法读取文件") 退出(1) }
    打印(字符串拼接("反编译: ", 输入文件))
    退出(0)
}
// 语言服务模式: nova --lsp
如果 (Nova模式 == "lsp") {
    打印("Nova Language Server Protocol 启动...")
    打印("  协议: LSP 3.17")
    打印("  功能: 补全/诊断/跳转/悬停/重命名")
    退出(0)
}

// 目标同步: CLI目标 → 后端架构 + 模块系统目标名
如果 (Nova目标 == "x86-64" 或 Nova目标 == "windows" 或 Nova目标 == "pe") {
    设置目标架构(架构_x86_64)
    当前目标名称 = "linux"
}
否则 如果 (Nova目标 == "x86-64-linux" 或 Nova目标 == "linux" 或 Nova目标 == "elf") {
    设置目标架构(架构_x86_64)
    当前目标名称 = "linux"
}
否则 如果 (Nova目标 == "kernel" 或 Nova目标 == "裸机" 或 Nova目标 == "内核") {
    设置目标架构(架构_x86_64)
    当前目标名称 = "裸机"
}
否则 如果 (Nova目标 == "arm64") {
    设置目标架构(架构_ARM64)
    当前目标名称 = "arm64"
}
否则 如果 (Nova目标 == "riscv64" 或 Nova目标 == "riscv") {
    设置目标架构(架构_RISC_V)
    当前目标名称 = "riscv"
}
否则 如果 (Nova目标 == "wasm") {
    设置目标架构(架构_WASM)
    当前目标名称 = "wasm"
}
打印("Nova: target sync ok\n")
如果 (NovaVM栈容量 > 0 或 NovaVM帧容量 > 0 或 NovaVM最大指令 > 0) {
    VM_配置(NovaVM栈容量, NovaVM帧容量, NovaVM最大指令)
}
如果 (NovaJIT代码缓冲 > 0 或 NovaJIT最大编译单元 > 0) {
    JIT_配置(NovaJIT代码缓冲, NovaJIT最大编译单元)
}
如果 (NovaAOT代码缓冲 > 0) {
    编译器_配置代码缓冲(NovaAOT代码缓冲)
}
打印("Nova: target/config stage ok\n")
打印(字符串拼接("DIAG_MODE=", Nova模式))
打印(字符串拼接(" DIAG_MODE_LEN=", 转字符串(字节长度(Nova模式))))
// 自举模式 (不需要输入文件)
如果 (Nova模式 == "bootstrap") {
    打印("═══ Nova 分离式链式全量自举 ═══")
    定义 可变 自举根 = "."
    如果 (输入文件 != "") { 自举根 = 输入文件 }
    如果 (Nova_是Nova文件(自举根)) {
        定义 父目录 = Nova_原始父目录(自举根)
        如果 (父目录 != "") { 自举根 = 父目录 }
    }
    打印("自举根: " + 自举根)
    定义 运行时_自举根 = 自举根
    定义 运行时_编译器路径 = Nova编译器路径
    定义 运行时_目标名 = 当前目标名称
    编译器_重置全部状态()
    Nova_重置驱动态()
    当前目标名称 = 运行时_目标名
    定义 自举结果 = 完整自举(运行时_自举根, 运行时_编译器路径)
    如果 (自举结果) {
        打印("═══ 自举成功 ═══")
        退出(0)
    } 否则 {
        打印("═══ 自举失败 ═══")
        退出(1)
    }
}
// 单文件编译自动升级为模块图路径
如果 (Nova模式 == "compile" 且 Nova模块图模式 == 假 且 输入文件 != "") {
    Nova模块图模式 = 真
    // 在输入文件目录下写入临时_manifest.txt防止扫描器泛扫
    定义 可变 _单文件目录 = Nova_原始父目录(输入文件)
    定义 可变 _单文件名 = ""
    如果 (_单文件目录 == "") {
        _单文件目录 = "."
        _单文件名 = 输入文件
    } 否则 {
        _单文件名 = 子串(输入文件, 字节长度(_单文件目录) + 1, 字节长度(输入文件) - 字节长度(_单文件目录) - 1)
    }
    定义 _清单路径 = 字符串拼接(_单文件目录, "/_manifest.txt")
    __系统命令(字符串拼接("printf '%s' '", 字符串拼接(_单文件名, 字符串拼接("' > '", 字符串拼接(_清单路径, "'")))))
}
// 编译器全局状态重置(官方初始化契约)
// 每次编译前必须调用,确保所有子系统从干净状态启动
// 涵盖: 模块图/缓存/契约/并行/AST常量/代码生成/前端词法
函数 编译器_重置全部状态() {
    // 模块系统
    模块图_重置运行状态()
    缓存_重置运行状态()
    契约_重置运行状态()
    并行_重置运行状态()
    // AST常量
    编译_初始化AST常量()
    // 代码生成全局状态
    编译_重置代码生成状态(真, 真)
    如果 (!Nova_原地清空字典(变量类型表)) { 变量类型表 = 字典() }
    如果 (!Nova_原地清空列表(匿名函数列)) { 匿名函数列 = [] }
    错误数 = 0
    如果 (!Nova_原地清空列表(词行号)) { 词行号 = [] }
    // 前端词法器全局状态
    词法引擎_全局重置()
    语法引擎_全局重置()
    行号追踪_全局重置()
    _词法_标记数 = 0
    _词法_回溯数 = 0
    _词法_错误数 = 0
    _字串_扫描次数 = 0
    _字串_转义次数 = 0
    _字串_未终止数 = 0
}
// 模块图编译模式 (项目根 → 全量模块图编译)
如果 (Nova模式 == "compile" 且 Nova模块图模式) {
    定义 可变 运行时_输入文件 = 输入文件
    定义 可变 运行时_参数列 = Nova参数列
    定义 可变 运行时_输出路径 = Nova输出路径
    定义 可变 运行时_详细模式 = Nova详细模式
    定义 可变 运行时_项目文件 = Nova项目文件
    定义 可变 运行时_Profile = Nova_性能档案
    定义 可变 运行时_入口模块 = Nova入口模块
    定义 可变 运行时_入口符号 = Nova入口符号
    定义 可变 运行时_镜像格式 = Nova镜像格式
    定义 可变 运行时_运行时类型 = Nova运行时类型
    定义 可变 运行时_调试合同 = Nova调试合同
    定义 可变 运行时_产物类型 = Nova产物类型
    定义 可变 运行时_链接布局 = Nova链接布局
    定义 可变 运行时_目标名 = 当前目标名称
    定义 可变 项目根 = 运行时_输入文件
    定义 可变 _argv诊断 = 字符串拼接("输入文件=", 输入文件)
    如果 (是列表(运行时_参数列) == 真) {
        定义 可变 _argvi = 0
        当 (_argvi < 计数(运行时_参数列) 且 _argvi < 6) {
            _argv诊断 = 字符串拼接(_argv诊断, 字符串拼接("\nargv[", 字符串拼接(转字符串(_argvi), 字符串拼接("]=", 运行时_参数列[_argvi]))))
            _argvi = _argvi + 1
        }
    }
    如果 (运行时_详细模式) { 写文件("/tmp/nova_stage2_argv.txt",  _argv诊断, 0) }
    如果 (项目根 == "") { 项目根 = "." }
    如果 (Nova_是Nova文件(项目根)) {
        定义 父目录2 = Nova_原始父目录(项目根)
        如果 (父目录2 != "") { 项目根 = 父目录2 }
        否则 { 项目根 = "." }
    }
    如果 (项目根 == "") { 项目根 = "." }

    如果 (运行时_输出路径 == "") {
        如果 (运行时_目标名 == "linux") {
            运行时_输出路径 = 路径_组合(项目根, "nova_module_graph")
        } 否则 如果 (运行时_目标名 == "裸机") {
            运行时_输出路径 = 路径_组合(项目根, "nova_module_graph.kernel")
        } 否则 {
            运行时_输出路径 = 路径_组合(项目根, "nova_module_graph.exe")
        }
    }

    打印("Phase 0: module-graph bootstrap...\n")
    // 编译器全局状态初始化(每次编译前必须调用)
    编译器_重置全部状态()
    Nova_重置驱动态()
    当前目标名称 = 运行时_目标名

    // 项目系统: 解析项目合同
    定义 可变 _项目合同 = 项目合同_创建()
    // 优先级1: CLI --project 指定
    如果 (运行时_项目文件 != "") {
        _项目合同 = 项目描述_解析(运行时_项目文件)
    } 否则 {
        // 优先级2: 自动发现 project.nova / project.txt
        定义 _自动项目 = 项目描述_自动发现(项目根)
        如果 (_自动项目 != 空) {
            _项目合同 = 项目描述_解析(_自动项目)
            如果 (运行时_详细模式) { 打印文本(字符串拼接("  [项目系统] 自动发现: ", _自动项目)) }
        }
    }
    // CLI覆盖
    如果 (运行时_Profile != "") { 项目合同_CLI覆盖(_项目合同, "profile", 运行时_Profile) }
    如果 (运行时_入口模块 != "") { 项目合同_CLI覆盖(_项目合同, "entry-module", 运行时_入口模块) }
    如果 (运行时_入口符号 != "") { 项目合同_CLI覆盖(_项目合同, "entry-symbol", 运行时_入口符号) }
    如果 (运行时_镜像格式 != "") { 项目合同_CLI覆盖(_项目合同, "image-format", 运行时_镜像格式) }
    如果 (运行时_产物类型 != "") { 项目合同_CLI覆盖(_项目合同, "emit", 运行时_产物类型) }
    如果 (运行时_链接布局 != "") { 项目合同_CLI覆盖(_项目合同, "link-layout", 运行时_链接布局) }
    如果 (运行时_运行时类型 != "") { 项目合同_CLI覆盖(_项目合同, "runtime", 运行时_运行时类型) }
    如果 (运行时_调试合同 != "") { 项目合同_CLI覆盖(_项目合同, "debug-contract", 运行时_调试合同) }

    // 解析活跃Profile → 构建配置
    定义 _活跃Profile = Profile_解析(运行时_Profile, 项目合同_默认Profile(_项目合同))
    定义 _构建配置 = 构建配置_从Profile(_活跃Profile)

    // Profile驱动目标名称联动
    如果 (构建配置_是裸机(_构建配置)) {
        当前目标名称 = "裸机"
        如果 (运行时_输出路径 == "" 或 以结尾(运行时_输出路径, "nova_module_graph")) {
            运行时_输出路径 = 路径_组合(项目根, "nova_module_graph.kernel")
        }
    }

    如果 (运行时_详细模式) {
        打印("模式:")
        打印("compile/module-graph")
        打印("项目根:")
        打印文本(项目根)
        打印("输出:")
        打印文本(运行时_输出路径)
        如果 (项目合同_名称(_项目合同) != "") {
            项目合同_打印报告(_项目合同)
            构建配置_打印(_构建配置)
        }
    }

    模块图_设置详细模式(运行时_详细模式)
    // 传递项目合同给模块图编译器
    如果 (项目合同_名称(_项目合同) != "") {
        模块图_设置项目合同(_项目合同)
    }
    定义 模块图结果 = 模块_自举(项目根, 运行时_输出路径)
    如果 (模块图结果) { 退出(0) }
    退出(1)
}
// self-test模式 (不需要输入文件)
如果 (Nova模式 == "self-test") {
    运行全部自检()
    退出(0)
}
// 无输入文件
如果 (输入文件 == "") {
    打印("用法: nova <源文件.nova> [--mode auto|interpret|compile|debug|bootstrap]")
    打印("运行 nova --help 查看完整帮助")
    退出(1)
}
如果 (Nova模式 == "interpret" 或 Nova模式 == "auto" 或 Nova模式 == "debug") {
    定义 可变 GPU管理器 = GPU管理器_创建()
    定义 GPU设备数 = GPU管理器_枚举设备(GPU管理器)
    如果 (GPU设备数 > 0) {
        GPU管理器_自动选择(GPU管理器)
        GPU管理器_报告(GPU管理器)
    } 否则 {
        打印("  GPU: 未检测到支持的GPU (仅CPU模式)")
    }
}
// 执行流程
打印("模式:")
打印(Nova模式)
打印("读取:")
打印(输入文件)

定义 Nova源码 = 读文件(输入文件)
如果 (Nova源码 == 空) { 打印("错误: 无法读取文件") 退出(1) }
// Phase 1: 前端 (词法→语法→语义)
打印("Phase 1: 前端分析...")
定义 可变 词表 = 前端_词法分析(Nova源码)

定义 程序 = 前端_解析_程序(词表)
如果 (是列表(程序) == 假 或 计数(程序) < 2) {
    打印("错误: 语法分析结果格式无效")
    退出(1)
}
定义 可变 Nova函数列 = 程序[0]
定义 可变 Nova主体 = 程序[1]
如果 (是列表(Nova函数列) == 假) { Nova函数列 = [] }
如果 (是列表(Nova主体) == 假) { Nova主体 = [] }

// Phase 1.5: 语义预检查
打印("Phase 1.5: 语义预检查...")
定义 语义结果 = 语义_最小预检查(Nova函数列, Nova主体)
定义 语义诊断 = 语义预检_生成诊断收集器(输入文件, 语义结果)
定义 语义警告数 = 诊断收集器_警告数(语义诊断)
定义 语义错误数 = 诊断收集器_错误数(语义诊断)
如果 (语义警告数 > 0 或 语义错误数 > 0) {
    诊断收集器_按行排序(语义诊断)
    诊断_打印全部(语义诊断)
}

// Phase 2: IR (字节码编码 + 优化)
打印("Phase 2: IR生成...")

如果 (Nova模式 == "interpret" 或 Nova模式 == "auto" 或 Nova模式 == "debug") {
    // 生成Nova-Bytecode
    定义 字节码 = Nova编码_编译程序(Nova函数列, Nova主体)
    打印(字符串拼接("  字节码: ", 字符串拼接(转字符串(Nova字节码_代码大小(字节码)), "字节")))
    打印(字符串拼接("  常量池: ", 字符串拼接(转字符串(Nova字节码_常量数(字节码)), "项")))

    // Phase 3: 运行时
    如果 (Nova模式 == "debug") {
        // 调试模式
        打印("Phase 3: 调试执行...")
        定义 _dbg = 调试器_创建()
        定义 vm = VM_创建(字节码)
        VM_注册GPU内建(vm)
        VM_设置调试(vm, 真)
        // 反汇编
        打印("── 字节码反汇编 ──")
        Nova字节码_反汇编(字节码)
        打印("── 开始执行 ──")
        定义 主函数 = 字典获取(字节码[6], "__主程序__")
        如果 (主函数 != 空) { vm[7] = 主函数[0] }
        定义 结果 = VM_执行(vm)
        打印(字符串拼接("执行完成: ", 字符串拼接(转字符串(结果), "条指令")))

    } 否则 如果 (Nova模式 == "interpret") {
        // 纯解释模式
        打印("Phase 3: 解释执行...")
        定义 结果 = VM_运行字节码(字节码)
        打印(字符串拼接("执行完成: 状态=", 字符串拼接(转字符串(结果[0]), 字符串拼接(" 指令=", 转字符串(结果[1])))))

    } 否则 {
        // 自动模式: 解释+JIT
        打印("Phase 3: 自动执行 (解释+JIT)...")

        // 初始化策略引擎
        定义 检测器 = 热点检测器_创建()
        定义 jit = JIT编译器_创建()
        定义 策略 = 策略引擎_创建(检测器, jit)

        // 设置热点回调
        热点检测器_设置回调(检测器, 策略引擎_热点回调(策略))

        // 创建VM并执行
        定义 vm = VM_创建(字节码)
        VM_注册GPU内建(vm)
        VM_绑定热点检测器(vm, 检测器)
        VM_绑定JIT缓冲(vm, jit)
        策略引擎_绑定VM(策略, vm)
        定义 主函数 = 字典获取(字节码[6], "__主程序__")
        如果 (主函数 != 空) { vm[7] = 主函数[0] }
        定义 结果 = 策略引擎_执行块(策略,  vm, 0)

        打印(字符串拼接("执行完成: ", 字符串拼接(转字符串(结果), "条指令")))

        // 显示统计
        策略引擎_统计(策略)
        定义 jit统计 = JIT编译器_统计(jit)
        打印(字符串拼接("JIT编译: ", 字符串拼接(转字符串(jit统计[0]), "次")))
    }

} 否则 如果 (Nova模式 == "compile") {
    // AOT 编译: Nova源码 → x86-64机器码 → PE/ELF可执行文件
    // 全程原生，不依赖任何外部编译器 (Rust/Go/C/Python)
    打印("Phase 2: AOT代码生成...")

    目标ELF = 0
    定义 可变 目标Kernel = 0
    如果 (Nova目标 == "x86-64-linux" 或 Nova目标 == "linux" 或 Nova目标 == "x86-64") { 目标ELF = 1 }
    如果 (Nova目标 == "kernel" 或 Nova目标 == "裸机") {
        目标Kernel = 1
        目标ELF = 2
    }

    编译_重置代码生成状态(真, 假)
    编译_设置目标ELF(目标ELF)
    管线_设置裸机模式(目标ELF == 2)
    // 运行时注册必须绑定当前函数表，否则 __运行时_字典设 会拿到坏指针
    发射_权威运行时(函数表)
    定义 可变 预扫i = 0
    当 (预扫i < 计数(Nova主体)) {
        定义 预扫句 = Nova主体[预扫i]
        如果 (是列表(预扫句) == 假 或 计数(预扫句) < 2) {
            预扫i = 预扫i + 1
            继续
        }
        如果 (预扫句[0] == 节_定义) {
            定义 预扫名 = 预扫句[1]
            如果 (字典取(全局变量表, 预扫名) == 空) {
                字典设(全局变量表, 预扫名, 全局变量数 + 1)
                全局变量数 = 全局变量数 + 1
            }
        }
        预扫i = 预扫i + 1
    }
    如果 (字典取(全局变量表, "__错误_标志") == 空) {
        字典设(全局变量表, "__错误_标志", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_值") == 空) {
        字典设(全局变量表, "__错误_值", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_基指针") == 空) {
        字典设(全局变量表, "__错误_基指针", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_栈指针") == 空) {
        字典设(全局变量表, "__错误_栈指针", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    如果 (字典取(全局变量表, "__错误_跳转") == 空) {
        字典设(全局变量表, "__错误_跳转", 全局变量数 + 1)
        全局变量数 = 全局变量数 + 1
    }
    定义 可变 预函i = 0
    当 (预函i < 计数(Nova函数列)) {
        定义 预函名 = Nova函数列[预函i][1]
        如果 (字典取(函数表, 预函名) == 空) {
            字典设(函数表, 预函名, 0 - 1)
        }
        预函i = 预函i + 1
    }

    // 强制重新初始化代码缓冲区(全局init可能未正确设置magic)
    代码_重置()

    // 强制设置AST常量(全局init可能未正确设置)
    编译_初始化AST常量()

    // 编译全部函数到代码缓冲区
    定义 可变 fi = 0
    当 (fi < 计数(Nova函数列)) {
        如果 (是列表(Nova函数列[fi]) == 假 或 计数(Nova函数列[fi]) < 4) {
            fi = fi + 1
            继续
        }
        编译_函数(Nova函数列[fi], 空)
        fi = fi + 1
    }

    // 编译主体语句
    定义 入口 = 代码位
    当前函数名 = "__主程序__"
    变量表 = 字典()
    变量数 = 0
    主体模式 = 1
    发射_序言()
    修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_堆初始化")
    发射(0xE8)
    发射32(0)
    如果 (目标ELF == 0) {
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_设控制台UTF8")
        发射(0xE8)
        发射32(0)
    }
    如果 (全局变量数 > 0) {
        发射_载立即(1, 全局变量数 * 8)
        修正表_追加记录(修正表, "call", 代码位 + 1, "__运行时_分配")
        发射(0xE8)
        发射32(0)
        修正表_追加记录(修正表, "rt_globals", 代码位 + 3, 空)
        发射组([0x48, 0x89, 0x05])
        发射32(0)
    }
    如果 (计数(Nova主体) > 0) {
        定义 可变 si = 0
        当 (si < 计数(Nova主体)) {
            编译_语句(Nova主体[si])
            si = si + 1
        }
    }
    如果 (目标ELF == 2) {
        发射(0xFA)
        发射(0xF4)
        发射组([0xEB, 0xFC])
    } 否则 如果 (目标ELF == 1) {
        // Linux: call 主程序() if defined, then syscall exit
        定义 可变 _有主 = 假
        定义 可变 _fic = 0
        当 (_fic < 计数(Nova函数列)) {
            如果 (Nova函数列[_fic][1] == "主程序") { _有主 = 真 }
            _fic = _fic + 1
        }
        如果 (_有主) {
            // 直接计算call位移,绕过fixup的0==空歧义
            定义 _主偏 = 字典取(函数表, "主程序")
            发射(0xE8)
            定义 _call_end = 代码位 + 4
            发射32(_主偏 - _call_end)
            发射组([0x48, 0x89, 0xC7])
        } 否则 {
            发射组([0x48, 0x31, 0xFF])
        }
        发射_载立即(0, 60)
        发射组([0x0F, 0x05])
    } 否则 {
        发射_载立即(1, 0)
        修正表_追加记录(修正表, "iat_exit", 代码位 + 2, 空)
        发射_调用间接(0)
    }
    发射(0xCC)
    定义 帧2 = (变量数 + 8) * 8
    定义 对齐帧2 = ((帧2 + 15) / 16) * 16
    _elf写32(代码, 帧大小位, 对齐帧2)

    // 嵌入字符串数据到代码段尾部
    定义 可变 _si = 0
    当 (_si < 计数(字串表)) {
        追加(字串偏移, 代码位)
        定义 _s = 字串表[_si]
        定义 可变 _bi = 0
        当 (_bi < 字节长度(_s)) {
            发射(字节取(_s, _bi))
            _bi = _bi + 1
        }
        发射(0)
        _si = _si + 1
    }

    打印(字符串拼接("  代码大小: ", 字符串拼接(转字符串(代码位), 字符串拼接(" 字节 (含 ", 字符串拼接(转字符串(计数(字串表)), " 个字符串)")))))
    打印(字符串拼接("  函数数: ", 转字符串(计数(Nova函数列))))

    // Phase 3: 链接+输出
    打印("Phase 3: 链接输出...")

    如果 (目标Kernel == 1) {
        // 裸机内核格式
        定义 kernel结果 = 构建裸机ELF(入口,  代码位, 0, 0)
        定义 kernel数据 = kernel结果[0]
        定义 kernel大小 = kernel结果[1]
        定义 可变 输出 = 替换(输入文件, ".nova", ".kernel")
        如果 (输出 == 输入文件) { 输出 = 字符串拼接(输入文件, ".kernel") }
        如果 (Nova输出路径 != "") { 输出 = Nova输出路径 }
        写二进制(输出, kernel数据, kernel大小)
        定义 qemu工件 = QEMU_写出Bundle工件(输出)
        打印(字符串拼接("═══ 生成裸机内核: ", 输出))
        打印(字符串拼接("═══ 生成 QEMU Bundle: ", qemu工件[1]))
    } 否则 如果 (目标ELF == 1) {
        定义 linux_wrap_offsets = 发射_权威wrappers()
        定义 elf结果 = 构建ELF(入口, 代码位, linux_wrap_offsets)
        定义 elf数据 = elf结果[0]
        定义 elf大小 = elf结果[1]
        定义 可变 输出 = 替换(输入文件, ".nova", "")
        如果 (输出 == 输入文件) { 输出 = 字符串拼接(输入文件, ".elf") }
        如果 (Nova输出路径 != "") { 输出 = Nova输出路径 }
        写二进制(输出, elf数据, elf大小)
        打印(字符串拼接("═══ 生成 ELF64: ", 输出))
    } 否则 {
        // Windows PE格式 (默认)
        定义 pe结果 = 构建PE(入口, 代码位)
        定义 pe数据 = pe结果[0]
        定义 pe大小 = pe结果[1]
        定义 可变 输出 = 替换(输入文件, ".nova", ".exe")
        如果 (输出 == 输入文件) { 输出 = 字符串拼接(输入文件, ".exe") }
        如果 (Nova输出路径 != "") { 输出 = Nova输出路径 }
        写二进制(输出, pe数据, pe大小)
        打印(字符串拼接("═══ 生成 PE: ", 输出))
    }
    退出(0)
} 否则 如果 (Nova模式 == "self-test") {
    // 模块自检: 运行全部运行时模块自检
    运行全部自检()
    退出(0)
}

打印("")
打印("═══ Nova 执行完毕 ═══")
